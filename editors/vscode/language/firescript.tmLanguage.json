{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "firescript",
  "scopeName": "source.fire",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#class-declaration" },
    { "include": "#function-definition" },
    { "include": "#new-expression" },
    { "include": "#decorator" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#this-keyword" },
    { "include": "#function-calls" },
    { "include": "#numerics" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.fire",
          "match": "//.*$"
        },
        {
          "name": "comment.block.fire",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.fire" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fire",
          "begin": "([rRfFbB]{0,3})\"",
          "end": "\"",
          "beginCaptures": {
            "1": { "name": "storage.type.string.fire" }
          },
          "patterns": [
            { "name": "constant.character.escape.fire", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.fire",
          "begin": "([rRfFbB]{0,3})'",
          "end": "'",
          "beginCaptures": {
            "1": { "name": "storage.type.string.fire" }
          },
          "patterns": [
            { "name": "constant.character.escape.fire", "match": "\\\\." }
          ]
        }
      ]
    },
    "decorator": {
      "patterns": [
        {
          "name": "entity.name.tag.fire",
          "match": "@[A-Za-z_][A-Za-z0-9_./]*"
        }
      ]
    },
    "class-declaration": {
      "patterns": [
        {
          "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(from)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.class.fire" },
            "2": { "name": "entity.name.type.class.fire" },
            "3": { "name": "keyword.control.inheritance.fire" },
            "4": { "name": "entity.name.type.class.fire" }
          }
        }
      ]
    },
    "function-definition": {
      "comment": "Matches: [modifier] return_type name(  — the main function definition pattern",
      "patterns": [
        {
          "match": "(?:^|(?<=\\s))(?:(static)\\s+)?((?:nullable\\s+)?(?:int8|int16|int32|int64|uint8|uint16|uint32|uint64|float32|float64|float128|bool|string|tuple|void|[A-Z][A-Za-z0-9_]*))(?:\\[\\])*\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "storage.modifier.fire" },
            "2": { "name": "storage.type.fire" },
            "3": { "name": "entity.name.function.fire" }
          }
        }
      ]
    },
    "new-expression": {
      "patterns": [
        {
          "match": "\\b(new)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.operator.new.fire" },
            "2": { "name": "entity.name.type.fire" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fire",
          "match": "\\b(if|else|elif|while|for|in|break|continue|return|ternary)\\b"
        },
        {
          "name": "storage.modifier.fire",
          "match": "\\b(static|const|nullable|copyable)\\b"
        },
        {
          "name": "keyword.control.import.fire",
          "match": "\\b(import|from|as)\\b"
        },
        {
          "name": "keyword.declaration.fire",
          "match": "\\b(class|constraint|directive|generator)\\b"
        },
        {
          "name": "keyword.operator.new.fire",
          "match": "\\bnew\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.fire",
          "match": "\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64|float32|float64|float128|bool|string|tuple|void)\\b"
        },
        {
          "comment": "User-defined type names (PascalCase) used as variable types or return types",
          "name": "entity.name.type.fire",
          "match": "(?<![.])\\b([A-Z][A-Za-z0-9_]*)\\b(?!\\s*[({])"
        }
      ]
    },
    "this-keyword": {
      "patterns": [
        {
          "name": "variable.language.this.fire",
          "match": "\\bthis\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "comment": "Method calls: obj.method(",
          "match": "(?<=[.])([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.fire" }
          }
        },
        {
          "comment": "Regular function and constructor calls",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.fire" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.fire",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "numerics": {
      "patterns": [
        {
          "name": "constant.numeric.hex.fire",
          "match": "(?<![A-Za-z_0-9])-?0[xX][0-9a-fA-F_]+"
        },
        {
          "name": "constant.numeric.binary.fire",
          "match": "(?<![A-Za-z_0-9])-?0[bB][01_]+"
        },
        {
          "name": "constant.numeric.octal.fire",
          "match": "(?<![A-Za-z_0-9])-?0[oO][0-7_]+"
        },
        {
          "name": "constant.numeric.float.fire",
          "match": "(?<![A-Za-z_0-9])-?[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9]+)?(?:f128|f64|f32|f)?"
        },
        {
          "name": "constant.numeric.integer.fire",
          "match": "(?<![A-Za-z_0-9])-?[0-9][0-9_]*(?:i8|i16|i32|i64|u8|u16|u32|u64)?"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.fire",
          "match": "\\+\\+|--|\\*\\*=|\\*\\*|\\+=|-=|\\*=|/=|%=|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.comparison.fire",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.logical.fire",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.fire",
          "match": "="
        },
        {
          "name": "keyword.operator.reference.fire",
          "match": "&"
        },
        {
          "name": "punctuation.separator.fire",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.brackets.fire",
          "match": "[()\\[\\]{}]"
        }
      ]
    }
  }
}

