import @firescript/std.io.{print, println};

// Test int8
i8_val: int8 = 127i8;
print("int8: ");
println(i8_val);

// Test int16
i16_val: int16 = 32767i16;
print("int16: ");
println(i16_val);

// Test int32
i32_val: int32 = 2147483647i32;
print("int32: ");
println(i32_val);

// Test int64
i64_val: int64 = 9223372036854775807i64;
print("int64: ");
println(i64_val);

// Test uint8
u8_val: uint8 = 255u8;
print("uint8: ");
println(u8_val);

// Test uint16
u16_val: uint16 = 65535u16;
print("uint16: ");
println(u16_val);

// Test uint32
u32_val: uint32 = 4294967295u32;
print("uint32: ");
println(u32_val);

// Test uint64
u64_val: uint64 = 18446744073709551615u64;
print("uint64: ");
println(u64_val);

// Test float32
f32_val: float32 = 3.14159f32;
print("float32: ");
println(f32_val);

// Test float64
f64_val: float64 = 2.71828f64;
print("float64: ");
println(f64_val);

// Test float128
f128_val: float128 = 1.23456789f128;
print("float128: ");
println(f128_val);

// Test bool
b_true: bool = true;
b_false: bool = false;
print("bool true: ");
println(b_true);
print("bool false: ");
println(b_false);

// Test string
str_val: string = "Hello, firescript!";
print("string: ");
println(str_val);

/* EXPECT
int8: 127
int16: 32767
int32: 2147483647
int64: 9223372036854775807
uint8: 255
uint16: 65535
uint32: 4294967295
uint64: 18446744073709551615
float32: 3.141590
float64: 2.718280
float128: 1.234568
bool true: true
bool false: false
string: Hello, firescript!
*/
