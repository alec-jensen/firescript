import @firescript/std.io.println;

// A top-level 'export' applied to an enum definition.
export enum Exported {
    Only
}

enum Color {
    Red,
    Green,
    Blue
}

enum Direction {
    North,
    South,
    East,
    West
}

a: Color = Color.Red;
b: Color = Color.Green;
c: Color = Color.Blue;

// Reassignment: the previously-held owned enum value must be dropped
// without corrupting subsequent allocations.
a = Color.Blue;

d: Direction = Direction.North;
d = Direction.West;

println("constructed all variants");
println("reassignment ok");

/* EXPECT
constructed all variants
reassignment ok
*/
