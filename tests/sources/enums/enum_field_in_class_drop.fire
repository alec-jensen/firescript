// An enum with owned payload stored as a class field: dropping the class
// must run the enum's generated destructor (including nested class payloads).
import @firescript/std.io.println;

class Box {
    label: string;

    fn Box(label: string) {
        this.label = label;
    }
}

enum Note {
    Text(body: string),
    Silent
}

enum Slot {
    Holds(inner: Box),
    Vacant
}

class Holder {
    note: Note;

    fn Holder(note: Note) {
        this.note = note;
    }
}

class Shelf {
    slot: Slot;

    fn Shelf(slot: Slot) {
        this.slot = slot;
    }
}

fn useHolder() -> void {
    n: Note = Note.Text("inside");
    h: Holder = Holder(n);
    match h.note {
        Note.Text(body) -> println("holder: " + body),
        Note.Silent -> println("holder: silent"),
    }
}

fn useShelf() -> void {
    b: Box = Box("boxed");
    s: Slot = Slot.Holds(b);
    shelf: Shelf = Shelf(s);
    match shelf.slot {
        Slot.Holds(inner) -> println("shelf: " + inner.label),
        Slot.Vacant -> println("shelf: vacant"),
    }
}

useHolder();
useShelf();
println("done");

/* EXPECT
holder: inside
shelf: boxed
done
*/
