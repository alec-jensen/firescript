// Enum bodies tolerate comments and trailing commas.
import @firescript/std.io.println;

enum Status {
    // a tag-only variant
    Ok,
    /* payload variant */
    Code(int32 value),
    Fail,
}

Status s = Status.Code(42);

match s {
    Status.Ok -> println("ok"),
    Status.Code(value) -> println("code " + (value as string)),
    Status.Fail -> println("fail"),
}

/* EXPECT
code 42
*/
