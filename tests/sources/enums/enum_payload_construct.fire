import @firescript/std.io.println;

// Payload fields are limited to copyable scalar types in this pass; owned
// payload data (strings, classes) requires the destructor support planned
// for a later stage (see docs/internal/development/version_planning.md,
// 0.6.0 "Griffin").
enum Shape {
    Circle(radius: float64),
    Rectangle(width: float64, height: float64),
    Labeled(code: int32, active: bool),
    Point
}

a: Shape = Shape.Circle(3.0);
b: Shape = Shape.Rectangle(2.0, 5.0);
c: Shape = Shape.Labeled(7, true);
d: Shape = Shape.Point;

// Reassignment across variants with different payload shapes must not
// corrupt the shared tagged-union storage.
a = Shape.Rectangle(1.0, 1.0);
b = Shape.Point;

println("constructed all payload variants");
println("reassignment across variants ok");

/* EXPECT
constructed all payload variants
reassignment across variants ok
*/
