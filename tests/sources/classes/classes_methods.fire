//@ snapshot: fir, flir
// Constructors and instance methods test

import @firescript/std.io.println;

class Point {
    x: int32;
    y: int32;

    // Constructor named same as class
    fn Point(&mut this, x: int32, y: int32) {
        this.x = x;
        this.y = y;
    }
    fn sum(&this) -> int32 {
        return this.x + this.y;
    }
}

p: Point = new Point(2, 3);
println(p.sum());

/* EXPECT
5
*/
