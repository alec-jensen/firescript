// Java-like 'new ClassName(args)' constructor syntax, an alternate to the
// direct 'ClassName(args)' constructor call form used elsewhere.
import @firescript/std.io.println;

class Box {
    v: int32;

    fn Box(v: int32) {
        this.v = v;
    }
}

fn main() -> void {
    b: Box = new Box(5i32);
    println(b.v);
}

/* EXPECT
5
*/
