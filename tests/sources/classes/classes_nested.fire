// Nested classes test: Rect composed of Points

import @firescript/std.io.println;

class Point {
    x: int32;
    y: int32;
    fn Point(&mut this, x: int32, y: int32) {
        this.x = x;
        this.y = y;
    }
}

class Rect {
    topLeft: Point;
    bottomRight: Point;
    fn Rect(&mut this, tl: Point, br: Point) {
        this.topLeft = tl;
        this.bottomRight = br;
    }
    
    // TODO: lsp says `this` is a point, doesnt show info for bottomRight or topLeft,
    // but does show info for their x and y fields. which are probably both the same issue,
    // it is picking up types from the first class, Point, and not recognizing that this is a Rect with Point fields.
    // so it sees `this` in Rect as a point, and it sees the x and y fields of the Rect's points as the x and y of Point
    fn width(&this) -> int32 {
        return this.bottomRight.x - this.topLeft.x;
    }
}

p1: Point = new Point(1, 2);
p2: Point = new Point(5, 7);
r: Rect = new Rect(p1, p2);
println(r.topLeft.x);
println(r.bottomRight.y);
println(r.width());

/* EXPECT
1
7
4
*/
