import @firescript/std.io.println;

class Greeter {
    prefix: string;

    fn Greeter(prefix: string) {
        this.prefix = prefix;
    }

    fn greet(&this, name: string?) -> string {
        return this.prefix + " " + name;
    }
}

g: Greeter = Greeter("Hello");
println(g.greet("World"));

/* EXPECT
Hello World
*/
