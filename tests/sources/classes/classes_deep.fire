import @firescript/std.io.println;

class Vec2 {
    x: int32;
    y: int32;

    fn Vec2(&mut this, x: int32, y: int32) {
        this.x = x;
        this.y = y;
    }

    fn add(&this, other: &Vec2) -> Vec2 {
        return Vec2(this.x + other.x, this.y + other.y);
    }

    fn dot(&this, other: &Vec2) -> int32 {
        return (this.x * other.x) + (this.y * other.y);
    }
}

v1 = Vec2(3, 4);
v2 = Vec2(1, 2);
v3 = v1.add(v2);
println(v3.x);
println(v3.y);
println(v1.dot(v2));

/* EXPECT
4
6
11
*/
