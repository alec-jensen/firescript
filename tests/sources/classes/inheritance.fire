//@ snapshot: fir, flir
import @firescript/std.io.println;

class Person {
    name: string;
    age: int32;

    fn Person(&mut this, name: string, age: int32) {
        this.name = name;
        this.age = age;
    }

    fn describe(&this) -> string {
        return this.name + " is " + toString(this.age);
    }
}

class Student from Person {
    school: string;

    fn Student(&mut this, name: string, age: int32, school: string) {
        // Constructor chaining to parent
        this.super(name, age);
        this.school = school;
    }

    fn describe(&this) -> string {
        return this.name + " is " + toString(this.age) + " at " + this.school;
    }
}

s: Student = new Student("Jane", 18, "School");
println(s.describe());
println(s.name);
println(s.age);

// Multi-level inheritance (double/triple/quad)

class A {
    id: string;

    fn A(&mut this, id: string) {
        this.id = id;
    }

    fn root(&this) -> string {
        return this.id;
    }

    fn chain(&this) -> string {
        return "A(" + this.id + ")";
    }
}

class B from A {
    bid: string;

    fn B(&mut this, id: string, bid: string) {
        this.super(id);
        this.bid = bid;
    }

    fn onlyB(&this) -> string {
        return this.bid;
    }

    fn chain(&this) -> string {
        return "A(" + this.id + ")->B(" + this.bid + ")";
    }
}

class C from B {
    cid: string;

    fn C(&mut this, id: string, bid: string, cid: string) {
        this.super(id, bid);
        this.cid = cid;
    }

    fn onlyC(&this) -> string {
        return this.cid;
    }

    fn chain(&this) -> string {
        return "A(" + this.id + ")->B(" + this.bid + ")->C(" + this.cid + ")";
    }
}

class D from C {
    did: string;

    fn D(&mut this, id: string, bid: string, cid: string, did: string) {
        this.super(id, bid, cid);
        this.did = did;
    }

    fn chain(&this) -> string {
        return "A(" + this.id + ")->B(" + this.bid + ")->C(" + this.cid + ")->D(" + this.did + ")";
    }
}

d: D = new D("a", "b", "c", "d");
println(d.chain());
println(d.id);
println(d.bid);
println(d.cid);
println(d.did);
println(d.root());
println(d.onlyB());
println(d.onlyC());

