// Calling a class's own constructor through `Type.Type(...)` syntax (the
// TYPE_METHOD_CALL node form) instead of the usual `Type(...)` /
// `new Type(...)` forms -- exercises the "is a constructor, not static"
// branch of TYPE_METHOD_CALL type-checking.
import @firescript/std.io.println;

class Foo {
    v: int32;

    fn Foo(v: int32) {
        this.v = v;
    }
}

f: Foo = Foo.Foo(42);
println(f.v);

/* EXPECT
42
*/
