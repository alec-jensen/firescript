import @firescript/std.io.println;

// A class holding a copyable (by-value) struct field: assigning/reading
// the whole nested struct (not just its scalar sub-fields) exercises the
// struct-sized Load/Store paths in flir_to_asm.py (_emit_load /
// _emit_store's `t.kind == "struct"` branches), which whole-object field
// access alone (as in functions_many_params.fire) doesn't reach.

copyable class Point {
    x: int32;
    y: int32;

    fn Point(x: int32, y: int32) {
        this.x = x;
        this.y = y;
    }
}

class Line {
    start: Point;
    end: Point;

    fn Line(&mut this, start: Point, end: Point) {
        this.start = start;
        this.end = end;
    }

    fn midpointStart(&this) -> Point {
        return this.start;
    }
}

a: Point = Point(0, 0);
b: Point = Point(4, 8);
l: Line = new Line(a, b);

println(l.start.x);
println(l.start.y);
println(l.end.x);
println(l.end.y);

copied: Point = l.midpointStart();
println(copied.x);
println(copied.y);

// Whole-struct field-to-field assignment.
l.start = l.end;
println(l.start.x);
println(l.start.y);

/* EXPECT
0
0
4
8
0
0
4
8
*/
