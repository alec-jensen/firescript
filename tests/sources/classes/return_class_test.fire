// Test returning a class from a function

import @firescript/std.io.println;

class Point {
    x: int32;
    y: int32;
}

fn makePoint(x: int32, y: int32) -> Point {
    p: Point = Point(x, y);
    return p;  // Return the point - what happens here?
}

p1: Point = makePoint(10i32, 20i32);
println(p1.x);
println(p1.y);

/* EXPECT
10
20
*/
