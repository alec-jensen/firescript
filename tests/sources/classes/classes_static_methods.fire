//@ snapshot: fir, flir
import @firescript/std.io.println;

class Math {
    static fn max(a: int32, b: int32) -> int32 {
        if (a > b) {
            return a;
        }
        return b;
    }

    static fn add(a: int32, b: int32) -> int32 {
        return a + b;
    }

    fn twice(x: int32) -> int32 {
        return x * 2i32;
    }
}

println(Math.max(3i32, 7i32));
println(Math.add(8i32, 5i32));

m: Math = Math();
println(m.twice(6i32));

/* EXPECT
7
13
12
*/
