import @firescript/std.io.println;

enum Shape {
    Circle(radius: float64),
    Rectangle(width: float64, height: float64),
    Point
}

fn describe(s: Shape) -> void {
    match s {
        Shape.Circle(radius) -> {
            println("circle r=" + (radius as string));
        }
        Shape.Rectangle(width, height) -> {
            println("rect " + (width as string) + "x" + (height as string));
        }
        Shape.Point -> {
            println("point");
        }
    }
}

describe(Shape.Circle(3.0));
describe(Shape.Rectangle(2.0, 5.0));
describe(Shape.Point);

// Field renaming (`field: local`) and field omission both work.
fn describeRenamed(s: Shape) -> void {
    match s {
        Shape.Circle(radius: r) -> { println("renamed circle r=" + (r as string)); }
        Shape.Rectangle(width) -> { println("rect width only=" + (width as string)); }
        Shape.Point -> { println("renamed point"); }
    }
}

describeRenamed(Shape.Circle(1.5));
describeRenamed(Shape.Rectangle(4.0, 9.0));
describeRenamed(Shape.Point);

/* EXPECT
circle r=3.000000
rect 2.000000x5.000000
point
renamed circle r=1.500000
rect width only=4.000000
renamed point
*/
