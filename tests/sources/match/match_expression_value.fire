import @firescript/std.io.println;

enum Shape {
    Circle(float64 radius),
    Rectangle(float64 width, float64 height),
    Point
}

float64 area(Shape s) {
    return match s {
        Shape.Circle(radius) -> 3.14159 * radius * radius,
        Shape.Rectangle(width, height) -> width * height,
        Shape.Point -> 0.0
    };
}

println(area(Shape.Circle(2.0)) as string);
println(area(Shape.Rectangle(3.0, 4.0)) as string);
println(area(Shape.Point) as string);

// Match-as-expression used directly in a variable declaration initializer.
Shape s = Shape.Rectangle(5.0, 6.0);
float64 a = match s {
    Shape.Circle(radius) -> radius,
    Shape.Rectangle(width, height) -> width + height,
    Shape.Point -> -1.0
};
println(a as string);
