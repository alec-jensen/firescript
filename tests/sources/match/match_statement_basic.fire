import @firescript/std.io.println;

enum Color {
    Red,
    Green,
    Blue
}

fn describe(c: Color) -> void {
    match c {
        Color.Red -> { println("red"); }
        Color.Green -> { println("green"); }
        Color.Blue -> { println("blue"); }
    }
}

describe(Color.Red);
describe(Color.Green);
describe(Color.Blue);

/* EXPECT
red
green
blue
*/
