import @firescript/std.io.println;

enum Shape {
    Circle(float64 radius),
    Rectangle(float64 width, float64 height),
    Triangle(float64 base, float64 height),
    Point
}

void describe(Shape s) {
    match s {
        Shape.Circle(radius) -> { println("circle r=" + (radius as string)); }
        _ -> { println("something else"); }
    }
}

describe(Shape.Circle(1.0));
describe(Shape.Rectangle(2.0, 3.0));
describe(Shape.Triangle(4.0, 5.0));
describe(Shape.Point);
