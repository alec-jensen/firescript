import @firescript/std.io.println;

enum Shape {
    Circle(radius: float64),
    Rectangle(width: float64, height: float64),
    Triangle(base: float64, height: float64),
    Point
}

fn describe(s: Shape) -> void {
    match s {
        Shape.Circle(radius) -> { println("circle r=" + (radius as string)); }
        _ -> { println("something else"); }
    }
}

describe(Shape.Circle(1.0));
describe(Shape.Rectangle(2.0, 3.0));
describe(Shape.Triangle(4.0, 5.0));
describe(Shape.Point);

/* EXPECT
circle r=1.000000
something else
something else
something else
*/
