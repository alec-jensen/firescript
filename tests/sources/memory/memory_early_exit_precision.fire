import @firescript/std.io.println;

fn consume(s: string) -> void {
    println("consume:" + s);
}

fn demo(flag: bool) -> string {
    value: string = "x";

    if (flag) {
        consume(value); // moved on this path
        return "moved";
    }

    println("after:" + value); // should be valid: return-path move does not continue
    return value;
}

println(demo(true));
println(demo(false));

/* EXPECT
consume:x
moved
after:x
x
*/
