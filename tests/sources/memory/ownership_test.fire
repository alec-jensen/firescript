// Test basic ownership semantics

import @firescript/std.io.println;

// Test 1: Basic class as Owned type
class Point {
    x: int32;
    y: int32;
}

// Create an owned value using field-based constructor
p1: Point = Point(10i32, 20i32);

// Move ownership
p2: Point = p1;  // p1 is now invalid

// This should work (p2 is valid)
println(p2.x);

// Test 2: Copyable types
a: int32 = 5i32;
b: int32 = a;  // Copy, not move
println(a);  // Should work - a is still valid
println(b);

/* EXPECT
10
5
5
*/
