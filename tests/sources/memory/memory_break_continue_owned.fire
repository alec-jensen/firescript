// Test that owned variables are correctly dropped on break and continue
// inside loops, without leaking or double-freeing.

import @firescript/std.io.println;

i: int32 = 0;
while (i < 5) {
    msg: string = "iter";
    if (i == 2) {
        i = i + 1;
        continue;
    }
    if (i == 4) {
        break;
    }
    println(i);
    i = i + 1;
}
println(i);

/* EXPECT
0
1
3
4
*/
