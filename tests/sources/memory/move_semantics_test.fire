//@ snapshot: fir, flir
import @firescript/std.io.println;

fn take_ownership(s: string) -> void {
    println(s);
}

fn borrow_only(s: &string) -> void {
    println(s);
}

// Test 1: Move to function expecting ownership
s1: string = "hello";
take_ownership(s1);

// Test 2: Borrow to function expecting borrow
s2: string = "world";
borrow_only(s2);
println(s2);  // OK - still valid

// Test 3: Move via assignment
s3: string = "test";
s4: string = s3;
println(s4);  // OK - s4 owns the value now

/* EXPECT
hello
world
world
test
*/
