//@ snapshot: fir, flir
// Test that classes with owned fields (strings) generate correct destructors
// and don't leak or double-free their fields.

import @firescript/std.io.println;

class Person {
    name: string;
    age: int32;
    fn Person(&mut this, name: string, age: int32) {
        this.name = name;
        this.age = age;
    }
    fn greet(&this) -> string {
        return "Hello, " + this.name;
    }
}

p: Person = new Person("Alice", 30);
println(p.name);
println(p.age);
println(p.greet());

/* EXPECT
Alice
30
Hello, Alice
*/
