// Regression test: owned objects moved into a constructor must not be freed
// by the caller afterward (double-free / use-after-free prevention).

import @firescript/std.io.println;

class Point {
    x: int32;
    y: int32;
    fn Point(&mut this, x: int32, y: int32) {
        this.x = x;
        this.y = y;
    }
}

class Rect {
    topLeft: Point;
    bottomRight: Point;
    fn Rect(&mut this, tl: Point, br: Point) {
        this.topLeft = tl;
        this.bottomRight = br;
    }
    fn width(&this) -> int32 {
        return this.bottomRight.x - this.topLeft.x;
    }
    fn height(&this) -> int32 {
        return this.bottomRight.y - this.topLeft.y;
    }
}

p1: Point = new Point(1, 2);
p2: Point = new Point(7, 8);
r: Rect = new Rect(p1, p2);
println(r.topLeft.x);
println(r.topLeft.y);
println(r.bottomRight.x);
println(r.bottomRight.y);
println(r.width());
println(r.height());

/* EXPECT
1
2
7
8
6
6
*/
