//@ snapshot: fir, flir
import @firescript/std.io.println;

class Counter {
    count: int32;

    fn Counter(&mut this, start: int32) {
        this.count = start;
    }

    fn increment(&mut this) -> void {
        this.count = this.count + 1;
    }

    fn add(&mut this, n: int32) -> void {
        this.count = this.count + n;
    }

    fn value(&this) -> int32 {
        return this.count;
    }
}

class Pair {
    first: string;
    second: string;

    fn Pair(&mut this, a: string, b: string) {
        this.first = a;
        this.second = b;
    }

    fn swap(&mut this) -> void {
        tmp: string = this.first;
        this.first = this.second;
        this.second = tmp;
    }

    fn describe(&this) -> string {
        return this.first + "," + this.second;
    }
}

c: Counter = new Counter(0);
c.increment();
c.increment();
c.increment();
println(c.value());

c.add(10);
println(c.value());

p: Pair = new Pair("hello", "world");
println(p.describe());
p.swap();
println(p.describe());

/* EXPECT
3
13
hello,world
world,hello
*/
