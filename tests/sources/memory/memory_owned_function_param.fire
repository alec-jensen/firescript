// Explicit 'owned' keyword on a plain (non-receiver) function parameter.
import @firescript/std.io.println;

class Box {
    v: int32;

    fn Box(v: int32) {
        this.v = v;
    }
}

fn consume(b: owned Box) -> void {
    println(b.v);
}

fn main() -> void {
    b: Box = Box(42i32);
    consume(b);
}

/* EXPECT
42
*/
