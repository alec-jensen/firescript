//@ snapshot: fir, flir
import @firescript/std.io.println;

enum Status {
    Ok,
    Failed(code: int32),
}

// Note: functions returning arrays (e.g. `int32[] f() { ... }`) are not
// exercised here -- returning a fixed-size array literal from a function
// declared with an unsized array return type (`int32[]`) currently trips
// an internal compiler error (FIRV-T4: 'int32[3]' vs declared 'int32[]')
// in the FIR verifier instead of a clean diagnostic or a successful
// compile. This looks like a real gap (array-returning functions appear
// untested elsewhere in the suite too) but is out of scope here -- avoided
// below by not returning arrays from functions.

fn makeString() -> string {
    return "abc";
}

fn makeStatus() -> Status {
    return Status.Failed(42);
}

// for-in over an array literal directly: a non-identifier collection,
// exercising the temporary-array ownership drop path in
// ast_to_fir.py::_convert_for_in_array (the array literal is always
// "owned" per ArrayType.category, so the exit-block drop always applies).
for (y: int32 in [1, 2, 3]) {
    println(y);
}

// for-in over a non-identifier string expression (function-call result):
// exercises the temporary-string ownership drop path in
// _convert_for_in_string.
// Note: `char` cannot be used as a for-in loop-variable type here -- the
// parser's for-in header (parser/statements.py's is_for_in check) only
// recognizes types in TYPE_TOKEN_NAMES, which doesn't include "char" (char
// is only ever accepted as a type via the import-deferred-identifier path
// used for plain variable declarations, not for-in headers). This makes
// ast_to_fir.py's _convert_for_in_string() str_char_code_at branch (the
// loop_var_type_str != "string" case) unreachable via valid source.
for (c: string in makeString()) {
    println(c);
}

// match over a non-identifier scrutinee (function-call result): exercises
// the temporary-scrutinee ownership drop path in _convert_match.
result: int32 = match makeStatus() {
    Status.Ok -> 0,
    Status.Failed(code) -> code
};
println(result);

// Sized array declared with no initializer at all (zero-initialized):
// exercises the "else" branch of _convert_variable_declaration's
// array-init handling.
uninitialized: int32[4];
println(uninitialized[0]);

// Sized array initialized from a non-array-literal expression (a bare
// identifier naming another array): exercises the "elif init_node is not
// None" branch (present initializer that isn't an ARRAY_LITERAL node).
src: int32[3] = [1, 2, 3];
fromExpr: int32[3] = src;
println(fromExpr[2]);

/* EXPECT
1
2
3
a
b
c
42
0
3
*/
