//@ snapshot: fir, flir
import @firescript/std.io.println;

// While loop
count: int32 = 0;
while (count < 5) {
    println(count);
    count++;
}

// While loop with break
i: int32 = 0;
while (i < 10) {
    if (i == 5) {
        break;
    }
    println(i);
    i++;
}

// While loop with continue
j: int32 = 0;
while (j < 5) {
    j++;
    if (j == 3) {
        continue;
    }
    println(j);  // Should skip 3
}

// Nested while loops
outer: int32 = 0;
while (outer < 3) {
    inner: int32 = 0;
    while (inner < 2) {
        println(outer * 10 + inner);
        inner++;
    }
    outer++;
}

