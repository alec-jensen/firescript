import @firescript/std.io.println;

// While loop
int32 count = 0;
while (count < 5) {
    println(count);
    count++;
}

// While loop with break
int32 i = 0;
while (i < 10) {
    if (i == 5) {
        break;
    }
    println(i);
    i++;
}

// While loop with continue
int32 j = 0;
while (j < 5) {
    j++;
    if (j == 3) {
        continue;
    }
    println(j);  // Should skip 3
}

// Nested while loops
int32 outer = 0;
while (outer < 3) {
    int32 inner = 0;
    while (inner < 2) {
        println(outer * 10 + inner);
        inner++;
    }
    outer++;
}
