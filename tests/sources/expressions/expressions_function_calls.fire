import @firescript/std.io.println;

fn add(a: int32, b: int32) -> int32 {
    return a + b;
}

fn multiply(a: int32, b: int32) -> int32 {
    return a * b;
}

println(add(5, 3));
println(multiply(4, 7));
println(add(multiply(2, 3), 4));  // 2*3 + 4 = 10
println(multiply(add(2, 3), 4));  // (2+3) * 4 = 20

// Nested calls to the same function
fn triple(n: int32) -> int32 {
    return n * 3;
}
println(triple(triple(2)));  // 18

/* EXPECT
8
28
10
20
18
*/
