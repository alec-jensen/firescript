// Comprehensive logical operator tests (&&, ||, !)

import @firescript/std.io.println;

println("=== Logical Operators ===");

// Boolean basics
println("--- Boolean Basics ---");
bool t = true;
bool f = false;

println(t);  // true
println(f);  // false
println(t == true);  // true
println(f == false);  // true
println(t == f);  // false

// Conditional logic using logical operators
println("--- Logical Conditions ---");
int32 a = 10;
int32 b = 5;
int32 c = 15;

if (a > b && a < c) {
    println("a is between b and c");
}

if (a < b || a > 0) {
    println("a meets at least one condition");
}

if (!(a < b || !t)) {
    println("not/or combination works");
}

if (t && !f) {
    println("and/not combination works");
}

println("=== All logical operator tests passed ===");
