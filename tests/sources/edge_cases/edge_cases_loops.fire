import @firescript/std.io.println;

// Zero-iteration loops
no_iterations: int32 = 0;
while (no_iterations > 0) {
    println("Should not print");
    no_iterations--;
}

for (i: int32 = 0; i < 0; i++) {
    println("Should not print");
}

empty_for_in: int32[] = [];
for (x: int32 in empty_for_in) {
    println("Should not print");
}

// Single-iteration loops
once: int32 = 1;
while (once > 0) {
    println("Once");
    once--;
}

for (j: int32 = 0; j < 1; j++) {
    println("One iteration");
}

/* EXPECT
Once
One iteration
*/
