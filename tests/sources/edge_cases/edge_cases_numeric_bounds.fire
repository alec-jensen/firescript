import @firescript/std.io.println;

// Minimum and maximum values
i8_min: int8 = -128i8;
i8_max: int8 = 127i8;
println(i8_min);
println(i8_max);

i32_min: int32 = -2147483648;
i32_max: int32 = 2147483647;
println(i32_min);
println(i32_max);

u8_max: uint8 = 255u8;
println(u8_max);

// Very large numbers
large: int64 = 9223372036854775807i64;
println(large);

ularge: uint64 = 18446744073709551615u64;
println(ularge);

// Very small float values
small_f32: float32 = 0.0001f;
small_f64: float64 = 0.0000001;
println(small_f32);
println(small_f64);

/* EXPECT
-128
127
-2147483648
2147483647
255
9223372036854775807
18446744073709551615
0.000100
0.000000
*/
