import @firescript/std.io.{print, println};
import @firescript/std.fs.{File, FileResult};

// Solution for a coding challenge, being used as a test

file: File = File("tests/sources/integration/hackathon8_mission2.txt");

r: FileResult = file.read();

fn contains(n: int16, a: &int16[]) -> bool {
    for (e: int16 in a) {
        if (e == n) {
            return true;
        }
    }

    return false;
}

if (r.ok()) {
    sign: bool = false; // true: +, false: -

    not_first: bool = false;

    number: string = "";
    input_data: string = r.result_data();

    nums: int16[1000] = [];
    idx: int8 = 0i8;
    frequencies: int16[1000] = [];

    for (ch: string in input_data) {
        if (ch == "+" || ch == "-") {
            if (not_first) {
                // convert number to int, add/subtract based on sign
                n: int16 = (number as int16);

                if (contains(n, nums)) {
                    n_idx: int16 = 0i16;

                    for (n1: int16 in nums) {
                        if (n1 == n) {
                            break;
                        }

                        n_idx++;
                    }

                    frequencies[n_idx] = frequencies[n_idx] + 1i16;
                } else {
                    idx++;
                    nums[idx] = n;
                }

                number = "";
            }

            // read sign
            if (ch == "+") { sign = true; }
            else if (ch == "-") { sign = false; }
            else {
                println("shits broke, cant read sign");
                break;
            }

            not_first = true;
        } else {
            if (ch == "\n" || ch == "\r") {
                continue;
            }

            // read number
            number = number + ch;
        }
    }

    max_n: int16 = -1i16;
    max_f: int16 = -1i16;

    for (i: uint8=0u8; i<(idx as uint8) + 1u8;i++) {
        if (frequencies[i] > max_f) {
            max_n = nums[i];
            max_f = frequencies[i];
        }
    }

    println(max_n);
} else {
    print("error: ");
    println(r.err_code());
}

/* EXPECT
17
*/
