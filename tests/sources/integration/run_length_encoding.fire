//@ arg: 
// Solution for a coding challenge, being used as a test -- given 1000
// digits of pi (an irrationally large input) as the text to encode.
// Also a regression case for a for-in-string loop variable conditionally
// moved into an outer variable across a chain of if/else-if branches (see
// strings_for_in_regression_conditional_move*.fire for the isolated
// compiler-bug cases this pattern originally triggered).
import @firescript/std.cli.args.{argc, argv_at};
import @firescript/std.io.{println};

if (argc() < 2) {
    println("Must provide text to encode");
} else {
    inp: string = argv_at(1);
    num: int32 = 0;
    result: string = "";
    last_chr: string = "";
    first: bool = true;

    for (chr: string in inp) {
        if (first == true) {
            last_chr = chr;
            num++;
        }
        else if (chr == last_chr) {
            num++;
        } else if (first != true) {
            result = result + last_chr + (num as string);
            last_chr = chr;
            num = 1;
        }

        first = false;
    }

    result = result + last_chr + (num as string);

    println(result);
}

