import @firescript/std.io.{print, println};
import @firescript/std.fs.{File, FileResult};

// Solution for a coding challenge, being used as a test

file: File = File("tests/sources/integration/hackathon8_mission1.txt");

r: FileResult = file.read();

if (r.ok()) {
    sign: bool = false; // true: +, false: -

    not_first: bool = false;

    number: string = "";
    input_data: string = r.result_data();

    total: int32 = 0i32;

    for (ch: string in input_data) {
        if (ch == "+" || ch == "-") {
            if (not_first) {
                // convert number to int, add/subtract based on sign
                n: int32 = (number as int32);

                if (sign) {
                    total = total + n;
                } else {
                    total = total - n;
                }

                number = "";
            }

            // read sign
            if (ch == "+") { sign = true; }
            else if (ch == "-") { sign = false; }
            else {
                println("shits broke, cant read sign");
                break;
            }

            not_first = true;
        } else {
            if (ch == "\n" || ch == "\r") {
                continue;
            }

            // read number
            number = number + ch;
        }
    }

    n: int32 = (number as int32);

    if (sign) {
        total = total + n;
    } else {
        total = total - n;
    }

    println(total);
} else {
    print("error: ");
    println(r.err_code());
}

/* EXPECT
576
*/
