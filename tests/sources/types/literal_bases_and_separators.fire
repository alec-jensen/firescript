// Integer literal bases (hex, binary, octal) and underscore separators.
import @firescript/std.io.println;

hex: int32 = 0xFF;
bin: int32 = 0b1010;
oct: int32 = 0o755;
sep: int32 = 1_000_000;
bigHex: int64 = 0xDEAD_BEEFi64;
hexSuffixed: uint8 = 0x2Au8;

println(hex);
println(bin);
println(oct);
println(sep);
println(bigHex);
println(hexSuffixed);

/* EXPECT
255
10
493
1000000
3735928559
42
*/
