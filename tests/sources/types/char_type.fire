import @firescript/std.io.println;

// Basic char literal
a: char = 'A';
println(a as string);

// Escape char literals
tab: char = '\t';
newline: char = '\n';
backslash: char = '\\';
println("t:" + tab as string + "|");
println("n:" + newline as string + "|");
println("bs:" + backslash as string + "|");

// Char is copyable
b: char = a;
println(b as string);

// Digit char
zero: char = '0';
nine: char = '9';
println(zero as string);
println(nine as string);

// Unrecognized escape sequence: the lexer's CHAR_LITERAL regex accepts any
// `\<char>` pair, but only \n \t \r \0 \\ \' \" are known escapes
// (firescript/flir/lowering.py's _CHAR_ESCAPES). Anything else falls back
// to the escaped character's own code point (_char_code's fallback path).
unknownEscape: char = '\d';
println(unknownEscape as string);

return 0;

/* EXPECT
A
t:	|
n:
|
bs:\|
A
0
9
d
*/
