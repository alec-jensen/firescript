// Integer arithmetic

import @firescript/std.io.println;

println("Integer arithmetic");
i1: int32 = 5;
i2: int32 = 10;
sum: int32 = i1 + i2;
diff: int32 = i2 - i1;
prod: int32 = i1 * i2;
quot: int32 = i2 / i1;
rem: int32 = i2 % 3;
println(sum);     // 15
println(diff);    // 5
println(prod);    // 50
println(quot);    // 2
println(rem);     // 1

// Floating point (float32)
println("Floating point arithmetic");
f1: float32 = 5.5f;
f2: float32 = 10.0f;
fsum: float32 = f1 + f2;
println(fsum);   // 15.5

// Double precision (float64)
println("Double precision arithmetic");
d1: float64 = 5.5;
d2: float64 = 10.0;
dsum: float64 = d1 + d2;
println(dsum);   // 15.5

// Booleans and comparisons
println("Boolean and comparisons");
t: bool = true;
f: bool = false;
println(t);       // true
println(f);       // false
println(i1 < i2); // true (int32 relational)
println(i1 == 5); // true
println(d1 > d2); // false (float64 relational)

// Strings and concatenation
println("String concatenation");
hello: string = "Hello, ";
world: string = "world!";
greeting: string = hello + world;
println(greeting); // Hello, world!

// Arrays of ints (fixed-size)
println("Array of integers");
a: int32[] = [1, 2, 3, 4];
println(a.length());   // 4
println(a[0]);         // 1
println(a[2]);         // 3

// Array of strings
println("Array of strings");
words: string[] = ["fire", "script", "rocks"];
println(words.length());   // 3
println(words[1]);         // script

/* EXPECT
Integer arithmetic
15
5
50
2
1
Floating point arithmetic
15.500000
Double precision arithmetic
15.500000
Boolean and comparisons
true
false
true
true
false
String concatenation
Hello, world!
Array of integers
