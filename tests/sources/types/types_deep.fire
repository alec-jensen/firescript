// Comprehensive type coverage and operations

import @firescript/std.io.println;

println("-- INTS: widths and ops --");
i8a: int8 = 120i8; 
i8b: int8 = 0i8 - 5i8; 
println(i8a); println(i8b); println(i8a + i8b); println(i8a - i8b);
i16a: int16 = 30000i16; 
i16b: int16 = 0i16 - 123i16; 
println(i16a); println(i16b); println(i16a + i16b); println(i16a - i16b);
i32a: int32 = 2000000000i32; 
i32b: int32 = 0i32 - 100i32; 
println(i32a); println(i32b); println(i32a + i32b); println(i32a - i32b);
i64a: int64 = 9000000000000000000i64; 
i64b: int64 = 0i64 - 7i64; 
println(i64a); println(i64b); println(i64a + i64b); println(i64a - i64b);

println("-- UINTS: widths and ops --");
u8a: uint8 = 250u8; u8b: uint8 = 5u8; println(u8a); println(u8b); println(u8a + u8b); println(u8a - u8b);
u16a: uint16 = 65000u16; u16b: uint16 = 400u16; println(u16a); println(u16b); println(u16a + u16b); println(u16a - u16b);
u32a: uint32 = 4000000000u32; u32b: uint32 = 10u32; println(u32a); println(u32b); println(u32a + u32b); println(u32a - u32b);
u64a: uint64 = 18446744073709551610u64; u64b: uint64 = 2u64; println(u64a); println(u64b); println(u64a + u64b); println(u64a - u64b);

println("-- FLOATS: 32/64/128 --");
f32a: float32 = 1.5f32; f32b: float32 = 2.25f32; println(f32a); println(f32b); println(f32a + f32b); println(f32a - f32b); println(f32a * f32b); println(f32a / f32b);
f64a: float64 = 3.5; f64b: float64 = 1.25; println(f64a); println(f64b); println(f64a + f64b); println(f64a - f64b); println(f64a * f64b); println(f64a / f64b);
f128a: float128 = 1.2345678901234567f128; f128b: float128 = 0.3333333333333333f128; println(f128a); println(f128b); println(f128a + f128b); println(f128a - f128b); println(f128a * f128b); println(f128a / f128b);

println("-- BOOLS & STRINGS --");
t: bool = true; f: bool = false; println(t); println(f); println(t == t); println(t == f); println(f == f);
s1: string = "fi"; s2: string = "rescript"; s3: string = s1 + s2; println(s1); println(s2); println(s3);

println("-- ARRAYS: fixed-size --");
ai: int32[] = [1,2,3]; println(ai.length()); println(ai[0]); println(ai[1]); println(ai[2]);
as: string[] = ["a","b","c"]; println(as.length()); println(as[2]);

println("-- REL/COMP: same-type only --");
println( (1 + 2) == 3 ); println( (1 + 2) > 1 ); println( (1 + 2) < 5 );
println( (3.0) == (3.0) ); println( (3.5) > (3.25) ); println( (3.5) < (3.75) );

println("-- MODULO: integers only --");
println( 10i32 % 3i32 ); println( 7u32 % 4u32 );

