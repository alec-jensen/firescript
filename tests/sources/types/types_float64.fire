import @firescript/std.io.println;

float64 f64_pi = 3.141592653589793;
float64 f64_e = 2.718281828459045;
float64 f64_large = 1e100;
float64 f64_small = 1e-100;
println(f64_pi);
println(f64_e);
println(f64_large);
println(f64_small);
println(f64_pi * f64_e);

