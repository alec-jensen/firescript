import @firescript/std.io.println;

f32_pi: float32 = 3.14159f;
f32_e: float32 = 2.71828f;
f32_zero: float32 = 0.0f;
f32_negative: float32 = -42.5f;
println(f32_pi);
println(f32_e);
println(f32_zero);
println(f32_negative);
println(f32_pi * 2.0f);
println(f32_e + f32_pi);

/* EXPECT
3.141590
2.718280
0.000000
-42.500000
6.283180
5.859870
*/
