// Comprehensive comparison operator tests

import @firescript/std.io.println;

println("=== Comparison Operators ===");

// Equality
println("--- Equality (==) ---");
a: int32 = 10;
b: int32 = 10;
c: int32 = 5;
println(a == b);  // true
println(a == c);  // false

s1: string = "hello";
s2: string = "hello";
s3: string = "world";
println(s1 == s2);  // true
println(s1 == s3);  // false

t1: bool = true;
t2: bool = true;
f1: bool = false;
println(t1 == t2);  // true
println(t1 == f1);  // false

// Inequality
println("--- Inequality (!=) ---");
println(a != b);  // false
println(a != c);  // true

// Less than
println("--- Less Than (<) ---");
println(c < a);  // true
println(a < c);  // false
println(a < b);  // false

fc1: float32 = 3.5f;
f2: float32 = 7.2f;
println(fc1 < f2);  // true
println(f2 < fc1);  // false

// Greater than
println("--- Greater Than (>) ---");
println(a > c);  // true
println(c > a);  // false
println(a > b);  // false

println(f2 > fc1);  // true
println(fc1 > f2);  // false

// Less than or equal
println("--- Less Than or Equal (<=) ---");
println(c <= a);  // true
println(a <= c);  // false
println(a <= b);  // true

println(fc1 <= f2);  // true
println(fc1 <= fc1);  // true
println(f2 <= fc1);  // false

// Greater than or equal
println("--- Greater Than or Equal (>=) ---");
println(a >= c);  // true
println(c >= a);  // false
println(a >= b);  // true

println(f2 >= fc1);  // true
println(f2 >= f2);  // true
println(fc1 >= f2);  // false

// Comparisons with different numeric types
println("--- Different Numeric Types ---");
i8a: int8 = 10i8;
i8b: int8 = 5i8;
println(i8a > i8b);  // true
println(i8a == 10i8);  // true

i64a: int64 = 100i64;
i64b: int64 = 50i64;
println(i64a > i64b);  // true
println(i64a <= 100i64);  // true

u32a: uint32 = 50u32;
u32b: uint32 = 30u32;
println(u32a > u32b);  // true
println(u32a != u32b);  // true

d1: float64 = 3.14;
d2: float64 = 2.71;
println(d1 > d2);  // true
println(d1 >= 3.14);  // true

// Chained comparisons in conditionals
println("--- Comparisons in Conditionals ---");
if (a > c) {
    println("a is greater than c");  // This should print
}

if (a == b) {
    println("a equals b");  // This should print
}

if (fc1 < f2) {
    println("fc1 is less than f2");  // This should print
}

println("=== All comparison operator tests passed ===");

