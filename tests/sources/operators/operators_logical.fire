//@ snapshot: fir, flir
// Comprehensive logical operator tests (&&, ||, !)

import @firescript/std.io.println;

println("=== Logical Operators ===");

// Boolean basics
println("--- Boolean Basics ---");
t: bool = true;
f: bool = false;

println(t);  // true
println(f);  // false
println(t == true);  // true
println(f == false);  // true
println(t == f);  // false

// Conditional logic using logical operators
println("--- Logical Conditions ---");
a: int32 = 10;
b: int32 = 5;
c: int32 = 15;

if (a > b && a < c) {
    println("a is between b and c");
}

if (a < b || a > 0) {
    println("a meets at least one condition");
}

if (!(a < b || !t)) {
    println("not/or combination works");
}

if (t && !f) {
    println("and/not combination works");
}

println("=== All logical operator tests passed ===");

/* EXPECT
=== Logical Operators ===
--- Boolean Basics ---
true
false
true
true
false
--- Logical Conditions ---
a is between b and c
a meets at least one condition
not/or combination works
and/not combination works
=== All logical operator tests passed ===
*/
