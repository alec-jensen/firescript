import @firescript/std.io.println;

// Basic boolean literals
t: bool = true;
f: bool = false;

// NOT
println(!t);
println(!f);

// AND
println(t && t);
println(t && f);
println(f && t);
println(f && f);

// OR
println(t || t);
println(t || f);
println(f || t);
println(f || f);

// Compound expressions
println(t && t || f);
println(f || f && t);
println(!(t && f));
println(!(t || f));

// Boolean from comparisons
a: int32 = 5;
b: int32 = 10;
gt: bool = a > b;
lt: bool = a < b;
println(gt);
println(lt);
println(gt && lt);
println(gt || lt);

// Negation of comparison result
println(!gt);
println(!lt);

// Chained conditions
x: int32 = 3;
inRange: bool = x > 0 && x < 10;
outRange: bool = x < 0 || x > 10;
println(inRange);
println(outRange);

// bool variable reassignment
flag: bool = false;
flag = true;
println(flag);
flag = !flag;
println(flag);

