// Comprehensive arithmetic operator tests

import @firescript/std.io.println;

println("=== Arithmetic Operators ===");

// Addition
println("--- Addition ---");
a: int32 = 10;
b: int32 = 5;
println(a + b);  // 15

f1: float32 = 3.5f;
f2: float32 = 2.5f;
println(f1 + f2);  // 6.0

// Subtraction
println("--- Subtraction ---");
println(a - b);  // 5
println(f1 - f2);  // 1.0

// Multiplication
println("--- Multiplication ---");
println(a * b);  // 50
println(f1 * f2);  // 8.75

// Division
println("--- Division ---");
println(a / b);  // 2
println(f1 / f2);  // 1.4

// Modulo
println("--- Modulo ---");
println(a % b);  // 0
c: int32 = 13;
d: int32 = 5;
println(c % d);  // 3

// Power
println("--- Power ---");
base: int32 = 2;
exp: int32 = 3;
println(base ** exp);  // 8

// Power with float operands (routes through fs_rt_pow_f64, not fs_rt_pow_i64)
fbase: float64 = 2.0;
fexp: float64 = 3.0;
println(fbase ** fexp);  // 8.0

// Unary operators
println("--- Unary Operations ---");
pos: int32 = 42;
neg: int32 = -pos;
println(neg);  // -42
println(-neg);  // 42

// Compound assignment
println("--- Compound Assignment ---");
x: int32 = 10;
x += 5;
println(x);  // 15
x -= 3;
println(x);  // 12
x *= 2;
println(x);  // 24
x /= 4;
println(x);  // 6
x %= 4;
println(x);  // 2

// Increment/Decrement
println("--- Increment/Decrement ---");
counter: int32 = 0;
counter++;
println(counter);  // 1
counter++;
println(counter);  // 2
counter--;
println(counter);  // 1

// Various numeric types
println("--- Different Numeric Types ---");
i8: int8 = 10i8;
i16: int16 = 20i16;
i64: int64 = 30i64;
println(i8 + 5i8);  // 15
println(i16 + 10i16);  // 30
println(i64 + 20i64);  // 50

u8: uint8 = 10u8;
u16: uint16 = 20u16;
u32: uint32 = 30u32;
u64: uint64 = 40u64;
println(u8 + 5u8);  // 15
println(u16 + 10u16);  // 30
println(u32 + 20u32);  // 50
println(u64 + 30u64);  // 70

d1: float64 = 5.5;
d2: float64 = 2.5;
println(d1 + d2);  // 8.0
println(d1 * d2);  // 13.75

println("=== All arithmetic operator tests passed ===");

