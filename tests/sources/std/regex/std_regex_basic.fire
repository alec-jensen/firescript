import @firescript/std.io.println;
import @firescript/std.regex.is_match;
import @firescript/std.regex.last_error;

println(is_match("abc", "abc"));
println(is_match("abc", "ab"));
println(is_match("a.c", "abc"));
println(is_match("ab|cd", "cd"));
println(is_match("ab|cd", "ab"));
println(is_match("ab|cd", "ad"));
println(is_match("a*", ""));
println(is_match("a*", "aaaa"));
println(is_match("a+", ""));
println(is_match("a+", "aaa"));
println(is_match("ab?c", "ac"));
println(is_match("ab?c", "abc"));
println(is_match("ab?c", "abbc"));
println(is_match("(ab)+c", "ababc"));
println(is_match("(ab)+c", "abc"));
println(is_match("(ab)+c", "ac"));
println(is_match("[abc]", "b"));
println(is_match("[abc]", "d"));
println(is_match("[a-z]", "m"));
println(is_match("[a-z]", "M"));
println(is_match("[^a-z]", "M"));
println(is_match("[^a-z]", "m"));
println(is_match("[a-c]+", "abccba"));
println(is_match("[a-c]+", "abdc"));
println(last_error("[ab"));
println(last_error("(ab"));
println(last_error("a\\"));
