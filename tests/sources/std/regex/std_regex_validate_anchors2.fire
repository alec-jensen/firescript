import @firescript/std.io.println;
import @firescript/std.regex.last_error;

// Check validation of patterns with anchors
e1: string = last_error("^abc");
println("Error 1:");
println(e1);

e2: string = last_error("abc$");
println("Error 2:");
println(e2);

e3: string = last_error("^abc$");
println("Error 3:");
println(e3);

e4: string = last_error("abc");
println("Error 4:");
println(e4);

/* EXPECT
Error 1:

Error 2:

Error 3:

Error 4:
*/
