import @firescript/std.io.println;
import @firescript/std.regex.find_at;

// Test find_at basic matching
println(find_at("abc", "abc", 0));        // 3: full match at position 0
println(find_at("ab", "abc", 0));         // 2: partial match at position 0
println(find_at("ab", "xab", 1));         // 2: match at position 1
println(find_at("ab", "xab", 0));         // -1: no match at position 0
println(find_at("a", "xaxbx", 1));        // 1: match at position 1
println(find_at("a", "xaxbx", 2));        // -1: no match at position 2

/* EXPECT
3
2
2
-1
1
-1
*/
