//@ snapshot: fir, flir
import @firescript/std.io.println;
import @firescript/std.types.Tuple;

// Test basic usage of the Tuple type
t1: Tuple<int32, string> = Tuple<int32, string>(42, "hello");
println(t1.first);  // Should print: 42
println(t1.second); // Should print: hello

/* EXPECT
42
hello
*/
