import @firescript/std.fs.File;
import @firescript/std.fs.FileResult;
import @firescript/std.io.println;

a: string = "build/temp/std_fs_path_ops_a.txt";
fileA: File = File(a);
fileB: File = File("build/temp/std_fs_path_ops_b.txt");
fileC: File = File("build/temp/std_fs_path_ops_c.txt");

fileB.remove();
fileC.remove();

write_result: FileResult = fileA.writeAll("path ops");
println(write_result.result_status());
println(fileA.exists());
println(fileB.exists());
rename_result: FileResult = fileA.renameTo("build/temp/std_fs_path_ops_b.txt");
println(rename_result.result_status());
println(fileA.exists());
println(fileB.exists());
read_b: FileResult = fileB.read();
println(read_b.result_data());
move_result: FileResult = fileA.moveTo("build/temp/std_fs_path_ops_c.txt");
println(move_result.result_status());
println(fileB.exists());
println(fileC.exists());
read_c: FileResult = fileC.read();
println(read_c.result_data());
remove_result: FileResult = fileC.remove();
println(remove_result.result_status());
println(fileC.exists());
remove_again_result: FileResult = fileC.remove();
println(remove_again_result.result_status());

/* EXPECT
