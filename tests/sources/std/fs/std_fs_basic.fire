import @firescript/std.fs.File;
import @firescript/std.fs.FileResult;
import @firescript/std.io.println;

path: string = "build/temp/std_fs_basic.txt";
file: File = File(path);

write_result: FileResult = file.writeAll("alpha");
println(write_result.result_status());

append_result: FileResult = file.appendAll(" beta");
println(append_result.result_status());

read_result: FileResult = file.read();
println(read_result.result_status());
println(read_result.result_data());

read_five_result: FileResult = file.readBytes(5);
println(read_five_result.result_status());
println(read_five_result.result_data());

missing_file: File = File("build/temp/does_not_exist_std_fs_basic.txt");
missing_result: FileResult = missing_file.read();
println(missing_result.result_status());

/* EXPECT
5
5
10
alpha beta
5
alpha
-2
*/
