import @firescript/std.fs.File;
import @firescript/std.fs.FileResult;
import @firescript/std.io.println;

path: string = "build/temp/std_fs_helpers.txt";
missing: string = "build/temp/does_not_exist_std_fs_helpers.txt";
file: File = File(path);
missingFile: File = File(missing);

write_result: FileResult = file.writeAll("one");
println(write_result.result_status());
append_result: FileResult = file.appendAll(" two");
println(append_result.result_status());

if (file.exists()) {
    println("exists");
} else {
    println("missing");
}

if (missingFile.exists()) {
    println("exists");
} else {
    println("missing");
}

read_result: FileResult = file.read();
println(read_result.result_status());
println(read_result.result_data());
missing_result: FileResult = missingFile.read();
println(missing_result.err_code());

/* EXPECT
3
4
exists
missing
7
one two
2
*/
