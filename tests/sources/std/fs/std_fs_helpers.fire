import @firescript/std.fs.File;
import @firescript/std.fs.FileResult;
import @firescript/std.io.println;

string path = "build/temp/std_fs_helpers.txt";
string missing = "build/temp/does_not_exist_std_fs_helpers.txt";
File file = File(path);
File missingFile = File(missing);

FileResult write_result = file.writeAll("one");
println(write_result.result_status());
FileResult append_result = file.appendAll(" two");
println(append_result.result_status());

if (file.exists()) {
    println("exists");
} else {
    println("missing");
}

if (missingFile.exists()) {
    println("exists");
} else {
    println("missing");
}

FileResult read_result = file.read();
println(read_result.result_status());
println(read_result.result_data());
FileResult missing_result = missingFile.read();
println(missing_result.err_code());
