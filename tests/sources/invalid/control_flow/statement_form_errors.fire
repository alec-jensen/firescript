// Malformed statement forms.
int32 x = 1;

// break outside a loop still parses; missing semicolon after break
while (x < 2) {
    x++;
    break
}  //~ ERROR FS-PARSE-0010 @1

// Bare identifier is not a statement
x;  //~ ERROR FS-PARSE-0010 @1

// Field access alone is not a statement
class Holder {
    int32 v;

    Holder() {
        this.v = 3;
    }
}
Holder h = Holder();  //~ ERROR FS-SEM-0010 @12
h.v;  //~ ERROR FS-PARSE-0010 @4

// Missing expression after field assignment
h.v = ;  //~ ERROR FS-PARSE-0012 @7
//~^ ERROR FS-PARSE-0010 @8

// Missing expression after array element assignment
int32[] arr = [1, 2];
arr[0] = ;

// Dangling else with a braceless statement
else x++;  //~ ERROR FS-PARSE-0012 @1
