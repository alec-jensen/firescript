// Exercises the 'Type.ConstructorName(...)' call form, which resolves to
// the class's own constructor rather than a static method (a constructor is
// not static, so this both succeeds at resolving the constructor and
// mismatches the surrounding declared type).

class Widget {
    id: int32;

    fn Widget(id: int32) {
        this.id = id;
    }
}

fn type_method_call_constructor_form() -> void {
    bad: string = Widget.Widget(5);  //~ ERROR FS-SEM-0002 @5
}
