// Malformed class definitions.

// Missing class name
class {
    int32 v;
}

// Missing generic type parameter name
class G1<> {
    int32 v;
}

// Missing '>' to close class type parameters
class G2<T {
    int32 v;
}

// Missing base class name after 'from'
class D1 from {
    int32 v;
}

// Class inheriting from itself
class S1 from S1 {
    int32 v;

    S1() {
        this.v = 1;
    }
}

// Missing '{' to start class body
class N1
int32 topLevel = 1;

// Member that is not a type
class M1 {
    ! bogus;
    int32 v;

    M1() {
        this.v = 1;
    }
}

// Static constructor is rejected
class C1 {
    int32 v;

    static C1() {
        this.v = 1;
    }
}

// Receiver must be 'this' after '&'
class R1 {
    int32 v;

    R1() {
        this.v = 1;
    }

    int32 get(&other) {
        return 1;
    }
}

// 'owned' receiver must be 'this'
class R2 {
    int32 v;

    R2() {
        this.v = 1;
    }

    int32 take(owned other) {
        return 1;
    }
}

// Method parameter type invalid
class P1 {
    int32 v;

    P1() {
        this.v = 1;
    }

    int32 m(&this, ! x) {
        return 1;
    }
}

// Array parameters are not supported for methods
class P2 {
    int32 v;

    P2() {
        this.v = 1;
    }

    int32 m(&this, int32[] xs) {
        return 1;
    }
}

// Missing method parameter name
class P3 {
    int32 v;

    P3() {
        this.v = 1;
    }

    int32 m(&this, int32) {
        return 1;
    }
}
