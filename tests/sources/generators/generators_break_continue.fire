import @firescript/std.io.println;

generator<int32> countup(int32 n) {
    int32 i = 0;
    while (i < n) {
        yield i;
        i += 1;
    }
}

// break inside for-in-over-generator
for (int32 v in countup(10)) {
    if (v == 3) {
        break;
    }
    println(v);
}

println("---");

// continue inside for-in-over-generator
for (int32 v in countup(6)) {
    if (v % 2 == 0) {
        continue;
    }
    println(v);
}

println("---");

// nested for-in-over-generator loops
for (int32 outer in countup(2)) {
    for (int32 inner in countup(2)) {
        println(outer * 10 + inner);
    }
}

/* EXPECT
0
1
2
---
1
3
5
---
0
1
10
11
*/
