import @firescript/std.io.println;

fn countup(n: int32) -> generator<int32> {
    i: int32 = 0;
    while (i < n) {
        yield i;
        i += 1;
    }
}

// break inside for-in-over-generator
for (v: int32 in countup(10)) {
    if (v == 3) {
        break;
    }
    println(v);
}

println("---");

// continue inside for-in-over-generator
for (v: int32 in countup(6)) {
    if (v % 2 == 0) {
        continue;
    }
    println(v);
}

println("---");

// nested for-in-over-generator loops
for (outer: int32 in countup(2)) {
    for (inner: int32 in countup(2)) {
        println(outer * 10 + inner);
    }
}

/* EXPECT
0
1
2
---
1
3
5
---
0
1
10
11
*/
