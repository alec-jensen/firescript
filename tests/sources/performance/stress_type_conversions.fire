// Stress test: Type conversions and precision loss
// Likely to expose: conversion bugs, precision loss, truncation errors

import @firescript/std.io.println;

println("=== Type Conversion Tests ===");

// Test 1: Int to float and back
original: int32 = 100;
as_float: float64 = i32_to_f64(original);
back_to_int: int32 = f64_to_i32(as_float);

println(original);
println(as_float);
println(back_to_int); // Should match original

// Test 2: Float truncation
f1: float64 = 3.14159;
truncated1: int32 = f64_to_i32(f1);
println(f1);
println(truncated1); // Should be 3

// Test 3: Negative float truncation
f2: float64 = -2.71828;
truncated2: int32 = f64_to_i32(f2);
println(f2);
println(truncated2); // Should be -2

// Test 4: Small fractions
tiny: float64 = 0.001;
tiny_int: int32 = f64_to_i32(tiny);
println(tiny);
println(tiny_int); // Should be 0

// Test 5: Float near integer boundary
almost_one: float64 = 0.999;
almost_one_int: int32 = f64_to_i32(almost_one);
println(almost_one);
println(almost_one_int); // Should be 0

just_over_one: float64 = 1.001;
just_over_one_int: int32 = f64_to_i32(just_over_one);
println(just_over_one);
println(just_over_one_int); // Should be 1

// Test 6: Division precision
a: int32 = 10;
b: int32 = 3;

// Integer division (truncated)
int_result: int32 = a / b;
println(int_result); // Should be 3

// Float division (precise)
float_result: float64 = i32_to_f64(a) / i32_to_f64(b);
println(float_result); // Should be 3.333...

// Test 7: Large float to int
large_float: float64 = 1000000.0;
large_int: int32 = f64_to_i32(large_float);
println(large_float);
println(large_int);

// Test 8: Conversion chain
start: int32 = 42;
step1: float64 = i32_to_f64(start);
step2: int32 = f64_to_i32(step1);
step3: float64 = i32_to_f64(step2);

println(start);
println(step1);
println(step2);
println(step3); // Should all be 42/42.0

/* EXPECT
=== Type Conversion Tests ===
100
100.000000
100
3.141590
3
-2.718280
-2
0.001000
0
0.999000
0
1.001000
1
3
3.333333
1000000.000000
1000000
42
42.000000
42
42.000000
*/
