// Stress test: Integer overflow and underflow
// Likely to expose: overflow bugs, type conversion errors, arithmetic edge cases

import @firescript/std.io.println;

println("=== Integer Overflow Tests ===");

// Test 1: Large positive numbers
max_approach: int32 = 2147483647;
println(max_approach);

// Test 2: Large negative numbers  
min_approach: int32 = -2147483648;
println(min_approach);

// Test 3: Multiplication of large numbers
large1: int32 = 10000;
large2: int32 = 10000;
product: int32 = large1 * large2;
println(product); // May overflow

// Test 4: Addition near max
near_max: int32 = 2147483640;
added: int32 = near_max + 5;
println(added);

// Test 5: Subtraction near min
near_min: int32 = -2147483640;
subtracted: int32 = near_min - 5;
println(subtracted);

// Test 6: Division by powers of 2
val: int32 = 1024;
println(val / 2);
println(val / 4);
println(val / 8);
println(val / 16);

// Test 7: Negative division
println(-100 / 3);
println(-100 / -3);
println(100 / -3);

// Test 8: Modulo with negatives
println(10 % 3);
println(-10 % 3);
println(10 % -3);
println(-10 % -3);

// Test 9: Zero arithmetic
z: int32 = 0;
println(z + 100);
println(z - 100);
println(z * 100);
println(100 - z);

/* EXPECT
