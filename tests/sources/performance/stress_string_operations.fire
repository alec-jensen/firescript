// Stress test: String operations and memory
// Likely to expose: memory leaks, move semantics bugs, string handling errors

import @firescript/std.io.println;

println("=== String Operation Tests ===");

// Test 1: Empty string
empty: string = "";
println(empty);
println("after empty");

// Test 2: String concatenation
hello: string = "Hello";
world: string = "World";
combined: string = hello + world;
println(combined);

// Test 3: Multiple concatenations
a: string = "A";
b: string = "B";
c: string = "C";
abc: string = a + b + c;
println(abc);

// Test 4: String reassignment
var: string = "first";
println(var);
var = "second";
println(var);
var = "third";
println(var);

// Test 5: String in loop
i: int32 = 0;
while (i < 3) {
    loop_str: string = "iteration";
    println(loop_str);
    i = i + 1;
}

// Test 6: String from int conversion
num: int32 = 123;
num_str: string = i32_to_str(num);
println(num_str);

negative: int32 = -456;
neg_str: string = i32_to_str(negative);
println(neg_str);

// Test 7: Special characters
newline_test: string = "line1
line2";
println(newline_test);

tab_test: string = "col1	col2";
println(tab_test);

// Test 8: Long string
long_str: string = "This is a much longer string to test memory allocation and handling of larger text content";
println(long_str);

// Test 9: String comparison/equality (if supported)
s1: string = "test";
s2: string = "test";
// Note: equality might not be supported yet

// Test 10: String in arrays
str_arr: string[] = ["first", "second", "third"];
println(str_arr[0]);
println(str_arr[1]);
println(str_arr[2]);

/* EXPECT
