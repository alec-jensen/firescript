import @firescript/std.io.println;

i: int32 = toInt("42");
println(i);

f: float32 = toFloat("3.5");
println(f);

d: float64 = toDouble("2.25");
println(d);

b: bool = toBool("true");
println(b);

c: char = toChar("65");
println(c);

s: string = toString(123);
println(s);

/* EXPECT
42
3.500000
2.250000
true
6
123
*/
