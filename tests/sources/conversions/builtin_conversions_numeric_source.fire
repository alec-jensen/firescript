import @firescript/std.io.println;

// toInt/toFloat/toDouble/toBool/toChar called with a numeric (non-string)
// source argument -- builtin_conversions.fire only exercises the
// string-source paths of these conversion builtins.

fromFloat: int32 = toInt(9.75);
println(fromFloat);

fromInt: float32 = toFloat(7);
println(fromInt);

fromInt2: float64 = toDouble(7);
println(fromInt2);

fromZero: bool = toBool(0);
println(fromZero);

fromNonZero: bool = toBool(5);
println(fromNonZero);

fromInt3: char = toChar(66);
println(fromInt3);

/* EXPECT
9
7.000000
7.000000
false
true
B
*/
