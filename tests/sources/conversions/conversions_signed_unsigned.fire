import @firescript/std.io.println;

// Unsigned to signed
u8: uint8 = 200u8;
i8_from_u8: int8 = (u8 as int8);
println(u8);
println(i8_from_u8);  // May be negative due to overflow

u32: uint32 = 3000000000u32;
i32_from_u32: int32 = (u32 as int32);
println(u32);
println(i32_from_u32);

// Signed to unsigned
negative: int32 = -42;
u_from_negative: uint32 = (negative as uint32);
println(negative);
println(u_from_negative);

/* EXPECT
200
-56
3000000000
-1294967296
-42
4294967254
*/
