//@ snapshot: fir, flir
import @firescript/std.io.println;

println("-- numeric casts --");

i8: int8 = (127i16 as int8);
println(i8);

i16: int16 = ((0i32 - 12345i32) as int16);
println(i16);

i32: int32 = (123456i64 as int32);
println(i32);

i64: int64 = (123456789i64 as int64);
println(i64);

u8: uint8 = (255i16 as uint8);
println(u8);

u16: uint16 = (65000i32 as uint16);
println(u16);

u32: uint32 = (4000000000u64 as uint32);
println(u32);

u64: uint64 = (9000000000u64 as uint64);
println(u64);

f32: float32 = (3.25 as float32);
println(f32);

f64: float64 = (3.25 as float64);
println(f64);

f128: float128 = (3.25 as float128);
println(f128);

/* EXPECT
-- numeric casts --
127
-12345
123456
123456789
255
65000
4000000000
9000000000
3.250000
3.250000
3.250000
*/
