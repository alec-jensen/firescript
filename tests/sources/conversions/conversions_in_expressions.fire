import @firescript/std.io.println;

// Casts combined with arithmetic operations
a: int8 = 10i8;
b: int16 = 20i16;
result: int32 = (a as int32) + (b as int32);
println(result);

x: int32 = 5;
y: float32 = 2.0f;
div_result: float32 = (x as float32) / y;
println(div_result);

/* EXPECT
30
2.500000
*/
