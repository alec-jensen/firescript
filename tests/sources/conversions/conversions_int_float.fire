import @firescript/std.io.println;

// Integer to float
int_val: int32 = 100;
f32_from_int: float32 = (int_val as float32);
f64_from_int: float64 = (int_val as float64);
println(int_val);
println(f32_from_int);
println(f64_from_int);

// Float to integer (truncation)
f32_val: float32 = 42.75f;
int_from_f32: int32 = (f32_val as int32);
println(f32_val);
println(int_from_f32);  // Should be 42

f64_val: float64 = 99.99;
int_from_f64: int64 = (f64_val as int64);
println(f64_val);
println(int_from_f64);  // Should be 99

/* EXPECT
100
100.000000
100.000000
42.750000
42
99.990000
99
*/
