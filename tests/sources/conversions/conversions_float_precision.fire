import @firescript/std.io.println;

// Float32 to float64
f32: float32 = 3.14159f;
f64: float64 = (f32 as float64);
println(f32);
println(f64);

// Float64 to float32 (precision loss)
precise: float64 = 3.141592653589793;
less_precise: float32 = (precise as float32);
println(precise);
println(less_precise);

/* EXPECT
3.141590
3.141590
3.141593
3.141593
*/
