// Test casting all primitive types to string

directive enable_lowlevel_stdout;

// Test int8
i8_val: int8 = 127i8;
i8_str: string = i8_val as string;
stdout("int8 to string: ");
stdout(i8_str);
stdout("\n");

// Test int16
i16_val: int16 = 32767i16;
i16_str: string = i16_val as string;
stdout("int16 to string: ");
stdout(i16_str);
stdout("\n");

// Test int32
i32_val: int32 = 2147483647i32;
i32_str: string = i32_val as string;
stdout("int32 to string: ");
stdout(i32_str);
stdout("\n");

// Test int64
i64_val: int64 = 9223372036854775807i64;
i64_str: string = i64_val as string;
stdout("int64 to string: ");
stdout(i64_str);
stdout("\n");

// Test uint8
u8_val: uint8 = 255u8;
u8_str: string = u8_val as string;
stdout("uint8 to string: ");
stdout(u8_str);
stdout("\n");

// Test uint16
u16_val: uint16 = 65535u16;
u16_str: string = u16_val as string;
stdout("uint16 to string: ");
stdout(u16_str);
stdout("\n");

// Test uint32
u32_val: uint32 = 4294967295u32;
u32_str: string = u32_val as string;
stdout("uint32 to string: ");
stdout(u32_str);
stdout("\n");

// Test uint64
u64_val: uint64 = 18446744073709551615u64;
u64_str: string = u64_val as string;
stdout("uint64 to string: ");
stdout(u64_str);
stdout("\n");

// Test float32
f32_val: float32 = 3.14159f32;
f32_str: string = f32_val as string;
stdout("float32 to string: ");
stdout(f32_str);
stdout("\n");

// Test float64
f64_val: float64 = 2.718281828f64;
f64_str: string = f64_val as string;
stdout("float64 to string: ");
stdout(f64_str);
stdout("\n");

// Test float128
f128_val: float128 = 1.23456789f128;
f128_str: string = f128_val as string;
stdout("float128 to string: ");
stdout(f128_str);
stdout("\n");

// Test bool true
b_true: bool = true;
b_true_str: string = b_true as string;
stdout("bool true to string: ");
stdout(b_true_str);
stdout("\n");

// Test bool false
b_false: bool = false;
b_false_str: string = b_false as string;
stdout("bool false to string: ");
stdout(b_false_str);
stdout("\n");

// Test string to string (should be identity)
str_val: string = "Hello, World!";
str_str: string = str_val as string;
stdout("string to string: ");
stdout(str_str);
stdout("\n");

// Test with negative values
negative: int32 = -42i32;
neg_str: string = negative as string;
stdout("negative int32 to string: ");
stdout(neg_str);
stdout("\n");

// Test zero
zero: int32 = 0i32;
zero_str: string = zero as string;
stdout("zero to string: ");
stdout(zero_str);
stdout("\n");

/* EXPECT
int8 to string: 127
int16 to string: 32767
int32 to string: 2147483647
int64 to string: 9223372036854775807
uint8 to string: 255
uint16 to string: 65535
uint32 to string: 4294967295
uint64 to string: 18446744073709551615
float32 to string: 3.141590
float64 to string: 2.718282
float128 to string: 1.234568
bool true to string: true
bool false to string: false
string to string: Hello, World!
negative int32 to string: -42
zero to string: 0
*/
