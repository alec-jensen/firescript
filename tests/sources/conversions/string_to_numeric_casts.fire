// Test casting string literals/values to numeric types.
// (string -> bool and string -> char are not supported casts.)

import @firescript/std.io.println;

println("-- string to numeric casts --");

i32: int32 = ("42" as int32);
println(i32);

i64: int64 = ("9223372036854775807" as int64);
println(i64);

u64: uint64 = ("18446744073709551615" as uint64);
println(u64);

f32: float32 = ("3.5" as float32);
println(f32);

f64: float64 = ("3.5" as float64);
println(f64);

/* EXPECT
-- string to numeric casts --
42
9223372036854775807
18446744073709551615
3.500000
3.500000
*/
