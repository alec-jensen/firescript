import @firescript/std.io.println;

// Integer to integer widening conversions
i8: int8 = 42i8;
i16: int16 = (i8 as int16);
i32: int32 = (i16 as int32);
i64: int64 = (i32 as int64);
println(i8);
println(i16);
println(i32);
println(i64);

// Chained conversions
start: int8 = 100i8;
end: int64 = (((start as int16) as int32) as int64);
println(start);
println(end);

/* EXPECT
42
42
42
42
100
100
*/
