import @firescript/std.io.println;

// No parameters
fn greet() -> void {
    println("Hello from function!");
}
greet();

// Return value, no parameters
fn getConstant() -> int32 {
    return 42;
}
println(getConstant());

// Single parameter
fn double(x: int32) -> int32 {
    return x * 2;
}
println(double(5));
println(double(10));

// Multiple parameters
fn add(a: int32, b: int32) -> int32 {
    return a + b;
}
println(add(3, 7));
println(add(100, 200));

fn multiply(x: int32, y: int32) -> int32 {
    return x * y;
}
println(multiply(4, 5));

/* EXPECT
Hello from function!
42
10
20
10
300
20
*/
