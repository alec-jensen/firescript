import @firescript/std.io.println;

// No parameters
void greet() {
    println("Hello from function!");
}
greet();

// Return value, no parameters
int32 getConstant() {
    return 42;
}
println(getConstant());

// Single parameter
int32 double(int32 x) {
    return x * 2;
}
println(double(5));
println(double(10));

// Multiple parameters
int32 add(int32 a, int32 b) {
    return a + b;
}
println(add(3, 7));
println(add(100, 200));

int32 multiply(int32 x, int32 y) {
    return x * y;
}
println(multiply(4, 5));

/* EXPECT
Hello from function!
42
10
20
10
300
20
*/
