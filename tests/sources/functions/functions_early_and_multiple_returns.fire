import @firescript/std.io.println;

// Early return
fn findPositive(x: int32) -> int32 {
    if (x > 0) {
        return x;
    }
    return 0;
}
println(findPositive(42));
println(findPositive(-5));

// Multiple return paths
fn classify(n: int32) -> string {
    if (n < 0) {
        return "negative";
    } else if (n == 0) {
        return "zero";
    } else {
        return "positive";
    }
}
println(classify(-3));
println(classify(0));
println(classify(5));

/* EXPECT
42
0
negative
zero
positive
*/
