import @firescript/std.io.println;

// Early return
int32 findPositive(int32 x) {
    if (x > 0) {
        return x;
    }
    return 0;
}
println(findPositive(42));
println(findPositive(-5));

// Multiple return paths
string classify(int32 n) {
    if (n < 0) {
        return "negative";
    } else if (n == 0) {
        return "zero";
    } else {
        return "positive";
    }
}
println(classify(-3));
println(classify(0));
println(classify(5));
