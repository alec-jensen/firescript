import @firescript/std.io.println;

fn getFirst(arr: int32[]) -> int32 {
    return arr[0];
}

nums: int32[] = [99, 88, 77];
println(getFirst(nums));

fn arraySum(values: int32[]) -> int32 {
    total: int32 = 0;
    for (v: int32 in values) {
        total = total + v;
    }
    return total;
}
to_sum: int32[] = [1, 2, 3, 4, 5];
println(arraySum(to_sum));  // 15

/* EXPECT
99
15
*/
