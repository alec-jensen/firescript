//@ snapshot: fir, flir
import @firescript/std.io.println;

fn add(a: int32, b: int32) -> int32 {
    return a + b;
}

fn double(x: int32) -> int32 {
    return x * 2;
}

fn addThenDouble(a: int32, b: int32) -> int32 {
    sum: int32 = add(a, b);
    return double(sum);
}
println(addThenDouble(2, 3));  // (2 + 3) * 2 = 10

// Function with more complex internal logic
fn complexCalc(a: int32, b: int32, c: int32) -> int32 {
    temp: int32 = a + b;
    temp = temp * c;
    if (temp > 100) {
        return temp / 2;
    }
    return temp;
}
println(complexCalc(10, 20, 5));  // (10 + 20) * 5 = 150, 150 > 100, so 75
println(complexCalc(2, 3, 4));    // (2 + 3) * 4 = 20

/* EXPECT
10
75
20
*/
