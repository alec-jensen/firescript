// Basic int addition function

import @firescript/std.io.println;

fn add(a: int32, b: int32) -> int32 {
    return a + b;
}

// float32 addition
fn addFloat(a: float32, b: float32) -> float32 {
    result: float32 = a + b; // both float32
    return result;
}

// float64 multiplication
fn mulDouble(a: float64, b: float64) -> float64 {
    prod: float64 = a * b;
    return prod;
}

// Sum first two elements of an int array parameter
fn sumFirstTwo(nums: int32[]) -> int32 {
    x: int32 = nums[0];
    y: int32 = nums[1];
    return x + y;
}


// Bool logic (returns bool)
fn bothTrue(x: bool, y: bool) -> bool {
    // Using relational + equality expressions indirectly via arithmetic
    // (x && y) style not implemented yet, so emulate with comparison on ints if needed
    // Here we just return one side equality to true twice to exercise bool params
    if (x == true) {
        if (y == true) {
            return true;
        }
    }
    return false;
}

// String concatenation inside function
fn greet(name: string) -> string {
    hello: string = "Hello, ";
    msg: string = hello + name; // string + string
    return msg;
}

// Simple helper returning int
fn buildAndSum(a: int32, b: int32) -> int32 {
    c: int32 = a + b;
    return c;
}

// Void function (returns nothing) exercising print builtin and multiple calls
fn logValues(a: int32, d: float64, s: string) -> void {
    println(a);
    println(d);
    println(s);
}

// Same-type numeric test returning float64 via float64 arithmetic
fn numericMix(a: float64, b: float64, c: float64) -> float64 {
    part1: float64 = a + b; // float64 + float64 -> float64
    part2: float64 = part1 + c; // float64 + float64 -> float64
    return part2;
}

// Character handling simulated via string single char (char type token not yet in types, using string)
fn firstChar(word: string) -> string {
    ch: string = word; // just return the string (no substring support yet)
    return ch;
}

// =============================================================
// Invocations / Outputs
// =============================================================

println("-- int add --");
println(add(2, 3)); // 5
println(add(10, 15)); // 25

println("-- float addFloat --");
println(addFloat(1.5f, 2.5f)); // 4.0

println("-- double mulDouble --");
println(mulDouble(2.0, 3.0)); // 6.0

println("-- array param --");
built: int32[] = [7, 8, 9];
println(sumFirstTwo(built)); // 15

println("-- bool bothTrue --");
println(bothTrue(true, true)); // true
println(bothTrue(true, false)); // false

println("-- string greet --");
println(greet("firescript")); // Hello, firescript

println("-- void logValues --");
logValues(42, 3.14, "value");

println("-- numericMix --");
println(numericMix(2.0, 3.0, 4.0));

println("-- firstChar --");
println(firstChar("Z"));

