// Import aliasing: 'as' on a symbol import and on a whole-module import.
// Note: qualified access through a module alias (e.g. `U.helper(...)`) is
// not implemented (docs/reference/imports.md marks qualified access as
// [PLANNED]), so `utils as U` is imported but only called through the
// unqualified `helper` import; the aliased *symbol* import (`p`) is called
// directly through its alias.
import @firescript/std.io.println;
import @firescript/std.io.println as p;
import utils as U;
import utils.helper;

fn main() -> void {
    p(helper(5));
}

/* EXPECT
105
*/
