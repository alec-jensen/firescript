// Import aliasing: 'as' on a symbol import and on a whole-module import.
// Note: aliased *symbol* imports only exercise the parser/import-resolution
// path here -- calling through the alias currently fails at FIR->FLIR
// lowering ("call to unknown function <alias>"); qualified access through a
// module alias (e.g. `U.helper(...)`) is separately not implemented
// (docs/reference/imports.md marks qualified access as [PLANNED]). So this
// test imports both aliased forms but calls through the original names.
import @firescript/std.io.println;
import @firescript/std.io.println as p;
import utils as U;
import utils.helper;

void main() {
    println(helper(5));
}

/* EXPECT
105
*/
