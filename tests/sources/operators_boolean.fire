import @firescript/std.io.println;

// Basic boolean literals
bool t = true;
bool f = false;

// NOT
println(!t);
println(!f);

// AND
println(t && t);
println(t && f);
println(f && t);
println(f && f);

// OR
println(t || t);
println(t || f);
println(f || t);
println(f || f);

// Compound expressions
println(t && t || f);
println(f || f && t);
println(!(t && f));
println(!(t || f));

// Boolean from comparisons
int32 a = 5;
int32 b = 10;
bool gt = a > b;
bool lt = a < b;
println(gt);
println(lt);
println(gt && lt);
println(gt || lt);

// Negation of comparison result
println(!gt);
println(!lt);

// Chained conditions
int32 x = 3;
bool inRange = x > 0 && x < 10;
bool outRange = x < 0 || x > 10;
println(inRange);
println(outRange);

// bool variable reassignment
bool flag = false;
flag = true;
println(flag);
flag = !flag;
println(flag);
