//@ snapshot: fir, flir
import @firescript/std.io.println;

// Nullable class fields
class Config {
    host: string;
    port: string?;

    fn Config(&mut this, host: string, port: string?) {
        this.host = host;
        this.port = port;
    }

    fn address(&this) -> string {
        if (this.port != null) {
            return this.host + ":" + this.port;
        }
        return this.host;
    }
}

c1: Config = new Config("localhost", "8080");
c2: Config = new Config("example.com", "1111");
println(c1.address());
println(c2.address());

// Nullable in conditional chains
a: string? = "first";
b: string? = null;
c: string? = "third";

count: int32 = 0;
if (a != null) { count = count + 1; }
if (b != null) { count = count + 1; }
if (c != null) { count = count + 1; }
println(count);

// Reassigning nullable
val: string? = null;
println(val == null);
val = "assigned";
println(val != null);

/* EXPECT
localhost:8080
example.com:1111
2
true
true
*/
