import @firescript/std.io.println;

newline: string = "Line1\nLine2";
println(newline);

tab: string = "Col1\tCol2\tCol3";
println(tab);

quote: string = "She said \"Hello\"";
println(quote);

backslash: string = "Path\\to\\file";
println(backslash);

/* EXPECT
Line1
Line2
Col1	Col2	Col3
She said "Hello"
Path\to\file
*/
