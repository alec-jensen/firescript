import @firescript/std.io.println;

// String declaration and initialization
string s1 = "Hello";
string s2 = "World";
string empty = "";
println(s1);
println(s2);
println(empty);

// Long strings
string long_str = "This is a very long string that contains many words and characters to test how the compiler and runtime handle longer string values.";
println(long_str);
