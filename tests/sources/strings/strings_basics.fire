import @firescript/std.io.println;

// String declaration and initialization
s1: string = "Hello";
s2: string = "World";
empty: string = "";
println(s1);
println(s2);
println(empty);

// Long strings
long_str: string = "This is a very long string that contains many words and characters to test how the compiler and runtime handle longer string values.";
println(long_str);

/* EXPECT
Hello
World

This is a very long string that contains many words and characters to test how the compiler and runtime handle longer string values.
*/
