//@ snapshot: fir, flir
import @firescript/std.io.println;

// Basic concatenation
s1: string = "Hello";
s2: string = "World";
greeting: string = s1 + ", " + s2 + "!";
println(greeting);

multi: string = "Line 1" + " " + "Line 2" + " " + "Line 3";
println(multi);

// Concatenation with a cast expression
count: int32 = 5;
result: string = "Count: " + (count as string);
println(result);

// Concatenation via variables
name: string = "Alice";
age_str: string = "30";
info: string = "Name: " + name + ", Age: " + age_str;
println(info);

// Repeated concatenation
build: string = "";
build = build + "a";
build = build + "b";
build = build + "c";
println(build);  // abc

/* EXPECT
Hello, World!
Line 1 Line 2 Line 3
Count: 5
Name: Alice, Age: 30
abc
*/
