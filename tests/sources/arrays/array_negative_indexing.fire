//@ snapshot: fir, flir
import @firescript/std.io.println;

fn last(values: int32[]) -> int32 {
    return values[-1i32];
}

nums: int32[] = [10i32, 20i32, 30i32, 40i32];

println(nums[-1i32]);
println(nums[-2i32]);

idx: int32 = -3i32;
println(nums[idx]);

nums[-1i32] = 99i32;
println(nums[3i32]);

println(last(nums));

/* EXPECT
40
30
20
99
99
*/
