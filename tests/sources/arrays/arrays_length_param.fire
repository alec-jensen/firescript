// Test .length() called on an array function parameter, whose size is
// not statically known at the call site (unlike a local declared from an
// array literal) -- exercises the array_length intrinsic call path.

import @firescript/std.io.println;

fn arrayLen(arr: &int32[]) -> int32 {
    return arr.length();
}

fn arraySize(arr: &int32[]) -> int32 {
    return arr.size();
}

nums: int32[] = [10, 20, 30, 40];
println(arrayLen(nums));
println(arraySize(nums));

return 0;

/* EXPECT
4
4
*/
