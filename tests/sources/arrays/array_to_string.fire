import @firescript/std.io.println;

nums: int32[3] = [1, 2, 3];
s1: string = nums as string;
println(s1);

fs: float64[2] = [1.5, 2.5];
s2: string = fs as string;
println(s2);

words: string[2] = ["hi", "there"];
s3: string = words as string;
println(s3);

empty: int32[0];
s4: string = empty as string;
println(s4);

/* EXPECT
[1, 2, 3]
[1.500000, 2.500000]
[hi, there]
[]
*/
