import @firescript/std.io.println;

i8_arr: int8[] = [1i8, 2i8, 3i8];
println(i8_arr[0]);
println(i8_arr.length());

i64_arr: int64[] = [100i64, 200i64, 300i64];
println(i64_arr[1]);

f32_arr: float32[] = [1.1f, 2.2f, 3.3f];
println(f32_arr[0]);
println(f32_arr[2]);

f64_arr: float64[] = [1.111, 2.222, 3.333];
println(f64_arr[1]);

str_arr: string[] = ["hello", "world", "firescript"];
println(str_arr[0]);
println(str_arr[2]);
println(str_arr.length());

bool_arr: bool[] = [true, false, true, true];
println(bool_arr[0]);
println(bool_arr[1]);
println(bool_arr.length());

