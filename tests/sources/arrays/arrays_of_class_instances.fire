import @firescript/std.io.println;

// Arrays whose element type is a user class. This forces lower_type_str
// (firescript/flir/lowering.py) to resolve a bare class name string (no
// generic args) via its `type_str in self.typedefs` branch, rather than
// going through lower_type's SimpleType path -- array element/index/store
// lowering always renders the element type to a string first.

class Box {
    value: int32;

    fn Box(value: int32) {
        this.value = value;
    }
}

boxes: Box[2] = [Box(1), Box(2)];
println(boxes[0].value);
println(boxes[1].value);

boxes[0] = Box(99);
println(boxes[0].value);

// Same lower_type_str path, but for a *copyable* class element type --
// hits the struct_type(...) (by-value) branch instead of ptr_to(...).
copyable class Vec2 {
    x: float32;
    y: float32;
}

points: Vec2[2] = [Vec2(1.0f32, 2.0f32), Vec2(3.0f32, 4.0f32)];
println(points[0].x);
println(points[1].y);

/* EXPECT
1
2
99
1.000000
4.000000
*/
