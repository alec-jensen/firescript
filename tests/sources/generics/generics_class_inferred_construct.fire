import @firescript/std.io.println;

copyable class Pair<T, U> {
    first: T;
    second: U;

    fn Pair(first: T, second: U) {
        this.first = first;
        this.second = second;
    }
}

// Construct without repeating explicit type args; inferred from the declared LHS type.
p: Pair<int32, string> = Pair(1, "x");
println(p.first);
println(p.second);

/* EXPECT
1
x
*/
