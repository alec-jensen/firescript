import @firescript/std.io.println;

copyable class Pair<T, U> {
    T first;
    U second;

    Pair(T first, U second) {
        this.first = first;
        this.second = second;
    }
}

// Construct without repeating explicit type args; inferred from the declared LHS type.
Pair<int32, string> p = Pair(1, "x");
println(p.first);
println(p.second);
