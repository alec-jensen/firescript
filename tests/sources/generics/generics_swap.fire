// Test generic function with multiple type parameters

import @firescript/std.io.println;

// Generic pair swap function
fn swap<T>(a: T, b: T) -> void {
    temp: T = a;
    a = b;
    b = temp;
    println(a);
    println(b);
}

// Test swapping int32 values
x: int32 = 5;
y: int32 = 10;
swap(x, y);  // Should print 10, 5

// Test swapping float64 values  
p: float64 = 1.5;
q: float64 = 2.5;
swap(p, q);  // Should print 2.5, 1.5

/* EXPECT
10
5
2.500000
1.500000
*/
