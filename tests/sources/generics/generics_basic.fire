//@ snapshot: fir, flir
// Test basic generic functions with type inference and explicit type arguments

import @firescript/std.io.println;

// Generic max function with type union constraint
fn max<T: int32 | int64 | float32 | float64>(a: T, b: T) -> T {
    if (a > b) {
        return a;
    }
    return b;
}

// Generic min function
fn min<T: int32 | int64 | float32 | float64>(a: T, b: T) -> T {
    if (a < b) {
        return a;
    }
    return b;
}

// Generic abs function for signed integers
fn abs<T: int8 | int16 | int32 | int64>(x: T, zero: T) -> T {
    if (x < zero) {
        return -x;
    }
    return x;
}

// Test with int32 (type inference)
a: int32 = 10;
b: int32 = 20;
maxVal: int32 = max(a, b);
println(maxVal);  // 20

minVal: int32 = min(a, b);
println(minVal);  // 10

// Test with int64 (type inference)
c: int64 = 100i64;
d: int64 = 50i64;
maxVal64: int64 = max(c, d);
println(maxVal64);  // 100

// Test with float32 (explicit type arguments)
e: float32 = 3.14f32;
f: float32 = 2.71f32;
maxFloat: float32 = max<float32>(e, f);
println(maxFloat);  // 3.14

// Test abs with different integer types
negInt: int32 = -42;
absInt: int32 = abs(negInt, 0);
println(absInt);  // 42

negInt64: int64 = -999i64;
absInt64: int64 = abs(negInt64, 0i64);
println(absInt64);  // 999

/* EXPECT
20
10
100
3.140000
42
999
*/
