// Regression test: calling a generic class's method directly as an
// if-condition (or any inline expression context that isn't first assigned
// to a local variable) must resolve to a real value, not crash lowering.
// Root cause was ast_to_fir.py's _find_method_def() looking up methods
// keyed by the bare class name while callers passed the full generic
// instantiation (e.g. "Option<int32>"), which only ever failed to resolve
// for classes imported from another module.
import @firescript/std.io.println;
import @firescript/std.types.Option;

some_opt: Option<int32> = Option<int32>(42);
if (some_opt.isSome()) {
    println("some");
} else {
    println("none");
}

/* EXPECT
some
*/
