//@ snapshot: fir, flir
import @firescript/std.io.println;

// A generic function using '%' between two operands of the same (still
// abstract) type parameter -- exercises the type-parameter-match branch of
// the '%' operator's type check, distinct from the concrete-integer-type
// branch already covered by other modulo tests.
constraint Numeric = int32 | float32;

fn modT<T: Numeric>(a: T, b: T) -> T {
    return a % b;
}

println(modT(5, 2));

/* EXPECT
1
*/
