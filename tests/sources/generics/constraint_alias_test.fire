// Test custom type constraint aliases

import @firescript/std.io.println;

// Define some constraint aliases
constraint NumericPrimitive = int32 | int64 | float32 | float64;
constraint SignedInteger = int8 | int16 | int32 | int64;

// Use the constraint alias in a generic function
fn add<T: NumericPrimitive>(a: T, b: T) -> T {
    return a + b;
}

fn abs<T: SignedInteger>(x: T, zero: T) -> T {
    if (x < zero) {
        return -x;
    }
    return x;
}

// Test with NumericPrimitive constraint
sum1: int32 = add(10i32, 20i32);
sum2: int64 = add(100i64, 200i64);
sum3: float32 = add(1.5f32, 2.5f32);
sum4: float64 = add(3.14f64, 2.71f64);

println(sum1);  // 30
println(sum2);  // 300
println(sum3);  // 4.0
println(sum4);  // 5.85

// Test with SignedInteger constraint
abs1: int32 = abs(-42i32, 0i32);
abs2: int64 = abs(-999i64, 0i64);

println(abs1);  // 42
println(abs2);  // 999

return 0;

/* EXPECT
30
300
4.000000
5.850000
42
999
*/
