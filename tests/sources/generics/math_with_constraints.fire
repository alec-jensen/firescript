import @firescript/std.io.println;
import @firescript/std.math.{max, min, abs, clamp}

// Test with int32
a: int32 = 10;
b: int32 = 20;
maxVal: int32 = max(a, b);
minVal: int32 = min(a, b);

println(maxVal);
println(minVal);

// Test with float64
x: float64 = 3.14;
y: float64 = 2.71;
maxFloat: float64 = max(x, y);

println(maxFloat);

// Test abs with int64
negNum: int64 = -42i64;
absVal: int64 = abs(negNum, 0i64);

println(absVal);

// Test clamp
clamped: int32 = clamp(100, 0, 50);
println(clamped);

/* EXPECT
20
10
3.140000
42
50
*/
