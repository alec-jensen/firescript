//@ snapshot: fir, flir
import @firescript/std.io.println;

copyable class Pair<T, U> {
    first: T;
    second: U;

    fn Pair(first: T, second: U) {
        this.first = first;
        this.second = second;
    }
}

p1: Pair<int32, int32> = Pair<int32, int32>(10, 20);
p2: Pair<int32, string> = Pair<int32, string>(42, "hello");

println(p1.first);
println(p1.second);
println(p2.first);
println(p2.second);

/* EXPECT
10
20
42
hello
*/
