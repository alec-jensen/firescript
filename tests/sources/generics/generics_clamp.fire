// Test generic clamp function

import @firescript/std.io.println;

fn clamp<T: int32 | int64 | float32 | float64>(value: T, min: T, max: T) -> T {
    if (value < min) {
        return min;
    }
    if (value > max) {
        return max;
    }
    return value;
}

// Test with int32
val1: int32 = clamp(5, 10, 20);
println(val1);  // 10 (clamped to min)

val2: int32 = clamp(15, 10, 20);
println(val2);  // 15 (within range)

val3: int32 = clamp(25, 10, 20);
println(val3);  // 20 (clamped to max)

// Test with float64
val4: float64 = clamp(0.5, 1.0, 5.0);
println(val4);  // 1.0 (clamped to min)

val5: float64 = clamp(3.0, 1.0, 5.0);
println(val5);  // 3.0 (within range)

val6: float64 = clamp(10.0, 1.0, 5.0);
println(val6);  // 5.0 (clamped to max)

/* EXPECT
10
15
20
1.000000
3.000000
5.000000
*/
