// Test combining constraint aliases

import @firescript/std.io.println;

constraint SmallInt = int8 | int16;
constraint MediumInt = int32 | int64;
constraint AllInt = SmallInt | MediumInt;  // Nested alias

fn triple<T: AllInt>(value: T) -> T {
    return value + value + value;
}

a: int8 = 10i8;
b: int16 = 100i16;
c: int32 = 1000i32;
d: int64 = 10000i64;

r1: int8 = triple(a);
r2: int16 = triple(b);
r3: int32 = triple(c);
r4: int64 = triple(d);

println(r1);  // 30
println(r2);  // 300
println(r3);  // 3000
println(r4);  // 30000

return 0;

/* EXPECT
30
300
3000
30000
*/
