// KNOWN BUG: `owned this` as a constructor receiver parses successfully
// (firescript/parser/declarations.py's constructor-parameter parsing has a
// dedicated branch for it, alongside `&this`/`&mut this`) but the emitted
// FIR is invalid: `this` gets dropped as an ordinary owned local at scope
// exit and then read again by the implicit "return this" the constructor
// synthesizes, so FIR ownership verification fails with FIRV-O1 (use after
// drop). See docs/reference/memory_management.md's "Future syntax" note --
// `owned this` receivers were only ever intended to be supported on regular
// methods, not constructors, but the parser doesn't reject the constructor
// form. Move this file back to tests/sources/classes/ (and regenerate the
// EXPECT block) once ast_to_fir.py stops treating a consuming-receiver
// constructor's `this` as needing a drop before its synthesized return.
import @firescript/std.io.println;

class Box {
    v: int32;

    fn Box(owned this, v: int32) {
        this.v = v;
    }
}

b: Box = Box(5);
println(b.v);
