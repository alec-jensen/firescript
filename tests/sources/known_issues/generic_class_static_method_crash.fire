// Regression test for a known compiler crash: a `static fn` on a generic
// class cannot be called in any form.
//
// Reproduction (inferred type arguments, as below): `Box.make(5)` crashes
// AST->FIR conversion with an internal FIR verifier error:
//   FIR verification failed (FIRV-L1): 1 violation(s) found in generated IR
//   FIRV-L1 in main/L0[0]: 'Box' has no dominating parameter, DeclareLocal,
//   or global constant
//     loadvar.int32 Box
// The lowered IR treats the bare class name `Box` as if it were a variable
// load (`loadvar`) instead of a static/type-qualified method call target.
//
// A second, distinct symptom of the same underlying gap: calling with
// explicit type arguments (`Box<int32>.make(5)`) doesn't even reach FIR --
// it's a parse error ("Expected '(' after generic class type arguments"),
// because the parser only expects a constructor call (`Box<int32>(...)`)
// immediately after generic type arguments, never a `.method(...)` call.
//
// Ordinary (non-generic) class static methods work fine -- see
// tests/sources/classes/classes_static_methods.fire. This is specific to
// the combination of `static fn` + a generic class.
//
// Expected (correct) behavior once fixed: prints 5.
import @firescript/std.io.println;

class Box<T> {
    value: T;

    fn Box(value: T) {
        this.value = value;
    }

    static fn make(v: T) -> Box<T> {
        return Box<T>(v);
    }
}

b: Box<int32> = Box.make(5);
println(b.value);
