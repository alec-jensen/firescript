import @firescript/std.io.println;

// Exercises the binary128 soft-float runtime: arithmetic, negation,
// comparisons, and conversions. Output uses printf "%f" (6 fraction digits).

println("-- arithmetic --");
float128 a = 1.25f128;
float128 b = 2.75f128;
println(a + b);          // 4.000000
println(b - a);          // 1.500000
println(a * b);          // 3.437500
println(b / a);          // 2.200000
println(-a);             // -1.250000

float128 third = 1.0f128 / 3.0f128;
println(third);          // 0.333333

println("-- comparisons --");
println(a < b);          // true
println(a > b);          // false
println(a == 1.25f128);  // true
println(a != b);         // true
println(a <= a);         // true
println(b >= a);         // true

println("-- conversions --");
float128 f = 3.999999f128;
println(f as int64);     // 3
println(42i64 as float128);   // 42.000000
println(7u64 as float128);    // 7.000000
println("1.25" as float128);  // 1.250000
float64 d = 2.5;
println(d as float128);       // 2.500000
println((a + b) as float64);  // 4.000000
