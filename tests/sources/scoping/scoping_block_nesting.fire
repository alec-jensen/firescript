import @firescript/std.io.println;

// Global scope
global: int32 = 100;
println(global);

// Block scope
outer: int32 = 10;
{
    inner: int32 = 20;
    println(outer);  // Can access outer
    println(inner);
}

// Deeply nested blocks
level0: int32 = 0;
{
    level1: int32 = 1;
    {
        level2: int32 = 2;
        {
            level3: int32 = 3;
            println(level0);
            println(level1);
            println(level2);
            println(level3);
        }
    }
}

// A variable's value is unaffected by nested blocks that go out of scope
x: int32 = 100;
println(x);  // 100
{
    x_inner: int32 = 200;
    println(x_inner);  // 200
    {
        x_deep: int32 = 300;
        println(x_deep);  // 300
    }
    println(x_inner);  // 200
}
println(x);  // 100

// Complex nesting across block/if/while
a: int32 = 1;
{
    b: int32 = 2;
    if (a > 0) {
        c: int32 = 3;
        while (c > 0) {
            d: int32 = 4;
            println(a);
            println(b);
            println(c);
            println(d);
            c--;
        }
    }
}

