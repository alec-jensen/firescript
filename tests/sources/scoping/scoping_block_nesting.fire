import @firescript/std.io.println;

// Global scope
int32 global = 100;
println(global);

// Block scope
int32 outer = 10;
{
    int32 inner = 20;
    println(outer);  // Can access outer
    println(inner);
}

// Deeply nested blocks
int32 level0 = 0;
{
    int32 level1 = 1;
    {
        int32 level2 = 2;
        {
            int32 level3 = 3;
            println(level0);
            println(level1);
            println(level2);
            println(level3);
        }
    }
}

// A variable's value is unaffected by nested blocks that go out of scope
int32 x = 100;
println(x);  // 100
{
    int32 x_inner = 200;
    println(x_inner);  // 200
    {
        int32 x_deep = 300;
        println(x_deep);  // 300
    }
    println(x_inner);  // 200
}
println(x);  // 100

// Complex nesting across block/if/while
int32 a = 1;
{
    int32 b = 2;
    if (a > 0) {
        int32 c = 3;
        while (c > 0) {
            int32 d = 4;
            println(a);
            println(b);
            println(c);
            println(d);
            c--;
        }
    }
}

