import @firescript/std.io.println;

// If statement scope
int32 condition = 1;
if (condition > 0) {
    int32 positive = 42;
    println(positive);
}

// Else scope
if (condition < 0) {
    int32 negative = -1;
    println(negative);
} else {
    int32 non_negative = 0;
    println(non_negative);
}

// While loop scope
int32 counter = 0;
while (counter < 3) {
    int32 loop_var = counter * 10;
    println(loop_var);
    counter++;
}

// For loop scope
for (int32 i = 0; i < 3; i++) {
    int32 loop_val = i * 100;
    println(loop_val);
}

// For-in loop scope
int32[] numbers = [1, 2, 3];
for (int32 num in numbers) {
    int32 doubled = num * 2;
    println(doubled);
}

/* EXPECT
42
0
0
10
20
0
100
200
2
4
6
*/
