import @firescript/std.io.println;

// If statement scope
condition: int32 = 1;
if (condition > 0) {
    positive: int32 = 42;
    println(positive);
}

// Else scope
if (condition < 0) {
    negative: int32 = -1;
    println(negative);
} else {
    non_negative: int32 = 0;
    println(non_negative);
}

// While loop scope
counter: int32 = 0;
while (counter < 3) {
    loop_var: int32 = counter * 10;
    println(loop_var);
    counter++;
}

// For loop scope
for (i: int32 = 0; i < 3; i++) {
    loop_val: int32 = i * 100;
    println(loop_val);
}

// For-in loop scope
numbers: int32[] = [1, 2, 3];
for (num: int32 in numbers) {
    doubled: int32 = num * 2;
    println(doubled);
}

/* EXPECT
42
0
0
10
20
0
100
200
2
4
6
*/
