import @firescript/std.io.println;

// Variables declared before use
int32 before = 1;
int32 after = before + 1;
println(before);
println(after);

// Same variable name across different sibling scopes are separate variables
int32 value = 1;
{
    int32 value2 = 2;
    println(value2);
}
if (true) {
    int32 value3 = 3;
    println(value3);
}
for (int32 j = 0; j < 1; j++) {
    int32 value4 = 4;
    println(value4);
}
println(value);  // Still 1

/* EXPECT
1
2
2
3
4
1
*/
