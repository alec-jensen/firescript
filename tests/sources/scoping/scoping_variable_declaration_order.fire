import @firescript/std.io.println;

// Variables declared before use
before: int32 = 1;
after: int32 = before + 1;
println(before);
println(after);

// Same variable name across different sibling scopes are separate variables
value: int32 = 1;
{
    value2: int32 = 2;
    println(value2);
}
if (true) {
    value3: int32 = 3;
    println(value3);
}
for (j: int32 = 0; j < 1; j++) {
    value4: int32 = 4;
    println(value4);
}
println(value);  // Still 1

/* EXPECT
1
2
2
3
4
1
*/
