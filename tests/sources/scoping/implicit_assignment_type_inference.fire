// Implicit variable declaration via bare assignment: the type of a
// not-yet-declared name is inferred from its initializer when the RHS is a
// constructor call or an instance method call on an already-typed object.

import @firescript/std.io.println;

class Widget {
    v: int32;

    fn Widget(v: int32) {
        this.v = v;
    }

    fn getV(&this) -> int32 {
        return this.v;
    }
}

w = Widget(7);
println(w.getV());

n = w.getV();
println(n);

/* EXPECT
7
7
*/
