    br %16, L2, L1

  L1:
    %17 = slotload.u64 new_cap
    %18 = const.u64 8
    %19 = mul.u64 %17, %18
    %20 = call.u64 @rt_raw_alloc(%19)
    slot new_table: u64
    slotstore new_table, %20
    %21 = slotload.u64 old_table
    %22 = const.u64 0
    %23 = ne.u64 %21, %22
    br %23, L4, L3

  L2:
    %24 = const.u64 256
    slotstore new_cap, %24
    jmp L1

  L3:
    %25 = slotload.u64 state
    %26 = const.u64 8
    %27 = add.u64 %25, %26
    %28 = slotload.u64 new_table
    %29 = cvt.u64_to_ptr %27
    store.u64 %29, 0, %28
    %30 = slotload.u64 state
    %31 = const.u64 16
    %32 = add.u64 %30, %31
    %33 = slotload.u64 new_cap
    %34 = cvt.u64_to_ptr %32
    store.u64 %34, 0, %33
    ret

  L4:
    %35 = const.u64 0
    slot i: u64
    slotstore i, %35
    jmp L5

  L5:
    %36 = slotload.u64 i
    %37 = slotload.u64 old_cap
    %38 = lt.u64 %36, %37
    br %38, L6, L7

  L6:
    %39 = slotload.u64 old_table
    %40 = slotload.u64 i
    %41 = const.u64 8
    %42 = mul.u64 %40, %41
    %43 = add.u64 %39, %42
    %44 = cvt.u64_to_ptr %43
    %45 = load.u64 %44, 0
    slot entry: u64
    slotstore entry, %45
    %46 = slotload.u64 entry
    %47 = const.u64 1
    %48 = gt.u64 %46, %47
    br %48, L9, L8

  L7:
    %49 = call.u64 @rt_heap()
    %50 = const.u32 0
    %51 = slotload.u64 old_table
    %52 = call.u32 @HeapFree(%49, %50, %51)
    jmp L3

  L8:
    %53 = slotload.u64 i
    %54 = const.u64 1
    %55 = add.u64 %53, %54
    slotstore i, %55
    jmp L5

  L9:
    %56 = slotload.u64 entry
    %57 = slotload.u64 new_cap
    %58 = call.u64 @rt_reg_hash(%56, %57)
    slot slot: u64
    slotstore slot, %58
    jmp L10

  L10:
    %59 = slotload.u64 new_table
    %60 = slotload.u64 slot
    %61 = const.u64 8
    %62 = mul.u64 %60, %61
    %63 = add.u64 %59, %62
    %64 = cvt.u64_to_ptr %63
    %65 = load.u64 %64, 0
    %66 = const.u64 1
    %67 = gt.u64 %65, %66
    br %67, L11, L12

  L11:
    %68 = slotload.u64 slot
    %69 = const.u64 1
    %70 = add.u64 %68, %69
    %71 = slotload.u64 new_cap
    %72 = mod.u64 %70, %71
    slotstore slot, %72
    jmp L10

  L12:
    %73 = slotload.u64 new_table
    %74 = slotload.u64 slot
    %75 = const.u64 8
    %76 = mul.u64 %74, %75
    %77 = add.u64 %73, %76
    %78 = slotload.u64 entry
    %79 = cvt.u64_to_ptr %77
    store.u64 %79, 0, %78
    jmp L8
}
