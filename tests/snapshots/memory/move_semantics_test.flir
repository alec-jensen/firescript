    %64 = cvt.u64_to_ptr %63
    %65 = load.u64 %64, 0
    %66 = const.u64 1
    %67 = gt.u64 %65, %66
    br %67, L11, L12

  L11:
    %68 = slotload.u64 slot
    %69 = const.u64 1
    %70 = add.u64 %68, %69
    %71 = slotload.u64 new_cap
    %72 = mod.u64 %70, %71
    slotstore slot, %72
    jmp L10

  L12:
    %73 = slotload.u64 new_table
    %74 = slotload.u64 slot
    %75 = const.u64 8
    %76 = mul.u64 %74, %75
    %77 = add.u64 %73, %76
    %78 = slotload.u64 entry
    %79 = cvt.u64_to_ptr %77
    store.u64 %79, 0, %78
    jmp L8
}
