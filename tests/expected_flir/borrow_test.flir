flir module borrow_test
entry @fs_main

struct Point { size: 8, align: 4, kind: class
  x: i32 @ 0
  y: i32 @ 4
}

func @getX(p: ptr<Point>) -> i32 {
  L0:
    %0 = slotload.ptr<Point> p
    %1 = load.i32 %0, 0
    ret %1
}

func @consumePoint(p: ptr<Point>) -> void {
  L0:
    %0 = slotload.ptr<Point> p
    %1 = load.i32 %0, 0
    call.void @println__int32(%1)
    ret
}

func @fs_main() -> void {
  L0:
    %0 = const.i32 10
    %1 = const.i32 20
    %2 = const.i64 8
    %3 = call.ptr<Point> @fs_rt_alloc_zeroed(%2)
    store.i32 %3, 0, %0
    store.i32 %3, 4, %1
    slot p1: ptr<Point>
    slotstore p1, %3
    %4 = slotload.ptr<Point> p1
    %5 = call.i32 @getX(%4)
    slot x: i32
    slotstore x, %5
    %6 = slotload.i32 x
    call.void @println__int32(%6)
    %7 = slotload.ptr<Point> p1
    %8 = load.i32 %7, 4
    call.void @println__int32(%8)
    %9 = slotload.ptr<Point> p1
    call.void @consumePoint(%9)
    ret
}

func @println__int32(value: i32) -> void {
  L0:
    %0 = slotload.i32 value
    %1 = call.ptr<i8> @fs_rt_i32_to_str(%0)
    %2 = strconst "\n"
    %3 = call.ptr<i8> @fs_rt_str_concat(%1, %2)
    call.void @fs_rt_stdout(%3)
    ret
}
