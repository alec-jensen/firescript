flir module imports_multi
entry @fs_main

func @square(x: i32) -> i32 {
  L0:
    %0 = slotload.i32 x
    %1 = slotload.i32 x
    %2 = mul.i32 %0, %1
    ret %2
}

func @double_val(x: i32) -> i32 {
  L0:
    %0 = slotload.i32 x
    %1 = slotload.i32 x
    %2 = add.i32 %0, %1
    ret %2
}

func @wrap(s: ptr<i8>) -> ptr<i8> {
  L0:
    %0 = strconst "["
    %1 = slotload.ptr<i8> s
    %2 = call.ptr<i8> @fs_rt_str_concat(%0, %1)
    %3 = strconst "]"
    %4 = call.ptr<i8> @fs_rt_str_concat(%2, %3)
    ret %4
}

func @fs_main() -> void {
  L0:
    %0 = const.i32 100
    slot MAX: i32
    slotstore MAX, %0
    %1 = strconst "-- Math Operations --"
    call.void @println__string(%1)
    %2 = const.i32 5
    %3 = call.i32 @square(%2)
    call.void @println__int32(%3)
    %4 = const.i32 10
    %5 = call.i32 @square(%4)
    call.void @println__int32(%5)
    %6 = slotload.i32 MAX
    call.void @println__int32(%6)
    %7 = strconst "-- String Operations --"
    call.void @println__string(%7)
    %8 = strconst "hello"
    %9 = call.ptr<i8> @wrap(%8)
    call.void @println__string(%9)
    %10 = strconst "imports work"
    %11 = call.ptr<i8> @wrap(%10)
    call.void @println__string(%11)
    ret
}

func @println__string(value: ptr<i8>) -> void {
  L0:
    %0 = slotload.ptr<i8> value
    %1 = call.ptr<i8> @fs_rt_str_dup(%0)
    %2 = strconst "\n"
    %3 = call.ptr<i8> @fs_rt_str_concat(%1, %2)
    call.void @fs_rt_stdout(%3)
    ret
}

func @println__int32(value: i32) -> void {
  L0:
    %0 = slotload.i32 value
    %1 = call.ptr<i8> @fs_rt_i32_to_str(%0)
    %2 = strconst "\n"
    %3 = call.ptr<i8> @fs_rt_str_concat(%1, %2)
    call.void @fs_rt_stdout(%3)
    ret
}
