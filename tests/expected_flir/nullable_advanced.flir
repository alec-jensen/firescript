  L6:
    %48 = slotload.i32 count
    %49 = const.i32 1
    %50 = add.i32 %48, %49
    slotstore count, %50
    jmp L5
}

func @Config__destroy(self: ptr<Config>) -> void {
  L0:
    %0 = slotload.ptr<Config> self
    %1 = load.ptr<i8> %0, 0
    %2 = nullconst
    %3 = ne.ptr %1, %2
