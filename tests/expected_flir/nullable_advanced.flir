    call.void @println__string(%10)
    %11 = slotload.ptr<Config> c2
    call.void @Config__destroy(%11)
    %12 = strconst "first"
    slot a: ptr<i8>
    %13 = call.ptr<i8> @fs_rt_str_dup(%12)
    slotstore a, %13
    %14 = nullconst
    slot b: ptr<i8>
    slotstore b, %14
    %15 = strconst "third"
    slot c: ptr<i8>
    %16 = call.ptr<i8> @fs_rt_str_dup(%15)
    slotstore c, %16
    %17 = const.i32 0
    slot count: i32
    slotstore count, %17
    %18 = slotload.ptr<i8> a
    %19 = nullconst
    %20 = ne.ptr %18, %19
    br %20, L2, L1

  L1:
    %21 = slotload.ptr<i8> a
    call.void @fs_rt_free(%21)
    %22 = slotload.ptr<i8> b
    %23 = nullconst
    %24 = ne.ptr %22, %23
    br %24, L4, L3

  L2:
    %25 = slotload.i32 count
    %26 = const.i32 1
    %27 = add.i32 %25, %26
    slotstore count, %27
    jmp L1

  L3:
    %28 = slotload.ptr<i8> b
    call.void @fs_rt_free(%28)
    %29 = slotload.ptr<i8> c
    %30 = nullconst
    %31 = ne.ptr %29, %30
    br %31, L6, L5

  L4:
    %32 = slotload.i32 count
    %33 = const.i32 1
    %34 = add.i32 %32, %33
    slotstore count, %34
    jmp L3

  L5:
    %35 = slotload.ptr<i8> c
    call.void @fs_rt_free(%35)
    %36 = slotload.i32 count
    call.void @println__int32(%36)
    %37 = nullconst
    slot val: ptr<i8>
    slotstore val, %37
    %38 = slotload.ptr<i8> val
    %39 = nullconst
    %40 = eq.ptr %38, %39
    call.void @println__bool(%40)
    %41 = slotload.ptr<i8> val
    call.void @fs_rt_free(%41)
    %42 = strconst "assigned"
    %43 = call.ptr<i8> @fs_rt_str_dup(%42)
    slotstore val, %43
    %44 = slotload.ptr<i8> val
    %45 = nullconst
    %46 = ne.ptr %44, %45
    call.void @println__bool(%46)
    %47 = slotload.ptr<i8> val
    call.void @fs_rt_free(%47)
