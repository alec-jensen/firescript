flir module nullable_advanced
entry @fs_main

struct Config { size: 16, align: 8, kind: class
  host: ptr<i8> @ 0
  port: ptr<i8> @ 8
}

func @Config__Config(host: ptr<i8>, port: ptr<i8>) -> ptr<Config> {
  L0:
    %0 = const.i64 16
    %1 = call.ptr<Config> @fs_rt_alloc_zeroed(%0)
    slot this: ptr<Config>
    slotstore this, %1
    %2 = slotload.ptr<i8> host
    %3 = slotload.ptr<Config> this
    store.ptr<i8> %3, 0, %2
    %4 = slotload.ptr<i8> port
    %5 = slotload.ptr<Config> this
    store.ptr<i8> %5, 8, %4
    %6 = slotload.ptr<Config> this
    ret %6
}

func @Config__address(this: ptr<Config>) -> ptr<i8> {
  L0:
    %0 = slotload.ptr<Config> this
    %1 = load.ptr<i8> %0, 8
    %2 = nullconst
    %3 = ne.ptr %1, %2
    br %3, L2, L1

  L1:
    %4 = slotload.ptr<Config> this
    %5 = load.ptr<i8> %4, 0
    ret %5

  L2:
    %6 = slotload.ptr<Config> this
    %7 = load.ptr<i8> %6, 0
    %8 = strconst ":"
    %9 = call.ptr<i8> @fs_rt_str_concat(%7, %8)
    %10 = slotload.ptr<Config> this
    %11 = load.ptr<i8> %10, 8
    %12 = call.ptr<i8> @fs_rt_str_concat(%9, %11)
    ret %12
}

