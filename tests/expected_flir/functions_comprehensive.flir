flir module functions_comprehensive
entry @fs_main

func @greet() -> void {
  L0:
    %0 = strconst "Hello from function!"
    call.void @println__string(%0)
    ret
}

func @getConstant() -> i32 {
  L0:
    %0 = const.i32 42
    ret %0
}

func @double(x: i32) -> i32 {
  L0:
    %0 = slotload.i32 x
    %1 = const.i32 2
    %2 = mul.i32 %0, %1
    ret %2
}

func @add(a: i32, b: i32) -> i32 {
  L0:
    %0 = slotload.i32 a
    %1 = slotload.i32 b
    %2 = add.i32 %0, %1
