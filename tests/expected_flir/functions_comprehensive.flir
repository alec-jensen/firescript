}

func @multiply(x: i32, y: i32) -> i32 {
  L0:
    %0 = slotload.i32 x
    %1 = slotload.i32 y
    %2 = mul.i32 %0, %1
    ret %2
}

func @addThenDouble(a: i32, b: i32) -> i32 {
  L0:
    %0 = slotload.i32 a
    %1 = slotload.i32 b
    %2 = call.i32 @add(%0, %1)
    slot sum: i32
    slotstore sum, %2
    %3 = slotload.i32 sum
    %4 = call.i32 @double(%3)
    ret %4
}

func @factorial(n: i32) -> i32 {
  L0:
    %0 = slotload.i32 n
    %1 = const.i32 1
    %2 = le.i32 %0, %1
    br %2, L2, L1

  L1:
    %3 = slotload.i32 n
    %4 = slotload.i32 n
    %5 = const.i32 1
    %6 = sub.i32 %4, %5
    %7 = call.i32 @factorial(%6)
    %8 = mul.i32 %3, %7
    ret %8

  L2:
    %9 = const.i32 1
    ret %9
}

func @divide(a: f32, b: f32) -> f32 {
  L0:
    %0 = slotload.f32 a
    %1 = slotload.f32 b
    %2 = div.f32 %0, %1
    ret %2
}

func @isEven(n: i32) -> bool {
  L0:
    %0 = slotload.i32 n
    %1 = const.i32 2
    %2 = mod.i32 %0, %1
    %3 = const.i32 0
    %4 = eq.i32 %2, %3
    ret %4
}

func @makeGreeting(name: ptr<i8>) -> ptr<i8> {
  L0:
    %0 = strconst "Hello, "
    %1 = slotload.ptr<i8> name
    %2 = call.ptr<i8> @fs_rt_str_concat(%0, %1)
    %3 = strconst "!"
    %4 = call.ptr<i8> @fs_rt_str_concat(%2, %3)
    ret %4
}

func @getFirst(arr: ptr, arr_len: i32) -> i32 {
  L0:
    %0 = slotload.ptr arr
    %1 = const.i32 0
    %2 = slotload.i32 arr_len
    %3 = const.i32 0
    %4 = lt.i32 %1, %3
    %5 = cvt.bool_to_i32 %4
    %6 = mul.i32 %5, %2
    %7 = add.i32 %1, %6
    %8 = ptradd %0, %7, 4
    %9 = load.i32 %8, 0
    ret %9
}

func @arraySum(values: ptr, values_len: i32) -> i32 {
  L0:
    %0 = const.i32 0
    slot total: i32
    slotstore total, %0
    %1 = slotload.ptr values
    slot __arr_v: ptr
    slotstore __arr_v, %1
    %2 = const.i32 0
    slot __i_v: i32
    slotstore __i_v, %2
    jmp L1

  L1:
    %3 = slotload.i32 __i_v
    %4 = slotload.ptr __arr_v
    %5 = slotload.i32 values_len
    %6 = lt.i32 %3, %5
    br %6, L2, L3

  L2:
    %7 = slotload.ptr __arr_v
    %8 = slotload.i32 __i_v
    %9 = slotload.i32 values_len
    %10 = const.i32 0
    %11 = lt.i32 %8, %10
    %12 = cvt.bool_to_i32 %11
    %13 = mul.i32 %12, %9
    %14 = add.i32 %8, %13
    %15 = ptradd %7, %14, 4
    %16 = load.i32 %15, 0
    slot v: i32
    slotstore v, %16
    %17 = slotload.i32 total
    %18 = slotload.i32 v
    %19 = add.i32 %17, %18
    slotstore total, %19
    jmp L4

  L3:
    %20 = slotload.i32 total
    ret %20

  L4:
    %21 = slotload.i32 __i_v
    %22 = const.i32 1
    %23 = add.i32 %21, %22
    slotstore __i_v, %23
    jmp L1
}

func @findPositive(x: i32) -> i32 {
  L0:
    %0 = slotload.i32 x
    %1 = const.i32 0
    %2 = gt.i32 %0, %1
    br %2, L2, L1

  L1:
    %3 = const.i32 0
    ret %3

  L2:
    %4 = slotload.i32 x
    ret %4
}

func @classify(n: i32) -> ptr<i8> {
  L0:
    %0 = slotload.i32 n
    %1 = const.i32 0
    %2 = lt.i32 %0, %1
    br %2, L2, L3

  L1:
    %3 = nullconst
    ret %3

  L2:
    %4 = strconst "negative"
    ret %4

  L3:
    %5 = slotload.i32 n
    %6 = const.i32 0
    %7 = eq.i32 %5, %6
    br %7, L5, L6

  L4:
    jmp L1

  L5:
    %8 = strconst "zero"
    ret %8

  L6:
    %9 = strconst "positive"
    ret %9
}

func @printTwice(msg: ptr<i8>) -> void {
  L0:
    %0 = slotload.ptr<i8> msg
    call.void @println__string(%0)
    %1 = slotload.ptr<i8> msg
    call.void @println__string(%1)
    ret
}

func @complexCalc(a: i32, b: i32, c: i32) -> i32 {
  L0:
    %0 = slotload.i32 a
    %1 = slotload.i32 b
    %2 = add.i32 %0, %1
    slot temp: i32
    slotstore temp, %2
    %3 = slotload.i32 temp
    %4 = slotload.i32 c
    %5 = mul.i32 %3, %4
    slotstore temp, %5
    %6 = slotload.i32 temp
    %7 = const.i32 100
    %8 = gt.i32 %6, %7
    br %8, L2, L1

  L1:
    %9 = slotload.i32 temp
    ret %9

  L2:
    %10 = slotload.i32 temp
    %11 = const.i32 2
    %12 = div.i32 %10, %11
    ret %12
}

func @fs_main() -> void {
  L0:
    %0 = strconst "=== Function Tests ==="
    call.void @println__string(%0)
    %1 = strconst "--- No Parameters ---"
    call.void @println__string(%1)
    call.void @greet()
    %2 = strconst "--- Return Value, No Parameters ---"
    call.void @println__string(%2)
    %3 = call.i32 @getConstant()
    call.void @println__int32(%3)
    %4 = strconst "--- Single Parameter ---"
    call.void @println__string(%4)
    %5 = const.i32 5
    %6 = call.i32 @double(%5)
    call.void @println__int32(%6)
    %7 = const.i32 10
    %8 = call.i32 @double(%7)
    call.void @println__int32(%8)
    %9 = strconst "--- Multiple Parameters ---"
    call.void @println__string(%9)
    %10 = const.i32 3
    %11 = const.i32 7
    %12 = call.i32 @add(%10, %11)
    call.void @println__int32(%12)
    %13 = const.i32 100
    %14 = const.i32 200
    %15 = call.i32 @add(%13, %14)
    call.void @println__int32(%15)
    %16 = const.i32 4
    %17 = const.i32 5
    %18 = call.i32 @multiply(%16, %17)
    call.void @println__int32(%18)
    %19 = strconst "--- Function Calling Function ---"
    call.void @println__string(%19)
    %20 = const.i32 2
    %21 = const.i32 3
    %22 = call.i32 @addThenDouble(%20, %21)
    call.void @println__int32(%22)
    %23 = strconst "--- Recursion ---"
    call.void @println__string(%23)
    %24 = const.i32 5
    %25 = call.i32 @factorial(%24)
    call.void @println__int32(%25)
    %26 = const.i32 3
    %27 = call.i32 @factorial(%26)
    call.void @println__int32(%27)
    %28 = strconst "--- Different Return Types ---"
    call.void @println__string(%28)
    %29 = fconst.f32 10.0
    %30 = fconst.f32 4.0
    %31 = call.f32 @divide(%29, %30)
    call.void @println__float32(%31)
    %32 = const.i32 4
    %33 = call.bool @isEven(%32)
    call.void @println__bool(%33)
    %34 = const.i32 7
    %35 = call.bool @isEven(%34)
    call.void @println__bool(%35)
    %36 = strconst "Alice"
    %37 = call.ptr<i8> @makeGreeting(%36)
    call.void @println__string(%37)
    %38 = strconst "--- Array Parameters ---"
    call.void @println__string(%38)
    %39 = const.i32 99
    %40 = const.i32 88
    %41 = const.i32 77
    %42 = const.i64 12
    %43 = call.ptr @fs_rt_alloc_zeroed(%42)
    store.i32 %43, 0, %39
    store.i32 %43, 4, %40
    store.i32 %43, 8, %41
    slot nums: ptr
    slotstore nums, %43
    %44 = slotload.ptr nums
    %45 = const.i32 3
    %46 = call.i32 @getFirst(%44, %45)
    call.void @println__int32(%46)
    %47 = const.i32 1
    %48 = const.i32 2
    %49 = const.i32 3
    %50 = const.i32 4
    %51 = const.i32 5
    %52 = const.i64 20
    %53 = call.ptr @fs_rt_alloc_zeroed(%52)
    store.i32 %53, 0, %47
    store.i32 %53, 4, %48
    store.i32 %53, 8, %49
    store.i32 %53, 12, %50
    store.i32 %53, 16, %51
    slot to_sum: ptr
    slotstore to_sum, %53
    %54 = slotload.ptr to_sum
    %55 = const.i32 5
    %56 = call.i32 @arraySum(%54, %55)
    call.void @println__int32(%56)
    %57 = strconst "--- Early Return ---"
    call.void @println__string(%57)
    %58 = const.i32 42
    %59 = call.i32 @findPositive(%58)
    call.void @println__int32(%59)
    %60 = const.i32 5
    %61 = neg.i32 %60
    %62 = call.i32 @findPositive(%61)
    call.void @println__int32(%62)
    %63 = strconst "--- Multiple Returns ---"
    call.void @println__string(%63)
    %64 = const.i32 3
    %65 = neg.i32 %64
    %66 = call.ptr<i8> @classify(%65)
    call.void @println__string(%66)
    %67 = const.i32 0
    %68 = call.ptr<i8> @classify(%67)
    call.void @println__string(%68)
    %69 = const.i32 5
    %70 = call.ptr<i8> @classify(%69)
    call.void @println__string(%70)
    %71 = strconst "--- Void Functions ---"
    call.void @println__string(%71)
    %72 = strconst "repeat"
    call.void @printTwice(%72)
    %73 = strconst "--- Complex Function ---"
    call.void @println__string(%73)
    %74 = const.i32 10
    %75 = const.i32 20
    %76 = const.i32 5
    %77 = call.i32 @complexCalc(%74, %75, %76)
    call.void @println__int32(%77)
    %78 = const.i32 2
    %79 = const.i32 3
    %80 = const.i32 4
    %81 = call.i32 @complexCalc(%78, %79, %80)
    call.void @println__int32(%81)
    %82 = strconst "=== All function tests passed ==="
    call.void @println__string(%82)
    ret
}

func @println__string(value: ptr<i8>) -> void {
  L0:
    %0 = slotload.ptr<i8> value
    %1 = call.ptr<i8> @fs_rt_str_dup(%0)
