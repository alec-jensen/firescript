func @println__int32(value: i32) -> void {
  L0:
    %0 = slotload.i32 value
    %1 = call.ptr<i8> @fs_rt_i32_to_str(%0)
    %2 = strconst "\n"
    %3 = call.ptr<i8> @fs_rt_str_concat(%1, %2)
