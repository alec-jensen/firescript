    slot this: %Pair__int32_string
    slotstore this, %2
    %3 = slotload.i32 first
    %4 = slotload.%Pair__int32_string this
    %5 = slotaddr this
    store.i32 %5, 0, %3
    %6 = slotload.ptr<i8> second
    %7 = slotload.%Pair__int32_string this
    %8 = slotaddr this
    store.ptr<i8> %8, 8, %6
