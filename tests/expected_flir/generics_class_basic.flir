func @println__string(value: ptr<i8>) -> void {
  L0:
    %0 = slotload.ptr<i8> value
    %1 = call.ptr<i8> @fs_rt_str_dup(%0)
    %2 = strconst "\n"
    %3 = call.ptr<i8> @fs_rt_str_concat(%1, %2)
