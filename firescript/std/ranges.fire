export fn range(end: int32) -> generator<int32> {
    i: int32 = 0;
    while (i < end) {
        yield i;
        i += 1;
    }
}

export fn rangeFrom(start: int32, end: int32) -> generator<int32> {
    i: int32 = start;
    while (i < end) {
        yield i;
        i += 1;
    }
}

export fn rangeStep(start: int32, end: int32, step: int32) -> generator<int32> {
    i: int32 = start;
    while (i < end) {
        yield i;
        i += step;
    }
}
