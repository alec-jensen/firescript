// firescript runtime, implemented in firescript.
//
// This module is compiled through the normal pipeline and merged into
// every program built with the FIR backends. Functions named fs_rt_*
// implement the FLIR runtime ABI (see FIR_flir_spec.md); the lowering
// routes runtime calls here instead of to backend-provided shims.
//
// Rules for code in this file:
// - Only lowlevel primitives (mem_*, win_*, str_to_addr/addr_to_str)
//   and other fs_rt_* functions may be used; no std imports.
// - Inside a function fs_rt_X, do not use language constructs that
//   lower to fs_rt_X itself (e.g. no string + inside fs_rt_str_concat).
// - Work with uint64 addresses internally; only touch string-typed
//   values at function boundaries (avoids ownership churn).

directive enable_lowlevel_runtime;

// ---------------------------------------------------------------------
// Runtime state block (lazily allocated; address in the state cell)
//
// Layout (byte offsets):
//   0:  process heap handle
//   8:  allocation registry table ptr (slots of u64; 0=empty, 1=tombstone)
//   16: registry capacity (power of two)
//   24: registry live count
//   32: scratch u64 (WriteFile/ReadFile out-params)
//   40: argc
//   48: argv block ptr (argc * u64 string addresses)
//   56: fd table ptr (64 slots of u64 HANDLE; fd = index + 3)
// ---------------------------------------------------------------------

fn rt_state() -> uint64 {
    state: uint64 = runtime_state_get();
    if (state != 0u64) {
        return state;
    }
    heap: uint64 = win_get_process_heap();
    // 0x8 = HEAP_ZERO_MEMORY
    block: uint64 = win_heap_alloc(heap, 8u32, 64u64);
    mem_store_u64(block, heap);
    runtime_state_set(block);
    return block;
}

fn rt_heap() -> uint64 {
    state: uint64 = rt_state();
    return mem_load_u64(state);
}

fn rt_raw_alloc(n: uint64) -> uint64 {
    if (n == 0u64) {
        n = 1u64;
    }
    return win_heap_alloc(rt_heap(), 8u32, n);
}

// ---- allocation registry (legacy double-free / literal-free guard) ----

fn rt_reg_hash(p: uint64, cap: uint64) -> uint64 {
    h: uint64 = (p / 16u64) * 2654435761u64;
    return h % cap;
}

fn rt_reg_grow() -> void {
    state: uint64 = rt_state();
    old_table: uint64 = mem_load_u64(state + 8u64);
    old_cap: uint64 = mem_load_u64(state + 16u64);
    new_cap: uint64 = old_cap * 2u64;
    if (new_cap == 0u64) {
        new_cap = 256u64;
    }
    new_table: uint64 = rt_raw_alloc(new_cap * 8u64);
    if (old_table != 0u64) {
        i: uint64 = 0u64;
        while (i < old_cap) {
            entry: uint64 = mem_load_u64(old_table + i * 8u64);
            if (entry > 1u64) {
                slot: uint64 = rt_reg_hash(entry, new_cap);
                while (mem_load_u64(new_table + slot * 8u64) > 1u64) {
                    slot = (slot + 1u64) % new_cap;
                }
                mem_store_u64(new_table + slot * 8u64, entry);
            }
            i = i + 1u64;
        }
        win_heap_free(rt_heap(), 0u32, old_table);
    }
    mem_store_u64(state + 8u64, new_table);
    mem_store_u64(state + 16u64, new_cap);
}

fn rt_reg_add(p: uint64) -> void {
    if (p <= 1u64) {
        return;
    }
    state: uint64 = rt_state();
    cap: uint64 = mem_load_u64(state + 16u64);
    count: uint64 = mem_load_u64(state + 24u64);
    if (cap == 0u64 || count * 10u64 >= cap * 7u64) {
        rt_reg_grow();
        cap = mem_load_u64(state + 16u64);
    }
    table: uint64 = mem_load_u64(state + 8u64);
    slot: uint64 = rt_reg_hash(p, cap);
    while (true) {
        entry: uint64 = mem_load_u64(table + slot * 8u64);
        if (entry <= 1u64) {
            mem_store_u64(table + slot * 8u64, p);
            mem_store_u64(state + 24u64, count + 1u64);
            return;
        }
        if (entry == p) {
            return;
        }
        slot = (slot + 1u64) % cap;
    }
}

fn rt_reg_remove(p: uint64) -> bool {
    if (p <= 1u64) {
        return false;
    }
    state: uint64 = rt_state();
    cap: uint64 = mem_load_u64(state + 16u64);
    if (cap == 0u64) {
        return false;
    }
    table: uint64 = mem_load_u64(state + 8u64);
    slot: uint64 = rt_reg_hash(p, cap);
    probes: uint64 = 0u64;
    while (probes < cap) {
        entry: uint64 = mem_load_u64(table + slot * 8u64);
        if (entry == 0u64) {
            return false;
        }
        if (entry == p) {
            // 1 = tombstone
            mem_store_u64(table + slot * 8u64, 1u64);
            count: uint64 = mem_load_u64(state + 24u64);
            mem_store_u64(state + 24u64, count - 1u64);
            return true;
        }
        slot = (slot + 1u64) % cap;
        probes = probes + 1u64;
    }
    return false;
}

// ---- core allocation ABI ----

fn fs_rt_alloc_zeroed(n: int64) -> string {
    p: uint64 = rt_raw_alloc(n as uint64);
    rt_reg_add(p);
    return addr_to_str(p);
}

fn fs_rt_free(&p: string) -> void {
    addr: uint64 = str_to_addr(p);
    if (addr == 0u64) {
        return;
    }
    if (rt_reg_remove(addr)) {
        win_heap_free(rt_heap(), 0u32, addr);
    }
    // Untracked pointers (string literals, already-freed blocks) are
    // ignored, matching the legacy runtime's registry semantics.
}

fn fs_rt_zero_memory(&p: string, n: int64) -> void {
    addr: uint64 = str_to_addr(p);
    i: uint64 = 0u64;
    while (i < (n as uint64)) {
        mem_store_u8(addr + i, 0u8);
        i = i + 1u64;
    }
}

// ---- integer exponentiation (** operator) ----

fn fs_rt_pow_i64(base: int64, exp: int64) -> int64 {
    result: int64 = 1i64;
    while (exp > 0i64) {
        result = result * base;
        exp = exp - 1i64;
    }
    return result;
}

fn fs_rt_pow_f64(base: float64, exp: float64) -> float64 {
    result: float64 = 1.0;
    if (exp < 0.0) {
        acc: float64 = 1.0;
        e: int64 = (-exp) as int64;
        while (e > 0i64) {
            acc = acc * base;
            e = e - 1i64;
        }
        return 1.0 / acc;
    }
    e2: int64 = exp as int64;
    while (e2 > 0i64) {
        result = result * base;
        e2 = e2 - 1i64;
    }
    return result;
}

// ---- string primitives (strings are NUL-terminated byte buffers) ----

fn rt_str_len_addr(addr: uint64) -> uint64 {
    if (addr == 0u64) {
        return 0u64;
    }
    len: uint64 = 0u64;
    while (mem_load_u8(addr + len) != 0u8) {
        len = len + 1u64;
    }
    return len;
}

fn fs_rt_str_length(&s: string) -> int32 {
    return rt_str_len_addr(str_to_addr(s)) as int32;
}

fn fs_rt_str_dup(&s: string) -> string {
    src: uint64 = str_to_addr(s);
    len: uint64 = rt_str_len_addr(src);
    dst: uint64 = rt_raw_alloc(len + 1u64);
    rt_reg_add(dst);
    if (len > 0u64) {
        mem_copy(dst, src, len);
    }
    mem_store_u8(dst + len, 0u8);
    return addr_to_str(dst);
}

fn fs_rt_str_concat(&a: string, &b: string) -> string {
    pa: uint64 = str_to_addr(a);
    pb: uint64 = str_to_addr(b);
    la: uint64 = rt_str_len_addr(pa);
    lb: uint64 = rt_str_len_addr(pb);
    dst: uint64 = rt_raw_alloc(la + lb + 1u64);
    rt_reg_add(dst);
    if (la > 0u64) {
        mem_copy(dst, pa, la);
    }
    if (lb > 0u64) {
        mem_copy(dst + la, pb, lb);
    }
    mem_store_u8(dst + la + lb, 0u8);
    return addr_to_str(dst);
}

fn fs_rt_str_eq(&a: string, &b: string) -> bool {
    pa: uint64 = str_to_addr(a);
    pb: uint64 = str_to_addr(b);
    if (pa == 0u64 || pb == 0u64) {
        return pa == pb;
    }
    i: uint64 = 0u64;
    while (true) {
        ca: uint8 = mem_load_u8(pa + i);
        cb: uint8 = mem_load_u8(pb + i);
        if (ca != cb) {
            return false;
        }
        if (ca == 0u8) {
            return true;
        }
        i = i + 1u64;
    }
    return true;
}

fn fs_rt_str_char_at(&s: string, index: int32) -> string {
    src: uint64 = str_to_addr(s);
    len: uint64 = rt_str_len_addr(src);
    dst: uint64 = rt_raw_alloc(2u64);
    rt_reg_add(dst);
    if (index >= 0 && (index as uint64) < len) {
        mem_store_u8(dst, mem_load_u8(src + (index as uint64)));
        mem_store_u8(dst + 1u64, 0u8);
    } else {
        mem_store_u8(dst, 0u8);
    }
    return addr_to_str(dst);
}

fn fs_rt_str_char_code_at(&s: string, index: int32) -> uint8 {
    src: uint64 = str_to_addr(s);
    len: uint64 = rt_str_len_addr(src);
    if (index < 0 || (index as uint64) >= len) {
        return 0u8;
    }
    return mem_load_u8(src + (index as uint64));
}

fn fs_rt_str_char_code(&s: string) -> uint8 {
    src: uint64 = str_to_addr(s);
    if (src == 0u64) {
        return 0u8;
    }
    return mem_load_u8(src);
}

fn fs_rt_str_index_of(&haystack: string, &needle: string) -> int32 {
    ph: uint64 = str_to_addr(haystack);
    pn: uint64 = str_to_addr(needle);
    if (ph == 0u64 || pn == 0u64) {
        return -1;
    }
    lh: uint64 = rt_str_len_addr(ph);
    ln: uint64 = rt_str_len_addr(pn);
    if (ln == 0u64) {
        return 0;
    }
    if (ln > lh) {
        return -1;
    }
    last: uint64 = lh - ln;
    i: uint64 = 0u64;
    while (i <= last) {
        j: uint64 = 0u64;
        matched: bool = true;
        while (j < ln) {
            if (mem_load_u8(ph + i + j) != mem_load_u8(pn + j)) {
                matched = false;
                break;
            }
            j = j + 1u64;
        }
        if (matched) {
            return i as int32;
        }
        i = i + 1u64;
    }
    return -1;
}

fn fs_rt_str_slice(&s: string, start: int32, end: int32) -> string {
    src: uint64 = str_to_addr(s);
    len: uint64 = rt_str_len_addr(src);
    length: int32 = len as int32;
    if (start < 0) { start = 0; }
    if (end < 0) { end = 0; }
    if (start > length) { start = length; }
    if (end > length) { end = length; }
    if (end < start) { end = start; }
    out_len: int32 = end - start;
    dst: uint64 = rt_raw_alloc((out_len as uint64) + 1u64);
    rt_reg_add(dst);
    if (out_len > 0) {
        mem_copy(dst, src + (start as uint64), out_len as uint64);
    }
    mem_store_u8(dst + (out_len as uint64), 0u8);
    return addr_to_str(dst);
}

// ---- integer -> string conversions ----

fn rt_u64_to_str_impl(v: uint64, negative: bool) -> string {
    // Max u64 is 20 digits + sign + NUL.
    buf: uint64 = rt_raw_alloc(22u64);
    rt_reg_add(buf);
    pos: uint64 = 21u64;
    mem_store_u8(buf + pos, 0u8);
    if (v == 0u64) {
        pos = pos - 1u64;
        mem_store_u8(buf + pos, 48u8); // '0'
    }
    while (v > 0u64) {
        pos = pos - 1u64;
        mem_store_u8(buf + pos, ((v % 10u64) as uint8) + 48u8);
        v = v / 10u64;
    }
    if (negative) {
        pos = pos - 1u64;
        mem_store_u8(buf + pos, 45u8); // '-'
    }
    // Shift to the buffer start so the returned pointer is the block start
    // (required for the allocation registry to recognize it on free).
    out_len: uint64 = 21u64 - pos;
    i: uint64 = 0u64;
    while (i < out_len) {
        mem_store_u8(buf + i, mem_load_u8(buf + pos + i));
        i = i + 1u64;
    }
    mem_store_u8(buf + out_len, 0u8);
    return addr_to_str(buf);
}

fn fs_rt_i64_to_str(v: int64) -> string {
    if (v < 0i64) {
        // Negate via u64 to handle INT64_MIN.
        magnitude: uint64 = 0u64 - (v as uint64);
        return rt_u64_to_str_impl(magnitude, true);
    }
    return rt_u64_to_str_impl(v as uint64, false);
}

fn fs_rt_i32_to_str(v: int32) -> string {
    return fs_rt_i64_to_str(v as int64);
}

fn fs_rt_u64_to_str(v: uint64) -> string {
    return rt_u64_to_str_impl(v, false);
}

fn fs_rt_u32_to_str(v: uint32) -> string {
    return rt_u64_to_str_impl(v as uint64, false);
}

fn fs_rt_bool_to_str(v: bool) -> string {
    if (v) {
        return fs_rt_str_dup("true");
    }
    return fs_rt_str_dup("false");
}

fn fs_rt_char_to_str(c: uint8) -> string {
    dst: uint64 = rt_raw_alloc(2u64);
    rt_reg_add(dst);
    mem_store_u8(dst, c);
    mem_store_u8(dst + 1u64, 0u8);
    return addr_to_str(dst);
}

// ---- string -> number parsing (atoi/atoll/atof semantics) ----

fn rt_parse_int(addr: uint64) -> int64 {
    if (addr == 0u64) {
        return 0i64;
    }
    i: uint64 = 0u64;
    // Skip leading whitespace (space, tab, newline, CR, FF, VT).
    while (true) {
        c: uint8 = mem_load_u8(addr + i);
        if (c == 32u8 || (c >= 9u8 && c <= 13u8)) {
            i = i + 1u64;
        } else {
            break;
        }
    }
    negative: bool = false;
    sign: uint8 = mem_load_u8(addr + i);
    if (sign == 45u8) { // '-'
        negative = true;
        i = i + 1u64;
    } else if (sign == 43u8) { // '+'
        i = i + 1u64;
    }
    value: int64 = 0i64;
    while (true) {
        c: uint8 = mem_load_u8(addr + i);
        if (c < 48u8 || c > 57u8) {
            break;
        }
        value = value * 10i64 + ((c - 48u8) as int64);
        i = i + 1u64;
    }
    if (negative) {
        return -value;
    }
    return value;
}

fn fs_rt_str_to_i32(&s: string) -> int32 {
    return rt_parse_int(str_to_addr(s)) as int32;
}

fn fs_rt_str_to_i64(&s: string) -> int64 {
    return rt_parse_int(str_to_addr(s));
}

fn fs_rt_str_to_bool(&s: string) -> bool {
    if (fs_rt_str_eq(s, "true")) {
        return true;
    }
    return fs_rt_str_eq(s, "1");
}

fn fs_rt_str_to_f64(&s: string) -> float64 {
    addr: uint64 = str_to_addr(s);
    if (addr == 0u64) {
        return 0.0;
    }
    i: uint64 = 0u64;
    while (true) {
        c: uint8 = mem_load_u8(addr + i);
        if (c == 32u8 || (c >= 9u8 && c <= 13u8)) {
            i = i + 1u64;
        } else {
            break;
        }
    }
    negative: bool = false;
    sign: uint8 = mem_load_u8(addr + i);
    if (sign == 45u8) {
        negative = true;
        i = i + 1u64;
    } else if (sign == 43u8) {
        i = i + 1u64;
    }
    value: float64 = 0.0;
    while (true) {
        c: uint8 = mem_load_u8(addr + i);
        if (c < 48u8 || c > 57u8) {
            break;
        }
        value = value * 10.0 + (((c - 48u8) as int32) as float64);
        i = i + 1u64;
    }
    if (mem_load_u8(addr + i) == 46u8) { // '.'
        i = i + 1u64;
        scale: float64 = 0.1;
        while (true) {
            c: uint8 = mem_load_u8(addr + i);
            if (c < 48u8 || c > 57u8) {
                break;
            }
            value = value + (((c - 48u8) as int32) as float64) * scale;
            scale = scale / 10.0;
            i = i + 1u64;
        }
    }
    // Exponent part (e/E).
    e: uint8 = mem_load_u8(addr + i);
    if (e == 101u8 || e == 69u8) {
        i = i + 1u64;
        exp_negative: bool = false;
        esign: uint8 = mem_load_u8(addr + i);
        if (esign == 45u8) {
            exp_negative = true;
            i = i + 1u64;
        } else if (esign == 43u8) {
            i = i + 1u64;
        }
        exponent: int32 = 0;
        while (true) {
            c: uint8 = mem_load_u8(addr + i);
            if (c < 48u8 || c > 57u8) {
                break;
            }
            exponent = exponent * 10 + ((c - 48u8) as int32);
            i = i + 1u64;
        }
        while (exponent > 0) {
            if (exp_negative) {
                value = value / 10.0;
            } else {
                value = value * 10.0;
            }
            exponent = exponent - 1;
        }
    }
    if (negative) {
        return -value;
    }
    return value;
}

// ---- stdout ----

fn fs_rt_stdout(&s: string) -> void {
    addr: uint64 = str_to_addr(s);
    if (addr == 0u64) {
        return;
    }
    len: uint64 = rt_str_len_addr(addr);
    if (len == 0u64) {
        return;
    }
    handle: uint64 = win_get_std_handle(-11); // STD_OUTPUT_HANDLE
    state: uint64 = rt_state();
    win_write_file(handle, addr, len as uint32, state + 32u64, 0u64);
}

// ---- float -> string conversions (exact binary-to-decimal) ----
//
// A double is mant * 2^bexp exactly. Binary fractions have finite decimal
// expansions, so we compute the exact decimal digits with a fixed-point
// digit array: start from the mantissa digits and double (bexp > 0) or
// halve (bexp < 0) the whole array. This matches printf output without
// approximation drift.
//
// Work buffer layout: [0]=int_len u64, [8]=frac_len u64, digits as bytes;
// integer digits end just before ANCHOR (most significant first),
// fraction digits start at ANCHOR. ANCHOR offset = 16 + 340.

fn rt_f64_decimal(mant: uint64, bexp: int32) -> uint64 {
    buf: uint64 = rt_raw_alloc(16u64 + 340u64 + 1090u64);
    anchor: uint64 = buf + 356u64;
    int_len: uint64 = 0u64;
    m: uint64 = mant;
    while (m > 0u64) {
        int_len = int_len + 1u64;
        mem_store_u8(anchor - int_len, (m % 10u64) as uint8);
        m = m / 10u64;
    }
    frac_len: uint64 = 0u64;
    while (bexp > 0) {
        carry: uint64 = 0u64;
        i: uint64 = frac_len;
        while (i > 0u64) {
            idx: uint64 = anchor + i - 1u64;
            d: uint64 = (mem_load_u8(idx) as uint64) * 2u64 + carry;
            mem_store_u8(idx, (d % 10u64) as uint8);
            carry = d / 10u64;
            i = i - 1u64;
        }
        while (frac_len > 0u64 && mem_load_u8(anchor + frac_len - 1u64) == 0u8) {
            frac_len = frac_len - 1u64;
        }
        j: uint64 = 0u64;
        while (j < int_len) {
            idx2: uint64 = anchor - 1u64 - j;
            d2: uint64 = (mem_load_u8(idx2) as uint64) * 2u64 + carry;
            mem_store_u8(idx2, (d2 % 10u64) as uint8);
            carry = d2 / 10u64;
            j = j + 1u64;
        }
        while (carry > 0u64) {
            int_len = int_len + 1u64;
            mem_store_u8(anchor - int_len, (carry % 10u64) as uint8);
            carry = carry / 10u64;
        }
        bexp = bexp - 1;
    }
    while (bexp < 0) {
        rem: uint64 = 0u64;
        i2: uint64 = 0u64;
        while (i2 < int_len) {
            idx3: uint64 = anchor - int_len + i2;
            cur: uint64 = rem * 10u64 + (mem_load_u8(idx3) as uint64);
            mem_store_u8(idx3, (cur / 2u64) as uint8);
            rem = cur % 2u64;
            i2 = i2 + 1u64;
        }
        while (int_len > 0u64 && mem_load_u8(anchor - int_len) == 0u8) {
            int_len = int_len - 1u64;
        }
        k: uint64 = 0u64;
        while (k < frac_len) {
            idx4: uint64 = anchor + k;
            cur2: uint64 = rem * 10u64 + (mem_load_u8(idx4) as uint64);
            mem_store_u8(idx4, (cur2 / 2u64) as uint8);
            rem = cur2 % 2u64;
            k = k + 1u64;
        }
        if (rem > 0u64) {
            mem_store_u8(anchor + frac_len, 5u8);
            frac_len = frac_len + 1u64;
        }
        bexp = bexp + 1;
    }
    mem_store_u64(buf, int_len);
    mem_store_u64(buf + 8u64, frac_len);
    return buf;
}

// Round the digit array at `keep` fraction digits (round half to even).
// Returns the new int_len (rounding can carry into a new leading digit).
fn rt_dec_round_frac(buf: uint64, keep: uint64) -> uint64 {
    anchor: uint64 = buf + 356u64;
    int_len: uint64 = mem_load_u64(buf);
    frac_len: uint64 = mem_load_u64(buf + 8u64);
    if (frac_len <= keep) {
        return int_len;
    }
    next: uint8 = mem_load_u8(anchor + keep);
    round_up: bool = false;
    if (next > 5u8) {
        round_up = true;
    } else if (next == 5u8) {
        more: bool = false;
        i: uint64 = keep + 1u64;
        while (i < frac_len) {
            if (mem_load_u8(anchor + i) != 0u8) {
                more = true;
                break;
            }
            i = i + 1u64;
        }
        if (more) {
            round_up = true;
        } else {
            // Exact tie: round half to even.
            prev: uint8 = 0u8;
            if (keep > 0u64) {
                prev = mem_load_u8(anchor + keep - 1u64);
            } else if (int_len > 0u64) {
                prev = mem_load_u8(anchor - 1u64);
            }
            if (prev % 2u8 == 1u8) {
                round_up = true;
            }
        }
    }
    if (round_up) {
        j: uint64 = keep;
        carry: bool = true;
        while (j > 0u64 && carry) {
            idx: uint64 = anchor + j - 1u64;
            d: uint8 = mem_load_u8(idx) + 1u8;
            if (d == 10u8) {
                mem_store_u8(idx, 0u8);
            } else {
                mem_store_u8(idx, d);
                carry = false;
            }
            j = j - 1u64;
        }
        k: uint64 = 0u64;
        while (k < int_len && carry) {
            idx2: uint64 = anchor - 1u64 - k;
            d2: uint8 = mem_load_u8(idx2) + 1u8;
            if (d2 == 10u8) {
                mem_store_u8(idx2, 0u8);
            } else {
                mem_store_u8(idx2, d2);
                carry = false;
            }
            k = k + 1u64;
        }
        if (carry) {
            int_len = int_len + 1u64;
            mem_store_u8(anchor - int_len, 1u8);
            mem_store_u64(buf, int_len);
        }
    }
    mem_store_u64(buf + 8u64, keep);
    return int_len;
}

// printf "%f" semantics: fixed notation, 6 fractional digits.
fn fs_rt_f64_to_str(value: float64) -> string {
    bits: uint64 = f64_bits(value);
    negative: bool = bits >= 9223372036854775808u64;
    exp_field: uint64 = (bits / 4503599627370496u64) % 2048u64;
    mant_field: uint64 = bits % 4503599627370496u64;
    if (exp_field == 2047u64) {
        if (mant_field != 0u64) {
            return fs_rt_str_dup("nan");
        }
        if (negative) {
            return fs_rt_str_dup("-inf");
        }
        return fs_rt_str_dup("inf");
    }
    mant: uint64 = mant_field;
    bexp: int32 = -1074;
    if (exp_field != 0u64) {
        mant = mant_field + 4503599627370496u64;
        bexp = (exp_field as int32) - 1075;
    }
    dec: uint64 = rt_f64_decimal(mant, bexp);
    anchor: uint64 = dec + 356u64;
    int_len: uint64 = rt_dec_round_frac(dec, 6u64);
    frac_len: uint64 = mem_load_u64(dec + 8u64);

    out_len: uint64 = int_len + 8u64;
    if (int_len == 0u64) {
        out_len = out_len + 1u64;
    }
    if (negative) {
        out_len = out_len + 1u64;
    }
    out: uint64 = rt_raw_alloc(out_len + 1u64);
    rt_reg_add(out);
    pos: uint64 = 0u64;
    if (negative) {
        mem_store_u8(out + pos, 45u8);
        pos = pos + 1u64;
    }
    if (int_len == 0u64) {
        mem_store_u8(out + pos, 48u8);
        pos = pos + 1u64;
    } else {
        i: uint64 = 0u64;
        while (i < int_len) {
            mem_store_u8(out + pos, mem_load_u8(anchor - int_len + i) + 48u8);
            pos = pos + 1u64;
            i = i + 1u64;
        }
    }
    mem_store_u8(out + pos, 46u8);
    pos = pos + 1u64;
    f: uint64 = 0u64;
    while (f < 6u64) {
        d: uint8 = 0u8;
        if (f < frac_len) {
            d = mem_load_u8(anchor + f);
        }
        mem_store_u8(out + pos, d + 48u8);
        pos = pos + 1u64;
        f = f + 1u64;
    }
    mem_store_u8(out + pos, 0u8);
    win_heap_free(rt_heap(), 0u32, dec);
    return addr_to_str(out);
}

fn fs_rt_f32_to_str(fvalue: float32) -> string {
    return fs_rt_f64_to_str(fvalue as float64);
}

// printf "%g" semantics: 6 significant digits, fixed or scientific,
// trailing zeros stripped.
fn fs_rt_f64_to_repr(value: float64) -> string {
    bits: uint64 = f64_bits(value);
    negative: bool = bits >= 9223372036854775808u64;
    exp_field: uint64 = (bits / 4503599627370496u64) % 2048u64;
    mant_field: uint64 = bits % 4503599627370496u64;
    if (exp_field == 2047u64) {
        if (mant_field != 0u64) {
            return fs_rt_str_dup("nan");
        }
        if (negative) {
            return fs_rt_str_dup("-inf");
        }
        return fs_rt_str_dup("inf");
    }
    if (exp_field == 0u64 && mant_field == 0u64) {
        if (negative) {
            return fs_rt_str_dup("-0");
        }
        return fs_rt_str_dup("0");
    }
    mant: uint64 = mant_field;
    bexp: int32 = -1074;
    if (exp_field != 0u64) {
        mant = mant_field + 4503599627370496u64;
        bexp = (exp_field as int32) - 1075;
    }
    dec: uint64 = rt_f64_decimal(mant, bexp);
    anchor: uint64 = dec + 356u64;
    int_len: uint64 = mem_load_u64(dec);
    frac_len: uint64 = mem_load_u64(dec + 8u64);

    // Decimal exponent of the leading significant digit.
    exp10: int32 = 0;
    sig_start_frac: uint64 = 0u64;
    if (int_len > 0u64) {
        exp10 = (int_len as int32) - 1;
    } else {
        while (sig_start_frac < frac_len && mem_load_u8(anchor + sig_start_frac) == 0u8) {
            sig_start_frac = sig_start_frac + 1u64;
        }
        exp10 = -((sig_start_frac as int32) + 1);
    }

    // Collect 6 significant digits (plus lookahead for rounding).
    digits: uint64 = rt_raw_alloc(16u64);
    ndig: uint64 = 0u64;
    ii: uint64 = 0u64;
    more_nonzero: bool = false;
    next_digit: uint8 = 0u8;
    have_next: bool = false;
    if (int_len > 0u64) {
        while (ii < int_len) {
            d: uint8 = mem_load_u8(anchor - int_len + ii);
            if (ndig < 6u64) {
                mem_store_u8(digits + ndig, d);
                ndig = ndig + 1u64;
            } else if (!have_next) {
                next_digit = d;
                have_next = true;
            } else if (d != 0u8) {
                more_nonzero = true;
            }
            ii = ii + 1u64;
        }
        jj: uint64 = 0u64;
        while (jj < frac_len) {
            d2: uint8 = mem_load_u8(anchor + jj);
            if (ndig < 6u64) {
                mem_store_u8(digits + ndig, d2);
                ndig = ndig + 1u64;
            } else if (!have_next) {
                next_digit = d2;
                have_next = true;
            } else if (d2 != 0u8) {
                more_nonzero = true;
            }
            jj = jj + 1u64;
        }
    } else {
        kk: uint64 = sig_start_frac;
        while (kk < frac_len) {
            d3: uint8 = mem_load_u8(anchor + kk);
            if (ndig < 6u64) {
                mem_store_u8(digits + ndig, d3);
                ndig = ndig + 1u64;
            } else if (!have_next) {
                next_digit = d3;
                have_next = true;
            } else if (d3 != 0u8) {
                more_nonzero = true;
            }
            kk = kk + 1u64;
        }
    }
    win_heap_free(rt_heap(), 0u32, dec);
    while (ndig < 6u64) {
        mem_store_u8(digits + ndig, 0u8);
        ndig = ndig + 1u64;
    }

    // Round half to even at 6 significant digits.
    round_up: bool = false;
    if (have_next) {
        if (next_digit > 5u8) {
            round_up = true;
        } else if (next_digit == 5u8) {
            if (more_nonzero) {
                round_up = true;
            } else if (mem_load_u8(digits + 5u64) % 2u8 == 1u8) {
                round_up = true;
            }
        }
    }
    if (round_up) {
        rr: uint64 = 6u64;
        carry: bool = true;
        while (rr > 0u64 && carry) {
            d4: uint8 = mem_load_u8(digits + rr - 1u64) + 1u8;
            if (d4 == 10u8) {
                mem_store_u8(digits + rr - 1u64, 0u8);
            } else {
                mem_store_u8(digits + rr - 1u64, d4);
                carry = false;
            }
            rr = rr - 1u64;
        }
        if (carry) {
            // 999999 -> 100000 with exponent bump.
            mem_store_u8(digits, 1u8);
            zz: uint64 = 1u64;
            while (zz < 6u64) {
                mem_store_u8(digits + zz, 0u8);
                zz = zz + 1u64;
            }
            exp10 = exp10 + 1;
        }
    }

    // Strip trailing zeros.
    sig: uint64 = 6u64;
    while (sig > 1u64 && mem_load_u8(digits + sig - 1u64) == 0u8) {
        sig = sig - 1u64;
    }

    out: uint64 = rt_raw_alloc(48u64);
    rt_reg_add(out);
    pos: uint64 = 0u64;
    if (negative) {
        mem_store_u8(out + pos, 45u8);
        pos = pos + 1u64;
    }

    if (exp10 < -4 || exp10 >= 6) {
        // Scientific: d[.ddddd]e[+-]XX
        mem_store_u8(out + pos, mem_load_u8(digits) + 48u8);
        pos = pos + 1u64;
        if (sig > 1u64) {
            mem_store_u8(out + pos, 46u8);
            pos = pos + 1u64;
            s: uint64 = 1u64;
            while (s < sig) {
                mem_store_u8(out + pos, mem_load_u8(digits + s) + 48u8);
                pos = pos + 1u64;
                s = s + 1u64;
            }
        }
        mem_store_u8(out + pos, 101u8);
        pos = pos + 1u64;
        e: int32 = exp10;
        if (e < 0) {
            mem_store_u8(out + pos, 45u8);
            e = -e;
        } else {
            mem_store_u8(out + pos, 43u8);
        }
        pos = pos + 1u64;
        if (e >= 100) {
            mem_store_u8(out + pos, (((e / 100) % 10) as uint8) + 48u8);
            pos = pos + 1u64;
        }
        mem_store_u8(out + pos, (((e / 10) % 10) as uint8) + 48u8);
        pos = pos + 1u64;
        mem_store_u8(out + pos, ((e % 10) as uint8) + 48u8);
        pos = pos + 1u64;
    } else if (exp10 >= 0) {
        // Fixed, point inside or right of the digits.
        int_digits: uint64 = (exp10 as uint64) + 1u64;
        p2: uint64 = 0u64;
        while (p2 < int_digits) {
            d5: uint8 = 0u8;
            if (p2 < sig) {
                d5 = mem_load_u8(digits + p2);
            }
            mem_store_u8(out + pos, d5 + 48u8);
            pos = pos + 1u64;
            p2 = p2 + 1u64;
        }
        if (sig > int_digits) {
            mem_store_u8(out + pos, 46u8);
            pos = pos + 1u64;
            p3: uint64 = int_digits;
            while (p3 < sig) {
                mem_store_u8(out + pos, mem_load_u8(digits + p3) + 48u8);
                pos = pos + 1u64;
                p3 = p3 + 1u64;
            }
        }
    } else {
        // Fixed, 0.0..ddd
        mem_store_u8(out + pos, 48u8);
        pos = pos + 1u64;
        mem_store_u8(out + pos, 46u8);
        pos = pos + 1u64;
        zeros: int32 = -exp10 - 1;
        while (zeros > 0) {
            mem_store_u8(out + pos, 48u8);
            pos = pos + 1u64;
            zeros = zeros - 1;
        }
        p4: uint64 = 0u64;
        while (p4 < sig) {
            mem_store_u8(out + pos, mem_load_u8(digits + p4) + 48u8);
            pos = pos + 1u64;
            p4 = p4 + 1u64;
        }
    }
    mem_store_u8(out + pos, 0u8);
    win_heap_free(rt_heap(), 0u32, digits);
    return addr_to_str(out);
}

fn fs_rt_f32_to_repr(fvalue: float32) -> string {
    return fs_rt_f64_to_repr(fvalue as float64);
}

// ---- process arguments (GetCommandLineA + Windows quoting rules) ----

fn rt_args_parse() -> void {
    state: uint64 = rt_state();
    if (mem_load_u64(state + 48u64) != 0u64) {
        return;
    }
    cmd: uint64 = win_get_command_line_a();
    cmd_len: uint64 = rt_str_len_addr(cmd);
    // Worst case every other char is an arg: cap argv at len/2 + 2.
    argv: uint64 = rt_raw_alloc((cmd_len / 2u64 + 2u64) * 8u64);
    argc: uint64 = 0u64;
    i: uint64 = 0u64;
    scratch: uint64 = rt_raw_alloc(cmd_len + 1u64);
    while (i < cmd_len) {
        // Skip whitespace between arguments.
        while (i < cmd_len) {
            c: uint8 = mem_load_u8(cmd + i);
            if (c == 32u8 || c == 9u8) {
                i = i + 1u64;
            } else {
                break;
            }
        }
        if (i >= cmd_len) {
            break;
        }
        out_len: uint64 = 0u64;
        in_quotes: bool = false;
        while (i < cmd_len) {
            c: uint8 = mem_load_u8(cmd + i);
            if (!in_quotes && (c == 32u8 || c == 9u8)) {
                break;
            }
            if (c == 92u8) { // backslash run
                n_bs: uint64 = 0u64;
                while (i < cmd_len && mem_load_u8(cmd + i) == 92u8) {
                    n_bs = n_bs + 1u64;
                    i = i + 1u64;
                }
                followed_by_quote: bool = i < cmd_len && mem_load_u8(cmd + i) == 34u8;
                emit: uint64 = n_bs;
                if (followed_by_quote) {
                    emit = n_bs / 2u64;
                }
                b: uint64 = 0u64;
                while (b < emit) {
                    mem_store_u8(scratch + out_len, 92u8);
                    out_len = out_len + 1u64;
                    b = b + 1u64;
                }
                if (followed_by_quote && n_bs % 2u64 == 1u64) {
                    mem_store_u8(scratch + out_len, 34u8);
                    out_len = out_len + 1u64;
                    i = i + 1u64;
                }
            } else if (c == 34u8) {
                in_quotes = !in_quotes;
                i = i + 1u64;
            } else {
                mem_store_u8(scratch + out_len, c);
                out_len = out_len + 1u64;
                i = i + 1u64;
            }
        }
        arg: uint64 = rt_raw_alloc(out_len + 1u64);
        if (out_len > 0u64) {
            mem_copy(arg, scratch, out_len);
        }
        mem_store_u8(arg + out_len, 0u8);
        mem_store_u64(argv + argc * 8u64, arg);
        argc = argc + 1u64;
    }
    win_heap_free(rt_heap(), 0u32, scratch);
    mem_store_u64(state + 40u64, argc);
    mem_store_u64(state + 48u64, argv);
}

fn fs_rt_argc() -> int32 {
    rt_args_parse();
    state: uint64 = rt_state();
    return mem_load_u64(state + 40u64) as int32;
}

fn fs_rt_argv_at(index: int32) -> string {
    rt_args_parse();
    state: uint64 = rt_state();
    argc: uint64 = mem_load_u64(state + 40u64);
    if (index < 0 || (index as uint64) >= argc) {
        return fs_rt_str_dup("");
    }
    argv: uint64 = mem_load_u64(state + 48u64);
    arg: uint64 = mem_load_u64(argv + (index as uint64) * 8u64);
    view: string = addr_to_str(arg);
    result: string = fs_rt_str_dup(view);
    return result;
}

// ---- syscalls over kernel32 (fd table maps small ints to HANDLEs) ----

copyable class SyscallResult {
    status: int32;
    data: string;
}

fn rt_fd_table() -> uint64 {
    state: uint64 = rt_state();
    table: uint64 = mem_load_u64(state + 56u64);
    if (table == 0u64) {
        table = rt_raw_alloc(64u64 * 8u64);
        mem_store_u64(state + 56u64, table);
    }
    return table;
}

fn rt_fd_register(handle: uint64) -> int32 {
    table: uint64 = rt_fd_table();
    i: uint64 = 0u64;
    while (i < 64u64) {
        if (mem_load_u64(table + i * 8u64) == 0u64) {
            mem_store_u64(table + i * 8u64, handle);
            return (i as int32) + 3;
        }
        i = i + 1u64;
    }
    return -24; // -EMFILE
}

fn rt_fd_handle(fd: int32) -> uint64 {
    if (fd == 0) {
        return win_get_std_handle(-10);
    }
    if (fd == 1) {
        return win_get_std_handle(-11);
    }
    if (fd == 2) {
        return win_get_std_handle(-12);
    }
    if (fd < 3 || fd >= 67) {
        return 0u64;
    }
    table: uint64 = rt_fd_table();
    return mem_load_u64(table + ((fd - 3) as uint64) * 8u64);
}

fn rt_fd_release(fd: int32) -> void {
    if (fd < 3 || fd >= 67) {
        return;
    }
    table: uint64 = rt_fd_table();
    mem_store_u64(table + ((fd - 3) as uint64) * 8u64, 0u64);
}

// Map a GetLastError code to a negated errno-style status (legacy ABI).
fn rt_win_err() -> int32 {
    err: uint32 = win_get_last_error();
    if (err == 2u32 || err == 3u32) {
        return -2; // ENOENT
    }
    if (err == 5u32) {
        return -13; // EACCES
    }
    if (err == 183u32) {
        return -17; // EEXIST
    }
    if (err == 17u32) {
        return -18; // EXDEV
    }
    if (err == 32u32) {
        return -16; // EBUSY (sharing violation)
    }
    return -(err as int32);
}

fn fs_rt_syscall_open(&path: string, &mode: string) -> SyscallResult {
    access: uint32 = 0u32;
    disposition: uint32 = 0u32;
    append: bool = false;
    if (fs_rt_str_eq(mode, "r")) {
        access = 2147483648u32;       // GENERIC_READ
        disposition = 3u32;           // OPEN_EXISTING
    } else if (fs_rt_str_eq(mode, "w")) {
        access = 1073741824u32;       // GENERIC_WRITE
        disposition = 2u32;           // CREATE_ALWAYS
    } else if (fs_rt_str_eq(mode, "a")) {
        access = 1073741824u32;
        disposition = 4u32;           // OPEN_ALWAYS
        append = true;
    } else if (fs_rt_str_eq(mode, "r+")) {
        access = 3221225472u32;       // GENERIC_READ | GENERIC_WRITE
        disposition = 3u32;
    } else if (fs_rt_str_eq(mode, "w+")) {
        access = 3221225472u32;
        disposition = 2u32;
    } else {
        return SyscallResult(-22, ""); // -EINVAL
    }
    handle: uint64 = win_create_file_a(
        str_to_addr(path), access, 3u32, 0u64, disposition, 128u32, 0u64
    );
    if (handle == 18446744073709551615u64) { // INVALID_HANDLE_VALUE
        return SyscallResult(rt_win_err(), "");
    }
    if (append) {
        win_set_file_pointer(handle, 0, 0u64, 2u32); // FILE_END
    }
    fd: int32 = rt_fd_register(handle);
    if (fd < 0) {
        win_close_handle(handle);
        return SyscallResult(fd, "");
    }
    return SyscallResult(fd, "");
}

fn fs_rt_syscall_read(fd: int32, n: int32) -> SyscallResult {
    if (n <= 0) {
        return SyscallResult(-22, "");
    }
    handle: uint64 = rt_fd_handle(fd);
    if (handle == 0u64) {
        return SyscallResult(-9, ""); // -EBADF
    }
    raw: uint64 = rt_raw_alloc((n as uint64) + 1u64);
    state: uint64 = rt_state();
    ok: int32 = win_read_file(handle, raw, n as uint32, state + 32u64, 0u64);
    if (ok == 0) {
        win_heap_free(rt_heap(), 0u32, raw);
        return SyscallResult(rt_win_err(), "");
    }
    got: uint64 = mem_load_u64(state + 32u64) % 4294967296u64;
    // Text-mode semantics (legacy parity): CRLF -> LF.
    dst: uint64 = rt_raw_alloc(got + 1u64);
    rt_reg_add(dst);
    src_i: uint64 = 0u64;
    dst_i: uint64 = 0u64;
    while (src_i < got) {
        c: uint8 = mem_load_u8(raw + src_i);
        if (c == 13u8 && src_i + 1u64 < got && mem_load_u8(raw + src_i + 1u64) == 10u8) {
            src_i = src_i + 1u64;
        } else {
            mem_store_u8(dst + dst_i, c);
            dst_i = dst_i + 1u64;
            src_i = src_i + 1u64;
        }
    }
    mem_store_u8(dst + dst_i, 0u8);
    win_heap_free(rt_heap(), 0u32, raw);
    return SyscallResult(dst_i as int32, addr_to_str(dst));
}

fn fs_rt_syscall_write(fd: int32, &buf: string) -> SyscallResult {
    src: uint64 = str_to_addr(buf);
    if (src == 0u64) {
        return SyscallResult(-22, "");
    }
    handle: uint64 = rt_fd_handle(fd);
    if (handle == 0u64) {
        return SyscallResult(-9, "");
    }
    len: uint64 = rt_str_len_addr(src);
    // Text-mode semantics (legacy parity): LF -> CRLF on disk; the
    // returned count is the pre-translation length.
    expanded: uint64 = rt_raw_alloc(len * 2u64 + 1u64);
    src_j: uint64 = 0u64;
    out_j: uint64 = 0u64;
    while (src_j < len) {
        c: uint8 = mem_load_u8(src + src_j);
        if (c == 10u8) {
            mem_store_u8(expanded + out_j, 13u8);
            out_j = out_j + 1u64;
        }
        mem_store_u8(expanded + out_j, c);
        out_j = out_j + 1u64;
        src_j = src_j + 1u64;
    }
    state: uint64 = rt_state();
    ok: int32 = win_write_file(handle, expanded, out_j as uint32, state + 32u64, 0u64);
    win_heap_free(rt_heap(), 0u32, expanded);
    if (ok == 0) {
        return SyscallResult(rt_win_err(), "");
    }
    return SyscallResult(len as int32, "");
}

fn fs_rt_syscall_close(fd: int32) -> SyscallResult {
    handle: uint64 = rt_fd_handle(fd);
    if (handle == 0u64 || fd < 3) {
        return SyscallResult(-9, "");
    }
    rt_fd_release(fd);
    ok: int32 = win_close_handle(handle);
    if (ok == 0) {
        return SyscallResult(rt_win_err(), "");
    }
    return SyscallResult(0, "");
}

fn fs_rt_syscall_remove(&path: string) -> SyscallResult {
    ok: int32 = win_delete_file_a(str_to_addr(path));
    if (ok == 0) {
        return SyscallResult(rt_win_err(), "");
    }
    return SyscallResult(0, "");
}

fn fs_rt_syscall_rename(&old_path: string, &new_path: string) -> SyscallResult {
    // C rename() on Windows fails when the destination exists.
    ok: int32 = win_move_file_ex_a(str_to_addr(old_path), str_to_addr(new_path), 0u32);
    if (ok == 0) {
        return SyscallResult(rt_win_err(), "");
    }
    return SyscallResult(0, "");
}

fn fs_rt_syscall_move(&src_path: string, &dst_path: string) -> SyscallResult {
    // Rename first; fall back to copy + remove for cross-device moves
    // (legacy contract).
    ok: int32 = win_move_file_ex_a(str_to_addr(src_path), str_to_addr(dst_path), 0u32);
    if (ok != 0) {
        return SyscallResult(0, "");
    }
    err: int32 = rt_win_err();
    if (err != -18) { // not EXDEV
        return SyscallResult(err, "");
    }
    copied: int32 = win_copy_file_a(str_to_addr(src_path), str_to_addr(dst_path), 0);
    if (copied == 0) {
        return SyscallResult(rt_win_err(), "");
    }
    removed: int32 = win_delete_file_a(str_to_addr(src_path));
    if (removed == 0) {
        rm_err: int32 = rt_win_err();
        win_delete_file_a(str_to_addr(dst_path));
        return SyscallResult(rm_err, "");
    }
    return SyscallResult(0, "");
}
