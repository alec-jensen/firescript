// firescript std.fs library

directive enable_syscalls;

export class FileResult {
    status: int32;
    data: string;

    fn FileResult(status: int32, data: string) {
        this.status = status;
        this.data = data;
    }

    fn ok(&this) -> bool {
        return this.status >= 0;
    }

    fn err_code(&this) -> int32 {
        if (this.status < 0) {
            return -this.status;
        }
        return 0;
    }

    fn result_status(&this) -> int32 {
        return this.status;
    }

    fn result_data(&this) -> string {
        return "" + this.data;
    }
}

export class File {
    path: string;

    fn File(&mut this, path: string) {
        this.path = path;
    }

    fn read(&this) -> FileResult {
        return _read_internal(this.path, -1);
    }

    fn readBytes(&this, bytes: int32) -> FileResult {
        return _read_internal(this.path, bytes);
    }

    fn writeAll(&this, data: string) -> FileResult {
        result: FileResult = _write_mode(this.path, data, "w");
        drop(data);
        return result;
    }

    fn appendAll(&this, data: string) -> FileResult {
        result: FileResult = _write_mode(this.path, data, "a");
        drop(data);
        return result;
    }

    fn exists(&this) -> bool {
        open_result: SyscallResult = syscall_open(this.path, "r");
        if (open_result.status < 0) {
            return false;
        }

        close_result: SyscallResult = syscall_close(open_result.status);
        return close_result.status >= 0;
    }

    fn remove(&this) -> FileResult {
        result: SyscallResult = syscall_remove(this.path);
        return FileResult(result.status, "");
    }

    fn renameTo(&mut this, new_path: string) -> FileResult {
        result: SyscallResult = syscall_rename(this.path, new_path);
        if (result.status >= 0) {
            this.path = new_path;
        } else {
            drop(new_path);
        }
        return FileResult(result.status, "");
    }

    fn moveTo(&mut this, dst_path: string) -> FileResult {
        result: SyscallResult = syscall_move(this.path, dst_path);
        if (result.status >= 0) {
            this.path = dst_path;
        } else {
            drop(dst_path);
        }
        return FileResult(result.status, "");
    }
}

fn _read_internal(&path: string, max_bytes: int32) -> FileResult {
    if (max_bytes < -1) {
        return FileResult(-22, "");
    }

    if (max_bytes == 0) {
        return FileResult(0, "");
    }

    open_result: SyscallResult = syscall_open(path, "r");
    if (open_result.status < 0) {
        return FileResult(open_result.status, "");
    }

    fd: int32 = open_result.status;
    content: string = "";
    total: int32 = 0;

    if (max_bytes == -1) {
        while (true) {
            read_result: SyscallResult = syscall_read(fd, 4096);
            if (read_result.status < 0) {
                syscall_close(fd);
                return FileResult(read_result.status, "");
            }
            if (read_result.status == 0) {
                break;
            }
            total = total + read_result.status;
            content = content + read_result.data;
        }
    } else {
        remaining: int32 = max_bytes;
        while (remaining > 0) {
            request: int32 = remaining;
            if (request > 4096) {
                request = 4096;
            }

            read_result: SyscallResult = syscall_read(fd, request);
            if (read_result.status < 0) {
                syscall_close(fd);
                return FileResult(read_result.status, "");
            }
            if (read_result.status == 0) {
                break;
            }

            total = total + read_result.status;
            remaining = remaining - read_result.status;
            content = content + read_result.data;
        }
    }

    close_result: SyscallResult = syscall_close(fd);
    if (close_result.status < 0) {
        return FileResult(close_result.status, "");
    }

    return FileResult(total, content);
}

fn _write_mode(&path: string, &data: string, &mode: string) -> FileResult {
    open_result: SyscallResult = syscall_open(path, mode);
    if (open_result.status < 0) {
        return FileResult(open_result.status, "");
    }

    fd: int32 = open_result.status;
    write_result: SyscallResult = syscall_write(fd, data);
    close_result: SyscallResult = syscall_close(fd);

    if (write_result.status < 0) {
        return FileResult(write_result.status, "");
    }
    if (close_result.status < 0) {
        return FileResult(close_result.status, "");
    }

    return FileResult(write_result.status, "");
}

