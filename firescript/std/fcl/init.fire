// firescript std.fcl package entrypoint

// String intrinsics used by this module are directive-gated.
directive enable_process_args;

export class FclLexTokenResult {
	status: int32;
	kind: string;
	lexeme: string;
	start: int32;
	end: int32;
	next_index: int32;

	fn FclLexTokenResult(status: int32, kind: string, lexeme: string, start: int32, end: int32, next_index: int32) {
		this.status = status;
		this.kind = kind;
		this.lexeme = lexeme;
		this.start = start;
		this.end = end;
		this.next_index = next_index;
	}
}

fn _len(&value: string) -> int32 {
	return str_length(value);
}

fn _char_at(&value: string, index: int32) -> string {
	return str_char_at(value, index);
}

fn _slice(&value: string, start: int32, end: int32) -> string {
	return str_slice(value, start, end);
}

fn _is_ws(&ch: string) -> bool {
	if (ch == " ") {
		return true;
	}
	if (ch == "\t") {
		return true;
	}
	if (ch == "\n") {
		return true;
	}
	if (ch == "\r") {
		return true;
	}
	return false;
}

fn _is_digit(&ch: string) -> bool {
	return str_index_of("0123456789", ch) >= 0;
}

fn _is_alpha(&ch: string) -> bool {
	if (str_index_of("abcdefghijklmnopqrstuvwxyz", ch) >= 0) {
		return true;
	}
	if (str_index_of("ABCDEFGHIJKLMNOPQRSTUVWXYZ", ch) >= 0) {
		return true;
	}
	if (ch == "_") {
		return true;
	}
	return false;
}

fn _is_ident_continue(&ch: string) -> bool {
	return _is_alpha(ch) || _is_digit(ch);
}

fn _single(&kind: string, &text: string, start: int32, next: int32) -> FclLexTokenResult {
	return FclLexTokenResult(0, "" + kind, "" + text, start, next, next);
}

export fn next_token(&source: string, index: int32) -> FclLexTokenResult {
	n: int32 = _len(source);
	i: int32 = index;

	if (i < 0) {
		i = 0;
	}

	while (i < n) {
		ch: string = _char_at(source, i);
		if (_is_ws(ch) == false) {
			break;
		}
		i = i + 1;
	}

	if (i >= n) {
		return FclLexTokenResult(0, "eof", "", i, i, i);
	}

	ch: string = _char_at(source, i);

	if (ch == "{") {
		tok: FclLexTokenResult = _single("lbrace", ch, i, i + 1);
		drop(ch);
		return tok;
	}
	if (ch == "}") {
		tok: FclLexTokenResult = _single("rbrace", ch, i, i + 1);
		drop(ch);
		return tok;
	}
	if (ch == "[") {
		tok: FclLexTokenResult = _single("lbracket", ch, i, i + 1);
		drop(ch);
		return tok;
	}
	if (ch == "]") {
		tok: FclLexTokenResult = _single("rbracket", ch, i, i + 1);
		drop(ch);
		return tok;
	}
	if (ch == ":") {
		tok: FclLexTokenResult = _single("colon", ch, i, i + 1);
		drop(ch);
		return tok;
	}
	if (ch == ",") {
		tok: FclLexTokenResult = _single("comma", ch, i, i + 1);
		drop(ch);
		return tok;
	}
	if (ch == "=") {
		tok: FclLexTokenResult = _single("assign", ch, i, i + 1);
		drop(ch);
		return tok;
	}

	if (ch == "\"") {
		j: int32 = i + 1;
		while (j < n) {
			c: string = _char_at(source, j);
			if (c == "\"") {
				return FclLexTokenResult(0, "string", _slice(source, i + 1, j), i, j + 1, j + 1);
			}
			j = j + 1;
		}
		return FclLexTokenResult(-84, "invalid", "unterminated_string", i, n, n);
	}

	if (ch == "-" || _is_digit(ch)) {
		j: int32 = i;
		if (ch == "-") {
			j = j + 1;
			if (j >= n) {
				return FclLexTokenResult(-84, "invalid", "-", i, i + 1, i + 1);
			}
			next_ch: string = _char_at(source, j);
			if (_is_digit(next_ch) == false) {
				return FclLexTokenResult(-84, "invalid", "-", i, i + 1, i + 1);
			}
		}
		while (j < n) {
			c: string = _char_at(source, j);
			if (_is_digit(c) == false) {
				break;
			}
			j = j + 1;
		}
		tok: FclLexTokenResult = FclLexTokenResult(0, "int32", _slice(source, i, j), i, j, j);
		drop(ch);
		return tok;
	}

	if (_is_alpha(ch)) {
		j: int32 = i + 1;
		while (j < n) {
			c: string = _char_at(source, j);
			if (_is_ident_continue(c) == false) {
				break;
			}
			j = j + 1;
		}
		word: string = _slice(source, i, j);
		drop(ch);
		if (word == "true" || word == "false") {
			return FclLexTokenResult(0, "bool", word, i, j, j);
		}
		return FclLexTokenResult(0, "identifier", word, i, j, j);
	}

	tok: FclLexTokenResult = FclLexTokenResult(-84, "invalid", ch, i, i + 1, i + 1);
	return tok;
}

export fn status(&token: FclLexTokenResult) -> int32 {
	return token.status;
}

export fn kind(&token: FclLexTokenResult) -> string {
	return "" + token.kind;
}

export fn lexeme(&token: FclLexTokenResult) -> string {
	return "" + token.lexeme;
}

export fn start(&token: FclLexTokenResult) -> int32 {
	return token.start;
}

export fn end(&token: FclLexTokenResult) -> int32 {
	return token.end;
}

export fn next_index(&token: FclLexTokenResult) -> int32 {
	return token.next_index;
}
