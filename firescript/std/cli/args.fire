// firescript std.cli.args library

directive enable_process_args;

export fn argc() -> int32 {
    return process_argc();
}

export fn argv_at(index: int32) -> string {
    return process_argv_at(index);
}

fn _str_len(&value: string) -> int32 {
    return str_length(value);
}

fn _starts_with(&value: string, &prefix: string) -> bool {
    return str_index_of(value, prefix) == 0;
}

fn _looks_like_option_token(&value: string) -> bool {
    if (value == "-") {
        return false;
    }
    return _starts_with(value, "-") == true;
}

fn _is_grouped_short_token(&value: string) -> bool {
    if (_starts_with(value, "-") == false) {
        return false;
    }
    if (_starts_with(value, "--")) {
        return false;
    }
    if (_str_len(value) <= 2) {
        return false;
    }
    if (str_index_of(value, "=") >= 0) {
        return false;
    }
    return true;
}

fn _group_has_short(&token: string, &short_name: string) -> bool {
    if (_str_len(short_name) != 1) {
        return false;
    }
    i: int32 = 1;
    while (i < _str_len(token)) {
        ch: string = str_char_at(token, i);
        if (ch == short_name) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn _value_after_equals(&token: string) -> string {
    eq: int32 = str_index_of(token, "=");
    if (eq < 0) {
        return "";
    }
    start: int32 = eq + 1;
    return str_slice(token, start, _str_len(token));
}

export fn has_flag(name: string) -> bool {
    short_flag: string = "-" + name;
    long_flag: string = "--" + name;
    i: int32 = 1;
    while (i < argc()) {
        arg: string = argv_at(i);
        if (arg == "--") {
            return false;
        }
        if (arg == short_flag) {
            return true;
        }
        if (arg == long_flag) {
            return true;
        }
        if (_is_grouped_short_token(arg)) {
            if (_group_has_short(arg, name)) {
                return true;
            }
        }
        i = i + 1;
    }
    return false;
}

export fn has_flag_alias(long_name: string, short_name: string) -> bool {
    short_flag: string = "-" + short_name;
    long_flag: string = "--" + long_name;
    i: int32 = 1;
    while (i < argc()) {
        arg: string = argv_at(i);
        if (arg == "--") {
            return false;
        }
        if (arg == short_flag) {
            return true;
        }
        if (arg == long_flag) {
            return true;
        }
        if (_is_grouped_short_token(arg)) {
            if (_group_has_short(arg, short_name)) {
                return true;
            }
        }
        i = i + 1;
    }
    return false;
}

export fn option_value(name: string, fallback: string) -> string {
    short_flag: string = "-" + name;
    long_flag: string = "--" + name;
    short_eq: string = short_flag + "=";
    long_eq: string = long_flag + "=";
    i: int32 = 1;
    while (i < argc()) {
        arg: string = argv_at(i);
        if (arg == "--") {
            return fallback;
        }
        if (arg == short_flag) {
            next: int32 = i + 1;
            if (next < argc()) {
                next_value: string = argv_at(next);
                if (_looks_like_option_token(next_value) == false) {
                    return next_value;
                }
            }
            i = i + 1;
            continue;
        }
        if (arg == long_flag) {
            next: int32 = i + 1;
            if (next < argc()) {
                next_value: string = argv_at(next);
                if (_looks_like_option_token(next_value) == false) {
                    return next_value;
                }
            }
            i = i + 1;
            continue;
        }
        if (_starts_with(arg, short_eq)) {
            result: string = _value_after_equals(arg);
            drop(arg);
            return result;
        }
        if (_starts_with(arg, long_eq)) {
            result: string = _value_after_equals(arg);
            drop(arg);
            return result;
        }
        i = i + 1;
    }
    return fallback;
}

export fn option_value_alias(long_name: string, short_name: string, fallback: string) -> string {
    short_flag: string = "-" + short_name;
    long_flag: string = "--" + long_name;
    short_eq: string = short_flag + "=";
    long_eq: string = long_flag + "=";
    i: int32 = 1;
    while (i < argc()) {
        arg: string = argv_at(i);
        if (arg == "--") {
            return fallback;
        }
        if (arg == short_flag) {
            next: int32 = i + 1;
            if (next < argc()) {
                next_value: string = argv_at(next);
                if (_looks_like_option_token(next_value) == false) {
                    return next_value;
                }
            }
            i = i + 1;
            continue;
        }
        if (arg == long_flag) {
            next: int32 = i + 1;
            if (next < argc()) {
                next_value: string = argv_at(next);
                if (_looks_like_option_token(next_value) == false) {
                    return next_value;
                }
            }
            i = i + 1;
            continue;
        }
        if (_starts_with(arg, short_eq)) {
            result: string = _value_after_equals(arg);
            drop(arg);
            return result;
        }
        if (_starts_with(arg, long_eq)) {
            result: string = _value_after_equals(arg);
            drop(arg);
            return result;
        }
        if (_str_len(short_name) == 1) {
            if (_starts_with(arg, short_flag)) {
                if (_str_len(arg) > 2) {
                    result: string = str_slice(arg, 2, _str_len(arg));
                    drop(arg);
                    return result;
                }
            }
        }
        i = i + 1;
    }
    return fallback;
}

export fn positional(index: int32, fallback: string) -> string {
    raw_index: int32 = index + 1;
    if (raw_index < 1) {
        return fallback;
    }
    if (raw_index >= argc()) {
        return fallback;
    }
    return argv_at(raw_index);
}

export fn positional_value(index: int32, fallback: string) -> string {
    if (index < 0) {
        return fallback;
    }

    logical_pos: int32 = 0;
    i: int32 = 1;
    parsing_options: bool = true;

    while (i < argc()) {
        arg: string = argv_at(i);

        if (parsing_options) {
            if (arg == "--") {
                parsing_options = false;
                i = i + 1;
                continue;
            }

            if (_starts_with(arg, "--")) {
                if (str_index_of(arg, "=") >= 0) {
                    i = i + 1;
                    continue;
                }
                next: int32 = i + 1;
                if (next < argc()) {
                    next_value: string = argv_at(next);
                    if (_looks_like_option_token(next_value) == false) {
                        i = i + 2;
                        continue;
                    }
                }
                i = i + 1;
                continue;
            }

            if (_starts_with(arg, "-")) {
                n: int32 = _str_len(arg);
                if (n == 1) {
                    if (logical_pos == index) {
                        return arg;
                    }
                    logical_pos = logical_pos + 1;
                    i = i + 1;
                    continue;
                }

                if (str_index_of(arg, "=") >= 0) {
                    i = i + 1;
                    continue;
                }

                if (n == 2) {
                    next: int32 = i + 1;
                    if (next < argc()) {
                        next_value: string = argv_at(next);
                        if (_looks_like_option_token(next_value) == false) {
                            i = i + 2;
                            continue;
                        }
                    }
                    i = i + 1;
                    continue;
                }

                i = i + 1;
                continue;
            }
        }

        if (logical_pos == index) {
            return arg;
        }
        logical_pos = logical_pos + 1;
        i = i + 1;
    }

    return fallback;
}
