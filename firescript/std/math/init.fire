// firescript std.math library
// Simple math utilities and basic trig

constraint Numeric = int8 | int16 | int32 | int64 | uint8 | uint16 | uint32 | uint64 | float32 | float64 | float128;

const PI64: float64 = 3.141592653589793f64;
const PI_2_64: float64 = 1.5707963267948966f64;

const TWO_PI: float64 = PI64 * 2.0;

export fn abs<T: Numeric>(x: T, zero: T) -> T {
	if (x < zero) {
		return -x;
	}
	return x;
}

export fn min<T: Numeric>(a: T, b: T) -> T {
	if (a < b) {
		return a;
	}
	return b;
}

export fn max<T: Numeric>(a: T, b: T) -> T {
	if (a > b) {
		return a;
	}
	return b;
}

export fn clamp<T: Numeric>(x: T, lo: T, hi: T) -> T {
	if (x < lo) {
		return lo;
	}
	if (x > hi) {
		return hi;
	}
	return x;
}

fn lerp<T: Numeric>(a: T, b: T, t: T) -> T {
	return a + (b - a) * t;
}

fn deg_to_rad(degrees: float64) -> float64 {
	return degrees * (PI64 / 180.0);
}

fn rad_to_deg(radians: float64) -> float64 {
	return radians * (180.0 / PI64);
}

fn pow_int<T: Numeric>(base: T, exp: int32, one: T) -> T {
	result: T = one;
	i: int32 = 0;
	while (i < exp) {
		result = result * base;
		i++;
	}
	return result;
}

fn pow(base: float64, exp: int32) -> float64 {
	result: float64 = 1.0;
	i: int32 = 0;
	while (i < exp) {
		result = result * base;
		i++;
	}
	return result;
}

fn sqrt(x: float64) -> float64 {
	if (x <= 0.0) {
		return 0.0;
	}
	guess: float64 = x;
	i: int32 = 0;
	while (i < 20) {
		guess = 0.5 * (guess + (x / guess));
		i++;
	}
	return guess;
}

fn _wrap_radians(x: float64) -> float64 {
	while (x > PI64) {
		x = x - TWO_PI;
	}
	while (x < -PI64) {
		x = x + TWO_PI;
	}
	return x;
}

fn sin(x: float64) -> float64 {
	x = _wrap_radians(x);
	term: float64 = x;
	sum: float64 = x;
	n: int32 = 1;
	while (n < 6) {
		n_f64: float64 = (n as float64);
		denom: float64 = (2.0 * n_f64) * (2.0 * n_f64 + 1.0);
		term = -term * x * x / denom;
		sum = sum + term;
		n++;
	}
	return sum;
}

fn cos(x: float64) -> float64 {
	x = _wrap_radians(x);
	term: float64 = 1.0;
	sum: float64 = 1.0;
	n: int32 = 1;
	while (n < 6) {
		n_f64: float64 = (n as float64);
		denom: float64 = (2.0 * n_f64 - 1.0) * (2.0 * n_f64);
		term = -term * x * x / denom;
		sum = sum + term;
		n++;
	}
	return sum;
}

fn tan(x: float64) -> float64 {
	c: float64 = cos(x);
	return sin(x) / c;
}
