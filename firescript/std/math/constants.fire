// firescript math constants
// TODO: verify these values and precisions

// ========== Pi Constants ==========
// Pi constants for different floating-point precisions
const PI32: float32 = 3.1415927f32;
const PI64: float64 = 3.141592653589793f64;
const PI128: float128 = 3.14159265358979323846264338327950288f128;

// Pi/2 - Half of pi
const PI_2_32: float32 = 1.5707963267948966f32;
const PI_2_64: float64 = 1.5707963267948966f64;
const PI_2_128: float128 = 1.57079632679489661923132169163975144f128;

// Pi/4 - Quarter of pi
const PI_4_32: float32 = 0.7853981633974483f32;
const PI_4_64: float64 = 0.7853981633974483f64;
const PI_4_128: float128 = 0.785398163397448309615660845819875721f128;

// 1/Pi - Reciprocal of pi
const INV_PI32: float32 = 0.31830988618379067f32;
const INV_PI64: float64 = 0.31830988618379067f64;
const INV_PI128: float128 = 0.318309886183790671537767526745028724f128;

// 2/Pi - Two times the reciprocal of pi
const TWO_INV_PI32: float32 = 0.6366197723675814f32;
const TWO_INV_PI64: float64 = 0.6366197723675814f64;
const TWO_INV_PI128: float128 = 0.636619772367581343075535053490057448f128;

// sqrt(Pi) - Square root of pi
const SQRT_PI32: float32 = 1.7724538509055159f32;
const SQRT_PI64: float64 = 1.7724538509055159f64;
const SQRT_PI128: float128 = 1.77245385090551602729816748334114518f128;

// 2/sqrt(Pi) - Two divided by square root of pi
const TWO_INV_SQRT_PI32: float32 = 1.1283791670955126f32;
const TWO_INV_SQRT_PI64: float64 = 1.1283791670955126f64;
const TWO_INV_SQRT_PI128: float128 = 1.12837916709551257389615890312154517f128;

// ln(Pi) - Natural logarithm of pi
const LN_PI32: float32 = 1.1447298858494002f32;
const LN_PI64: float64 = 1.1447298858494002f64;
const LN_PI128: float128 = 1.14472988584940017414342735135305871f128;

// ========== Euler's Number Constants ==========
// Euler's number constants for different floating-point precisions
const E32: float32 = 2.7182817f32;
const E64: float64 = 2.718281828459045f64;
const E128: float128 = 2.7182818284590452353602874713526624977572f128;

// log2(e) - Base-2 logarithm of e
const LOG2_E32: float32 = 1.4426950408889634f32;
const LOG2_E64: float64 = 1.4426950408889634f64;
const LOG2_E128: float128 = 1.44269504088896340735992468100189214f128;

// log10(e) - Base-10 logarithm of e
const LOG10_E32: float32 = 0.4342944819032518f32;
const LOG10_E64: float64 = 0.4342944819032518f64;
const LOG10_E128: float128 = 0.434294481903251827651128918916605082f128;

// ========== Natural Logarithm Constants ==========
// ln(2) - Natural logarithm of 2
const LN_2_32: float32 = 0.6931471805599453f32;
const LN_2_64: float64 = 0.6931471805599453f64;
const LN_2_128: float128 = 0.693147180559945309417232121458176568f128;

// ln(10) - Natural logarithm of 10
const LN_10_32: float32 = 2.302585092994046f32;
const LN_10_64: float64 = 2.302585092994046f64;
const LN_10_128: float128 = 2.30258509299404568401799145468436421f128;

// ========== Square Root Constants ==========
// sqrt(2) - Square root of 2
const SQRT_2_32: float32 = 1.4142135623730951f32;
const SQRT_2_64: float64 = 1.4142135623730951f64;
const SQRT_2_128: float128 = 1.41421356237309504880168872420969808f128;

// sqrt(3) - Square root of 3
const SQRT_3_32: float32 = 1.7320508075688772f32;
const SQRT_3_64: float64 = 1.7320508075688772f64;
const SQRT_3_128: float128 = 1.73205080756887729352744634150587237f128;

// sqrt(1/2) or 1/sqrt(2) - Square root of one-half
const SQRT_1_2_32: float32 = 0.7071067811865476f32;
const SQRT_1_2_64: float64 = 0.7071067811865476f64;
const SQRT_1_2_128: float128 = 0.707106781186547524400844362104849039f128;

// ========== Special Mathematical Constants ==========
// Euler-Mascheroni constant (gamma) - γ ≈ 0.5772156649...
const EULER_GAMMA32: float32 = 0.5772156649015329f32;
const EULER_GAMMA64: float64 = 0.5772156649015329f64;
const EULER_GAMMA128: float128 = 0.577215664901532860606512090082402431f128;

// Golden ratio (phi) - φ = (1 + sqrt(5))/2 ≈ 1.618033988...
const PHI32: float32 = 1.618033988749895f32;
const PHI64: float64 = 1.618033988749895f64;
const PHI128: float128 = 1.61803398874989484820458683436563812f128;

// Catalan's constant - G ≈ 0.915965594...
const CATALAN32: float32 = 0.915965594177219f32;
const CATALAN64: float64 = 0.915965594177219f64;
const CATALAN128: float128 = 0.915965594177219015054603514932384110f128;

// ========== Degree/Radian Conversion ==========
// Degrees to radians multiplier - π/180
const DEG_TO_RAD32: float32 = 0.017453292519943295f32;
const DEG_TO_RAD64: float64 = 0.017453292519943295f64;
const DEG_TO_RAD128: float128 = 0.0174532925199432957692369076848861271f128;

// Radians to degrees multiplier - 180/π
const RAD_TO_DEG32: float32 = 57.29577951308232f32;
const RAD_TO_DEG64: float64 = 57.29577951308232f64;
const RAD_TO_DEG128: float128 = 57.2957795130823208767981548141051703f128;