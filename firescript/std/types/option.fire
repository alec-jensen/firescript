class Option<T?> {
    T value?;

    Option(T value?) {
        this.value = value;
    }

    bool isSome() {
        return this.value != null;
    }

    bool isNone() {
        return this.value == null;
    }
}

copyable class CopyableOption<T?> {
    T value?;

    CopyableOption(T value?) {
        this.value = value;
    }

    bool isSome() {
        return this.value != null;
    }

    bool isNone() {
        return this.value == null;
    }
}