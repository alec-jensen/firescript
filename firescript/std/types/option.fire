class Option<T?> {
    value: T?;

    fn Option(value: T?) {
        this.value = value;
    }

    fn isSome() -> bool {
        return this.value != null;
    }

    fn isNone() -> bool {
        return this.value == null;
    }
}

copyable class CopyableOption<T?> {
    value: T?;

    fn CopyableOption(value: T?) {
        this.value = value;
    }

    fn isSome() -> bool {
        return this.value != null;
    }

    fn isNone() -> bool {
        return this.value == null;
    }
}