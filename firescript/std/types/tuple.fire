// Tuple types: immutable, copyable product types.
// A Tuple holds two values of potentially different types.

class Tuple<T, U> {
    first: T;
    second: U;

    fn Tuple(first: T, second: U) {
        this.first = first;
        this.second = second;
    }
}

copyable class CopyableTuple<T, U> {
    first: T;
    second: U;

    fn CopyableTuple(first: T, second: U) {
        this.first = first;
        this.second = second;
    }
}