// firescript std.regex library
// Public entry points for the regex module.

// TODO: Currently, errors in regex pattern are entirely runtime. firescript needs a way for modules/libraries
// to run compile-time analysis so that regex pattern errors can be reported at compile time.

directive enable_process_args;

import @firescript/std.regex.pattern.RegexPattern;

export fn is_match(pattern: string, text: string) -> bool {
    result: bool = RegexPattern(pattern).is_match(text);
    return result;
}

export fn find_match(pattern: string, text: string) -> bool {
    result: bool = RegexPattern(pattern).matches(text);
    return result;
}

export fn find_at(pattern: string, text: string, start_pos: int32) -> int32 {
    result: int32 = RegexPattern(pattern).find_at(text, start_pos);
    return result;
}

export fn last_error(pattern: string) -> string {
    return RegexPattern(pattern).last_error();
}
