// firescript std.regex pattern engine
// v2: full-string match, position-aware matching, anchors, and basic quantifiers

directive enable_process_args;

export class RegexPattern {
    pattern: string;           // The core pattern without anchors
    anchor_start: bool;        // True if pattern began with ^
    anchor_end: bool;          // True if pattern ended with $

    fn RegexPattern(&mut this, original_pattern: string) {
        // Parse and strip anchors from pattern
        plen: int32 = str_length(original_pattern);
        start: int32 = 0;
        end: int32 = plen;
        
        this.anchor_start = false;
        this.anchor_end = false;
        
        // Check for leading ^
        if (plen > 0 && str_char_at(original_pattern, 0) == "^") {
            this.anchor_start = true;
            start = 1;
        }
        
        // Check for trailing $
        if (plen > 0 && str_char_at(original_pattern, plen - 1) == "$") {
            this.anchor_end = true;
            end = plen - 1;
        }
        
        // Extract core pattern using str_slice
        if (start < end) {
            this.pattern = str_slice(original_pattern, start, end);
        } else {
            this.pattern = "";
        }
    }

    // ----- Helper methods (instance) -----
    fn _decode_escape_char(&this, esc: &string) -> string {
        if (esc == "n") {
            return "\n";
        }
        if (esc == "t") {
            return "\t";
        }
        if (esc == "r") {
            return "\r";
        }
        return "" + esc;
    }

    fn _is_quantifier(&this, ch: &string) -> bool {
        if (ch == "*") {
            return true;
        }
        if (ch == "+") {
            return true;
        }
        if (ch == "?") {
            return true;
        }
        return false;
    }

    fn _find_matching_paren(&this, open_index: int32, end_index: int32) -> int32 {
        depth: int32 = 0;
        i: int32 = open_index;

        while (i < end_index) {
            ch: string = str_char_at(this.pattern, i);

            if (ch == "\\") {
                i = i + 2;
                continue;
            }

            if (ch == "(") {
                depth = depth + 1;
            } else if (ch == ")") {
                depth = depth - 1;
                if (depth == 0) {
                    return i;
                }
            }

            i = i + 1;
        }

        return -1;
    }

    fn _find_matching_class_end(&this, open_index: int32, end_index: int32) -> int32 {
        i: int32 = open_index + 1;

        while (i < end_index) {
            ch: string = str_char_at(this.pattern, i);
            if (ch == "\\") {
                i = i + 2;
                continue;
            }
            if (ch == "]") {
                return i;
            }
            i = i + 1;
        }

        return -1;
    }

    fn _char_between(&this, c: &string, lo: string, hi: string) -> bool {
        range_order: string = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
        c_idx: int32 = str_index_of(range_order, c);
        lo_idx: int32 = str_index_of(range_order, lo);
        hi_idx: int32 = str_index_of(range_order, hi);

        if (c_idx < 0 || lo_idx < 0 || hi_idx < 0) {
            return false;
        }
        return c_idx >= lo_idx && c_idx <= hi_idx;
    }

    fn _class_contains(&this, class_start: int32, class_end: int32, c: &string) -> bool {
        i: int32 = class_start + 1;
        negated: bool = false;
        matched: bool = false;

        if (i < class_end && str_char_at(this.pattern, i) == "^") {
            negated = true;
            i = i + 1;
        }

        while (i < class_end) {
            first: string = str_char_at(this.pattern, i);
            first_val: string = "";

            if (first == "\\") {
                if (i + 1 >= class_end) {
                    drop(first);
                    return false;
                }
                esc: string = str_char_at(this.pattern, i + 1);
                first_val = this._decode_escape_char(esc);
                drop(esc);
                drop(first);
                i = i + 2;
            } else {
                first_val = first;
                i = i + 1;
            }

            if (i + 1 < class_end && str_char_at(this.pattern, i) == "-") {
                rhs_i: int32 = i + 1;
                rhs_raw: string = str_char_at(this.pattern, rhs_i);
                last_val: string = "";

                if (rhs_raw == "\\") {
                    if (rhs_i + 1 >= class_end) {
                        drop(rhs_raw);
                        drop(first_val);
                        return false;
                    }
                    esc2: string = str_char_at(this.pattern, rhs_i + 1);
                    last_val = this._decode_escape_char(esc2);
                    drop(esc2);
                    drop(rhs_raw);
                    i = rhs_i + 2;
                } else {
                    last_val = rhs_raw;
                    i = rhs_i + 1;
                }

                if (this._char_between(c, first_val, last_val)) {
                    matched = true;
                }
                continue;
            }

            if (c == first_val) {
                matched = true;
            }
            drop(first_val);
        }

        if (negated) {
            return matched == false;
        }
        return matched;
    }

    fn _match_one_atom(&this, atom_start: int32, atom_end: int32, text: &string, cur: int32, t_len: int32) -> int32 {
        if (cur >= t_len) {
            return -1;
        }

        atom_ch: string = str_char_at(this.pattern, atom_start);
        text_ch: string = str_char_at(text, cur);

        if (atom_ch == "(") {
            return this._match_range(atom_start + 1, atom_end - 1, text, cur, t_len);
        }

        if (atom_ch == ".") {
            return cur + 1;
        }

        if (atom_ch == "[") {
            if (this._class_contains(atom_start, atom_end - 1, text_ch)) {
                return cur + 1;
            }
            return -1;
        }

        if (atom_ch == "\\") {
            esc_ch: string = str_char_at(this.pattern, atom_start + 1);
            want_ch: string = this._decode_escape_char(esc_ch);
            if (want_ch == text_ch) {
                return cur + 1;
            }
            return -1;
        }

        if (text_ch == atom_ch) {
            return cur + 1;
        }
        return -1;
    }

    fn _match_range(&this, p_start: int32, p_end: int32, text: &string, t_index: int32, t_len: int32) -> int32 {
        // Expression level: split by top-level alternation first.
        depth: int32 = 0;
        i: int32 = p_start;
        while (i < p_end) {
            ch: string = str_char_at(this.pattern, i);

            if (ch == "\\") {
                i = i + 2;
                continue;
            }

            if (ch == "(") {
                depth = depth + 1;
            } else if (ch == ")") {
                depth = depth - 1;
            } else if (ch == "|" && depth == 0) {
                left: int32 = this._match_range(p_start, i, text, t_index, t_len);
                if (left >= 0) {
                    return left;
                }
                return this._match_range(i + 1, p_end, text, t_index, t_len);
            }

            i = i + 1;
        }

        // Sequence level.
        p: int32 = p_start;
        cur: int32 = t_index;

        while (p < p_end) {
            ch0: string = str_char_at(this.pattern, p);

            if (ch0 == "|") {
                return -1;
            }
            if (this._is_quantifier(ch0)) {
                return -1;
            }

            atom_start: int32 = p;
            atom_end: int32 = p + 1;

            if (ch0 == "\\") {
                atom_end = p + 2;
                if (atom_end > p_end) {
                    return -1;
                }
            } else if (ch0 == "[") {
                class_close: int32 = this._find_matching_class_end(p, p_end);
                if (class_close < 0) {
                    return -1;
                }
                atom_end = class_close + 1;
            } else if (ch0 == "(") {
                close: int32 = this._find_matching_paren(p, p_end);
                if (close < 0) {
                    return -1;
                }
                atom_end = close + 1;
            } else if (ch0 == ")") {
                return -1;
            }

            quant: string = "";
            next_pattern: int32 = atom_end;
            if (atom_end < p_end) {
                maybe_q: string = str_char_at(this.pattern, atom_end);
                if (this._is_quantifier(maybe_q)) {
                    quant = maybe_q;
                    next_pattern = atom_end + 1;
                } else {
                    drop(maybe_q);
                }
            }

            one: int32 = this._match_one_atom(atom_start, atom_end, text, cur, t_len);

            if (quant == "") {
                if (one < 0) {
                    return -1;
                }
                cur = one;
                p = next_pattern;
                continue;
            }

            if (quant == "?") {
                if (one >= 0) {
                    with_one: int32 = this._match_range(next_pattern, p_end, text, one, t_len);
                    if (with_one >= 0) {
                        return with_one;
                    }
                }
                return this._match_range(next_pattern, p_end, text, cur, t_len);
            }

            if (quant == "*") {
                if (one < 0 || one == cur) {
                    return this._match_range(next_pattern, p_end, text, cur, t_len);
                }

                // Greedy first, then backtrack to zero-consumption path.
                greedy: int32 = this._match_range(p, p_end, text, one, t_len);
                if (greedy >= 0) {
                    return greedy;
                }
                return this._match_range(next_pattern, p_end, text, cur, t_len);
            }

            // quant == '+'
            if (one < 0 || one == cur) {
                return -1;
            }

            greedy_plus: int32 = this._match_range(p, p_end, text, one, t_len);
            if (greedy_plus >= 0) {
                return greedy_plus;
            }
            return this._match_range(next_pattern, p_end, text, one, t_len);
        }

        return cur;
    }

    fn _validate_pattern(&this) -> string {
        n: int32 = str_length(this.pattern);
        
        // Pattern should not be empty (anchors are stripped)
        if (n == 0) {
            return "pattern is empty";
        }
        
        i: int32 = 0;
        depth: int32 = 0;
        can_quantify: bool = false;

        while (i < n) {
            ch: string = str_char_at(this.pattern, i);

            if (ch == "\\") {
                if (i + 1 >= n) {
                    return "dangling escape at end of pattern";
                }
                can_quantify = true;
                i = i + 2;
                continue;
            }

            if (ch == "(") {
                depth = depth + 1;
                can_quantify = false;
            } else if (ch == "[") {
                class_end: int32 = this._find_matching_class_end(i, n);
                if (class_end < 0) {
                    return "unmatched '[' in pattern";
                }
                if (class_end == i + 1) {
                    return "empty character class";
                }
                i = class_end;
                can_quantify = true;
            } else if (ch == ")") {
                if (depth == 0) {
                    return "unmatched ')' in pattern";
                }
                depth = depth - 1;
                can_quantify = true;
            } else if (this._is_quantifier(ch)) {
                if (can_quantify == false) {
                    return "quantifier without target";
                }
                can_quantify = true;
            } else if (ch == "|") {
                can_quantify = false;
            } else {
                can_quantify = true;
            }

            i = i + 1;
        }

        if (depth != 0) {
            return "unmatched '(' in pattern";
        }

        return "";
    }

    fn _match_full(&this, text: &string) -> bool {
        p_len: int32 = str_length(this.pattern);
        t_len: int32 = str_length(text);
        end: int32 = this._match_range(0, p_len, text, 0, t_len);
        
        // If anchor_end is set, must match exactly to end of text
        if (this.anchor_end) {
            return end == t_len;
        }
        
        // Otherwise, must consume entire text
        return end == t_len;
    }

    fn _match_at_position(&this, text: &string, start_pos: int32) -> int32 {
        t_len: int32 = str_length(text);
        
        // Check if start position is valid
        if (start_pos < 0 || start_pos > t_len) {
            return -1;
        }
        
        // If anchor_start is set, can only match at position 0
        if (this.anchor_start && start_pos != 0) {
            return -1;
        }
        
        // Try to match pattern starting at start_pos
        p_len: int32 = str_length(this.pattern);
        matched_end: int32 = this._match_range(0, p_len, text, start_pos, t_len);
        
        if (matched_end < 0) {
            return -1;
        }
        
        // If anchor_end is set, must match to end of text
        if (this.anchor_end && matched_end != t_len) {
            return -1;
        }
        
        return matched_end - start_pos;  // Return match length
    }

    // ----- Public methods -----
    fn is_match(&this, text: &string) -> bool {
        err: string = this._validate_pattern();
        if (err != "") {
            return false;
        }

        return this._match_full(text);
    }

    fn matches(&this, text: &string) -> bool {
        return this.is_match(text);
    }

    fn find_at(&this, text: &string, start_pos: int32) -> int32 {
        err: string = this._validate_pattern();
        if (err != "") {
            return -1;
        }
        
        return this._match_at_position(text, start_pos);
    }

    fn last_error(&this) -> string {
        return this._validate_pattern();
    }
}